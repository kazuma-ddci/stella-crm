# ============================================
# Database connection
# ============================================
# ローカル: postgresql://postgres:postgres@db:5432/crm_db
# 本番:     postgresql://USER:PASSWORD@db-prod:5432/DB_NAME
DATABASE_URL="postgresql://postgres:postgres@db:5432/crm_db"

# PostgreSQL container settings (docker-compose.prod/stg.yml で使用)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="crm_db"

# ============================================
# Auth.js configuration
# ============================================
# 生成方法: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ============================================
# Email configuration (SMTP/Gmail)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
EMAIL_FROM="your-email@example.com"

# ============================================
# Application URL (for email links)
# ============================================
# ローカル: http://localhost:3000
# 本番:     https://your-domain.com or http://VPS_IP:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# External domain (BBS / Vendor page URL)
# ============================================
# ローカル: http://localhost:3000
# stg:      https://stg-bbs.alkes.jp / https://stg-vendor.alkes.jp / https://stg-loan.alkes.jp
# 本番:     https://bbs.alkes.jp / https://vendor.alkes.jp / https://loan.alkes.jp
NEXT_PUBLIC_BBS_DOMAIN="http://localhost:3000"
NEXT_PUBLIC_VENDOR_DOMAIN="http://localhost:3000"
NEXT_PUBLIC_LENDER_DOMAIN="http://localhost:3000"
# SLPの顧客向け公開ドメイン（資料・動画ビューアURLの生成に使用）
# 本番: https://customer.koutekiseido-japan.com
# stg:  https://stg-customer.koutekiseido-japan.com
NEXT_PUBLIC_SLP_CUSTOMER_URL="http://localhost:3000"

# ============================================
# Application display name
# ============================================
# ローカル/本番: Stella CRM
# ステージング:  Stella CRM テスト環境
NEXT_PUBLIC_APP_TITLE="Stella 基幹OS"

# ============================================
# Google API (Slides/Drive)
# ============================================
# サービスアカウント認証キーのパス
GOOGLE_SERVICE_ACCOUNT_KEY_PATH="./credentials/google-service-account.json"
# テンプレートスライドID（全環境共通）
GOOGLE_SLIDE_TEMPLATE_ID="your-template-slide-id"
# 環境別の出力フォルダID（企業フォルダの親）
# ローカル: 1228pCZ42GoELTDACUlZiMDPctYGxr8LX
# stg:     1jM2vFq7H5DXBwxedPsciEtlVJGoq8K7o
# 本番:    1RcfhFaV7iM2p_DKvLhxgG2DHTd4mZKf
GOOGLE_DRIVE_OUTPUT_FOLDER_ID="your-output-folder-id"
# 環境別の「紐付け前」フォルダID
GOOGLE_DRIVE_UNLINKED_FOLDER_ID="your-unlinked-folder-id"

# ============================================
# CloudSign Webhook
# ============================================
# CloudSignのWebhook URLに ?token=<ここの値> を付与してトークン認証する
# 生成方法: openssl rand -hex 32
# 未設定の場合はトークン検証なし（誰でもWebhookを叩ける状態になる）
CLOUDSIGN_WEBHOOK_SECRET=""

# ============================================
# Cron 認証トークン
# ============================================
# /api/cron/* エンドポイントのBearer認証用。生成方法: openssl rand -hex 32
CRON_SECRET=""

# ============================================
# AES-256-GCM 暗号化キー（Zoom OAuthトークンなど機密情報の保存用）
# 生成方法: openssl rand -base64 32  （32バイト/base64）
# ============================================
ENCRYPTION_KEY=""

# ============================================
# Zoom 連携（OAuth + Webhook）
# Zoom App Marketplace で User-managed OAuth App を作成して取得
# Redirect URL 登録: {NEXT_PUBLIC_APP_URL}/api/integrations/zoom/callback
# Webhook URL 登録: {NEXT_PUBLIC_APP_URL}/api/webhooks/zoom
# Scopes: meeting:write:meeting meeting:read:meeting meeting:update:meeting
#         meeting:delete:meeting cloud_recording:read:recording
#         meeting:read:transcript user:read:user
# ============================================
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
ZOOM_WEBHOOK_SECRET=""

# ============================================
# Anthropic Claude API（Zoom議事録要約・お礼メッセージ生成）
# ============================================
ANTHROPIC_API_KEY=""
