# 補助金プロジェクト ProLine同期 環境変数
# コピーして .env.sync.hojo として保存し、値を埋めてください
# cp sync-proline-hojo-env.example .env.sync.hojo

# 共通
CRON_SECRET=（.env.prodのCRON_SECRETと同じ値）
APP_URL=http://localhost:4001

# 申請サポートセンター
HOJO_SHINSEI_PROLINE_EMAIL=
HOJO_SHINSEI_PROLINE_PASSWORD=
HOJO_SHINSEI_PROLINE_LOGIN_UID=

# 一般社団法人助成金申請サポート
HOJO_JOSEI_PROLINE_EMAIL=
HOJO_JOSEI_PROLINE_PASSWORD=
HOJO_JOSEI_PROLINE_LOGIN_UID=

# ALKES
HOJO_ALKES_PROLINE_EMAIL=
HOJO_ALKES_PROLINE_PASSWORD=
HOJO_ALKES_PROLINE_LOGIN_UID=

# セキュリティクラウドサポート
HOJO_SECURITY_PROLINE_EMAIL=
HOJO_SECURITY_PROLINE_PASSWORD=
HOJO_SECURITY_PROLINE_LOGIN_UID=
