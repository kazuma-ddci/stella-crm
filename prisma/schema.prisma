  @@map("usdt_daily_rates")
}

// ============================================
// SLP 組合員 (SLP Members)
// 公的制度教育推進協会の組合員情報を管理
// ============================================

model SlpMember {
  id                       Int       @id @default(autoincrement())
  name                     String    @db.VarChar(100)
  email                    String?   @db.VarChar(255)
  status                   String?   @db.VarChar(50) // 契約書未送付/契約書送付済/組合員契約書締結/契約破棄
  contractSentDate         DateTime?
  contractSignedDate       DateTime?
  position                 String?   @db.VarChar(100)
  company                  String?   @db.VarChar(200)
  memberCategory           String?   @db.VarChar(50) // 個人（法人代表・役員・従業員）/法人担当者/代理店
  lineName                 String?   @db.VarChar(100)
  uid                      String    @unique @db.VarChar(100)
  phone                    String?   @db.VarChar(50)
  address                  String?
  referrerUid              String?   @db.VarChar(100)
  note                     String?
  memo                     String?
  documentId               String?   @db.VarChar(255)
  cloudsignUrl             String?
  reminderCount            Int       @default(0)
  formSubmittedAt          DateTime? // フォーム送信日時
  lastReminderSentAt       DateTime? // 直近リマインド送付日時
  emailChangeCount         Int       @default(0) // メールアドレス変更回数（フォーム経由、上限2回）
  resubmitted              Boolean   @default(false) // 未締結再フォーム送信フラグ（管理者通知用）
  watermarkCode            String?   @unique @db.VarChar(9) // ウォーターマーク用固定コード（XXXX-XXXX形式、変更不可）
  form5NotifyCount         Int       @default(0) // Form5（契約締結通知）送信回数
  form5NotifiedReferrerUid String?   @map("form5_notified_referrer_uid") @db.VarChar(100) // 最後にForm5通知を送信した紹介者UID（free1と比較して未通知判定に使用）
  form5NotifySkippedReferrerUid String? @map("form5_notify_skipped_referrer_uid") @db.VarChar(100) // Form5通知「送信不要」と判断した紹介者UID（free1と比較して未通知判定から除外）
  reminderExcluded         Boolean   @default(false) // 自動リマインド除外フラグ
  richmenuBeaconCalled     Boolean   @default(false) @map("richmenu_beacon_called") // リッチメニュー切り替えビーコンを呼び出し済みか（締結済み / 締結ビーコン D6DJAb2MNC・xZugEszbhx 共通）
  postLinkSentBeaconCalled Boolean   @default(false) @map("post_link_sent_beacon_called") // 後追い紐付け時の「契約書送付済」案内ビーコン（G0JqiTyQx9）呼び出し済みフラグ
  cloudsignBounced         Boolean   @default(false) @map("cloudsign_bounced") // CloudSignメール送信失敗フラグ
  cloudsignBouncedAt       DateTime? @map("cloudsign_bounced_at") // CloudSignメール送信失敗検知日時
  cloudsignBouncedEmail    String?   @map("cloudsign_bounced_email") @db.VarChar(255) // 失敗したメールアドレス
  // 送付履歴・フロー制御フィールド
  bounceConfirmedAt        DateTime? @map("bounce_confirmed_at") // 「間違いない」ボタン押下日時
  bounceFixUsed            Boolean   @default(false) @map("bounce_fix_used") // 不達修正（リトライ）を使用済みか
  emailChangeUsed          Boolean   @default(false) @map("email_change_used") // 成功後のメアド変更を使用済みか
  formLocked               Boolean   @default(false) @map("form_locked") // フォームから完全に操作不可（公式LINE案内）
  autoSendLocked           Boolean   @default(false) @map("auto_send_locked") // 自動送付停止（スタッフ手動対応）
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  referrer         SlpMember?           @relation("MemberReferral", fields: [referrerUid], references: [uid])
  referrals        SlpMember[]          @relation("MemberReferral")
  contracts        MasterContract[]
  contractAttempts SlpContractAttempt[]
  lineLinkRequests SlpLineLinkRequest[]

  @@index([referrerUid])
  @@map("slp_members")
}

// ============================================
// SLP LINE紐付け申請 (SLP LINE Link Requests)
// プロライン構築前の既存組合員が、後から公式LINEを友達追加して
// uidを紐付けるための申請レコード。1uidにつき1レコード（再送信不可）。
// 自動紐付けに失敗したケースはスタッフが手動で対応する。
// ============================================

model SlpLineLinkRequest {
  id                Int        @id @default(autoincrement())
  uid               String     @unique @db.VarChar(100) // フォーム送信時の uid（1uid 1申請）
  submittedLineName String?    @map("submitted_line_name") @db.VarChar(200) // フォーム送信されたLINE名
  submittedEmail    String     @map("submitted_email") @db.VarChar(255) // フォーム送信されたメールアドレス（小文字正規化済み）
  // ステータス:
  //   pending_friend_sync   = SlpLineFriend未着、cronで再処理待ち
  //   pending_staff_review  = 自動判定でスタッフ確認が必要と判定
  //   email_not_found       = メアドがどの組合員にもマッチしなかった（ユーザー画面で案内）
  //   resolved_auto         = フォーム送信時に自動紐付け成功
  //   resolved_manual       = スタッフが手動で紐付け
  //   rejected              = スタッフが却下（嫌がらせ等）
  status            String     @db.VarChar(50)
  // 保留理由（status=pending_staff_review のとき設定）:
  //   line_name_mismatch    = 送信LINE名と公式LINE友達情報のsnsname不一致
  //   email_multiple_match  = メアドが複数の組合員にマッチ
  //   uid_already_linked    = マッチした組合員に既に別のuidが紐付いている
  //   member_deleted        = マッチした組合員が論理削除済み
  //   contract_canceled     = マッチした組合員の status=契約破棄
  //   status_not_sent       = マッチした組合員が「契約書未送付」または「送付エラー」
  reviewReason      String?    @map("review_reason") @db.VarChar(50)
  resolvedMemberId  Int?       @map("resolved_member_id")
  resolvedMember    SlpMember? @relation(fields: [resolvedMemberId], references: [id])
  resolvedAt        DateTime?  @map("resolved_at")
  resolvedByStaffId Int?       @map("resolved_by_staff_id") // スタッフユーザーID（自動の場合はnull）
  beaconCalledAt    DateTime?  @map("beacon_called_at") // 後追い紐付け用ビーコンの実行日時
  beaconType        String?    @map("beacon_type") @db.VarChar(20) // signed=締結済み / sent=送付済み（いずれが発火されたか）
  staffNote         String?    @map("staff_note")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  @@index([status])
  @@index([submittedEmail])
  @@index([resolvedMemberId])
  @@map("slp_line_link_requests")
}

// ============================================
// SLP 契約書送付履歴 (SLP Contract Attempts)
// 組合員への契約書送付の全履歴を管理
// ============================================

model SlpContractAttempt {
  id                Int       @id @default(autoincrement())
  slpMemberId       Int       @map("slp_member_id")
  email             String    @db.VarChar(255) // 送付先メールアドレス
  documentId        String?   @map("document_id") @db.VarChar(255) // CloudSignドキュメントID
  cloudsignUrl      String?   @map("cloudsign_url") @db.VarChar(500) // CloudSign URL
  sendResult        String    @map("send_result") @db.VarChar(20) // delivered / bounced / api_error
  cloudsignStatus   String?   @map("cloudsign_status") @db.VarChar(30) // pending / completed / canceled / unknown
  triggerType       String    @map("trigger_type") @db.VarChar(20) // initial / bounce_fix / email_change / staff_manual
  sequence          Int // 何番目の送付か（1, 2, 3...）
  // スタッフによるAPIエラー時の手動確認結果
  manualCheckResult String?   @map("manual_check_result") @db.VarChar(20) // found_pending / found_completed / not_found
  manualCheckAt     DateTime? @map("manual_check_at")
  manualCheckBy     String?   @map("manual_check_by") @db.VarChar(100)
  // CRMからの破棄操作
  declinedAt        DateTime? @map("declined_at")
  declinedBy        String?   @map("declined_by") @db.VarChar(100)
  declineError      String?   @map("decline_error") // 破棄API失敗時のエラー内容
  createdAt         DateTime  @default(now()) @map("created_at")

  slpMember SlpMember @relation(fields: [slpMemberId], references: [id])

  @@unique([slpMemberId, sequence])
  @@index([slpMemberId])
  @@index([documentId])
  @@map("slp_contract_attempts")
}

// ============================================
// SLP 未照合バウンス通知 (SLP Unmatched Bounces)
// Webhookで受信したがCRM内の契約書にマッチしなかったバウンス通知を保存
// スタッフがAPIエラー時にドキュメントIDを入力した際の照合に使用
// ============================================

model SlpUnmatchedBounce {
  id           Int       @id @default(autoincrement())
  documentId   String    @map("document_id") @db.VarChar(255) // CloudSignドキュメントID
  bouncedEmail String    @map("bounced_email") @db.VarChar(255) // 不達メールアドレス
  webhookText  String?   @map("webhook_text") // Webhookのtextフィールド（デバッグ用）
  matched      Boolean   @default(false) // スタッフの手動確認で照合済みか
  matchedAt    DateTime? @map("matched_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([documentId])
  @@map("slp_unmatched_bounces")
}

// ============================================
// SLP 公式LINE友達情報 (SLP LINE Friends)
// プロライン連携のLINE友達情報を管理
// ============================================

model SlpLineFriend {
  id                  Int       @id @default(autoincrement())
  snsname             String?   @db.VarChar(200) // アカウント名
  password            String?   @db.VarChar(100) // プロラインパスワード
  emailLine           String?   @db.VarChar(255) // LINE送信専用メルアド
  emailRenkei         String?   @db.VarChar(255) // 連携用メールアドレス
  emailLine2          String?   @db.VarChar(255) // LINE送信専用メルアド２
  email               String?   @db.VarChar(255) // メールアドレス（ユーザー入力）
  uid                 String    @unique @db.VarChar(100) // ユーザーID
  friendAddedDate     DateTime? // 友だち追加日
  activeStatus        String?   @db.VarChar(50) // 稼働状態（稼働中/ブロック等）
  lastActivityDate    String?   @db.VarChar(50) // 最終活動日
  sei                 String?   @db.VarChar(100) // 姓
  mei                 String?   @db.VarChar(100) // 名
  nickname            String?   @db.VarChar(100) // ニックネーム
  phone               String?   @db.VarChar(50) // 電話番号
  postcode            String?   @db.VarChar(20) // 郵便番号
  address1            String?   @db.VarChar(255) // 住所１
  address2            String?   @db.VarChar(255) // 住所２
  address3            String?   @db.VarChar(255) // 住所３
  nenrei              String?   @db.VarChar(20) // 年齢
  nendai              String?   @db.VarChar(20) // 年代
  seibetu             String?   @db.VarChar(20) // 性別
  free1               String? // フリー項目１
  free2               String? // フリー項目２
  free3               String? // フリー項目３
  free4               String? // フリー項目４
  free5               String? // フリー項目５
  free6               String? // フリー項目６
  scenarioPos1        String? // シナリオ位置1
  scenarioPos2        String? // 現在の場所2
