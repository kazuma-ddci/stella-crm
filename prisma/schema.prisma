// ============================================
// スタッフ役割種別マスタ (Staff Role Types)
// スタッフが担当できる役割の種別
// ============================================

model StaffRoleType {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(50) // 営業, 運用, CS, AS など
  name         String   @db.VarChar(100) // 表示名
  description  String? // 説明
  displayOrder Int      @default(0) // 表示順
  isActive     Boolean  @default(true) // 有効フラグ
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  staffAssignments  StaffRoleAssignment[]
  projectLinks      StaffRoleTypeProject[]
  fieldRestrictions StaffFieldRestriction[]

  @@map("staff_role_types")
}

// ============================================
// スタッフ役割割当 (Staff Role Assignments) - 廃止予定
// 後方互換のため残存、新規はStaffProjectRoleAssignmentを使用
// ============================================

model StaffRoleAssignment {
  id         Int      @id @default(autoincrement())
  staffId    Int
  roleTypeId Int
  createdAt  DateTime @default(now())

  staff    MasterStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  roleType StaffRoleType @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)

  @@unique([staffId, roleTypeId])
  @@map("staff_role_assignments")
}

// ============================================
// スタッフプロジェクト割当 (Staff Project Assignments)
// スタッフ×プロジェクトの多対多中間テーブル
// 担当者選択時にプロジェクトで絞り込み可能
// ============================================

model StaffProjectAssignment {
  id        Int      @id @default(autoincrement())
  staffId   Int
  projectId Int
  createdAt DateTime @default(now())

  staff   MasterStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  project MasterProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([staffId, projectId])
  @@map("staff_project_assignments")
}

// ============================================
// スタッフ権限 (Staff Permissions)
// プロジェクトごとの閲覧・変更権限を管理
// ============================================

model StaffPermission {
  id              Int      @id @default(autoincrement())
  staffId         Int // master_staffへの外部キー
  projectId       Int // master_projectsへの外部キー
  permissionLevel String   @db.VarChar(20) // none, view, edit, manager
  canApprove      Boolean  @default(false) // 承認権限（支払グループ等の承認が可能）
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  staff   MasterStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  project MasterProject @relation(fields: [projectId], references: [id])

  @@unique([staffId, projectId])
  @@map("staff_permissions")
}

// ============================================
// サイドバー表示設定 (Staff Sidebar Preferences)
// スタッフごとのサイドバーナビ表示/非表示設定
// ============================================

model StaffSidebarPreference {
  id          Int      @id @default(autoincrement())
  staffId     Int      @unique
  hiddenItems String[] @default([]) // 非表示ナビアイテムのキー配列
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff MasterStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("staff_sidebar_preferences")
}

// ============================================
// 契約履歴 (STP Contract Histories)
// ============================================

model StpContractHistory {
  id                Int       @id @default(autoincrement())
  companyId         Int // master_stella_companiesへの外部キー
  industryType      String    @db.VarChar(20) // general（一般）, dispatch（派遣）
  contractPlan      String    @db.VarChar(20) // monthly（月額）, performance（成果報酬）
  jobMedia          String?   @db.VarChar(50) // 求人媒体（Indeed, Wantedly等）
  contractStartDate DateTime  @db.Date // 契約開始日
  contractEndDate   DateTime? @db.Date // 契約終了日（nullの場合アクティブ）
  initialFee        Int // 初期費用（0, 100000, 150000）
  monthlyFee        Int // 月額（契約時点の金額を保存）
  performanceFee    Int // 成果報酬単価（契約時点の金額を保存）
  salesStaffId      Int? // 担当営業（master_staffへの外部キー）
  operationStaffId  Int? // 担当運用（master_staffへの外部キー）
  status            String    @db.VarChar(20) // active, cancelled, dormant
  note              String? // 備考
  operationStatus   String?   @db.VarChar(20) // 運用ステータス（テスト1,テスト2）
  accountId         String?   @db.VarChar(100) // アカウントID
  accountPass       String?   @db.VarChar(100) // アカウントPASS
  masterContractId  Int? // 関連する契約書（master_contractsへの外部キー）
  contractDate      DateTime? @db.Date // 契約日（署名日）— 初期費用の発生日に使用

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // 論理削除日時

  // Relations
  company        MasterStellaCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesStaff     MasterStaff?        @relation("SalesStaff", fields: [salesStaffId], references: [id])
  operationStaff MasterStaff?        @relation("OperationStaff", fields: [operationStaffId], references: [id])
  masterContract MasterContract?     @relation(fields: [masterContractId], references: [id])
  revenueRecords StpRevenueRecord[]
  expenseRecords StpExpenseRecord[]
  transactions   Transaction[]
  mediaAds       StpMediaAd[]

  @@index([masterContractId], map: "idx_stp_contract_histories_master_contract_id")
  @@map("stp_contract_histories")
}

// ============================================
// 請求ルール (STP Billing Rules)
// ============================================

model StpBillingRule {
  id        Int    @id @default(autoincrement())
  projectId Int
  feeType   String // "initial" | "monthly" | "performance"

  // 初期費用用
  invoiceBusinessDays Int? @default(3) // 契約日からN営業日で請求書発行
  paymentBusinessDays Int? @default(5) // 請求書発行からN営業日で支払期限

  // 月額・成果報酬用
  closingDay         Int? @default(0) // 0=末日, 1-28
  paymentMonthOffset Int? @default(1) // 1=翌月
  paymentDay         Int? @default(15) // 15日

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project MasterProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, feeType])
  @@map("stp_billing_rules")
}

// ============================================
// プロジェクトマスタ (Master Projects)
// ============================================

model MasterProject {
  id                           Int     @id @default(autoincrement())
  code                         String  @unique @db.VarChar(50) // 権限管理用コード（例: stp, srd, slp）
  name                         String  @db.VarChar(100)
  description                  String?
  isActive                     Boolean @default(true) @map("is_active")
  displayOrder                 Int     @default(0) @map("display_order")
  operatingCompanyId           Int?    @map("operating_company_id")
  defaultCostCenterId          Int?    @map("default_cost_center_id")
  slpMemberCloudSignTemplateId Int?    @map("slp_member_cloudsign_template_id") // SLP入会フォーム回答後の自動送付契約書(CloudSignテンプレート)
  reminderDays                 Int     @default(7) @map("reminder_days") // 契約書送付から何日後にリマインドするか
  autoSendContract             Boolean @default(true) @map("auto_send_contract") // フォーム回答時の契約書自動送付ON/OFF
  slpForm5AutoSendOnLink       Boolean @default(false) @map("slp_form5_auto_send_on_link") // LINE後紐付け時にForm5（紹介者通知）を自動送信するか
  defaultApproverStaffId       Int?    @map("default_approver_staff_id") // 経費の既定承認者（このプロジェクトで生成される取引に自動セット）

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  operatingCompany           OperatingCompany?             @relation(fields: [operatingCompanyId], references: [id])
  defaultApprover            MasterStaff?                  @relation("ProjectDefaultApprover", fields: [defaultApproverStaffId], references: [id])
  defaultCostCenter          CostCenter?                   @relation("ProjectDefaultCostCenter", fields: [defaultCostCenterId], references: [id])
  slpMemberCloudSignTemplate CloudSignTemplate?            @relation("SlpMemberCloudSignTemplate", fields: [slpMemberCloudSignTemplateId], references: [id])
  contracts                  MasterContract[]
  staffAssignments           StaffProjectAssignment[]
  staffPermissions           StaffPermission[]
  displayViews               DisplayView[]
  contractTypes              ContractType[]
  customerTypes              CustomerType[]
  contactCategories          ContactCategory[]
  accountingTransactions     AccountingTransaction[]
  accountingMonthlyCloses    AccountingMonthlyClose[]
  accountingReconciliations  AccountingReconciliation[]
  roleTypeLinks              StaffRoleTypeProject[]
  fieldDefinitionProjects    StaffFieldDefinitionProject[]
  managingRestrictions       StaffFieldRestriction[]       @relation("ManagingProjectRestrictions")
  sourceRestrictions         StaffFieldRestriction[]       @relation("SourceProjectRestrictions")

  // 経理システム追加Relations
  costCenters              CostCenter[]
  costCenterAssignments    CostCenterProjectAssignment[]
  finTransactions          Transaction[]
  finRecurringTransactions RecurringTransaction[]
  monthlyCloseLogs         MonthlyCloseLog[]
  finInvoiceGroups         InvoiceGroup[]                @relation("ProjectInvoiceGroups")
  finPaymentGroups         PaymentGroup[]                @relation("ProjectPaymentGroups")
  projectEmails            ProjectEmail[]
  projectBankAccounts      ProjectBankAccount[]
  invoiceTemplates         InvoiceTemplate[]
  expenseCategories        ExpenseCategory[]
  journalEntries           JournalEntry[]
  billingRules             StpBillingRule[]

  @@map("master_projects")
}

// ============================================
// 運営法人マスタ (Operating Companies)
// プロジェクトを運営する法人の情報を管理
// ============================================

model OperatingCompany {
  id                 Int      @id @default(autoincrement())
  companyName        String   @db.VarChar(200) // 法人名
  registrationNumber String?  @unique @db.VarChar(20) // 適格請求書発行事業者登録番号（T+13桁）
  postalCode         String?  @db.VarChar(10) // 郵便番号
  address            String? // 住所1
  address2           String? // 住所2
  representativeName String?  @db.VarChar(100) // 代表者名
  phone              String?  @db.VarChar(50) // 電話番号
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // 経理システム追加カラム
  logoPath           String? // ロゴ画像パス
  abbreviation       String? // 略称（例: STE、MTR）→ 請求書番号に使用
  invoicePrefix      String? // 請求書番号プレフィックス
  paymentMonthOffset Int? // 支払月（0=当月, 1=翌月, 2=翌々月...）
  paymentDay         Int? // 支払日（0=末日, 1-28=指定日）

  // クラウドサイン連携
  cloudsignClientId        String? @db.VarChar(500) // クラウドサインWeb APIクライアントID
  cloudsignRegisteredEmail String? @map("cloudsign_registered_email") @db.VarChar(255) // 登録メールアドレス（先方/弊社破棄判定用）

  projects     MasterProject[]
  bankAccounts OperatingCompanyBankAccount[]

  // 経理システム追加Relations
  emails                  OperatingCompanyEmail[]
  invoiceGroups           InvoiceGroup[]
  paymentGroups           PaymentGroup[]
  invoiceTemplates        InvoiceTemplate[]
  invoiceMails            InvoiceMail[]
  invoiceNumberSequences  StpInvoiceNumberSequence[]
  cloudsignTemplates      CloudSignTemplate[]
  accountingTransactions  AccountingTransaction[]
  moneyForwardConnections MoneyForwardConnection[]

  @@map("operating_companies")
}

// ============================================
// 運営法人銀行口座 (Operating Company Bank Accounts)
// ============================================

model OperatingCompanyBankAccount {
  id                 Int       @id @default(autoincrement())
  operatingCompanyId Int // OperatingCompanyへの外部キー
  bankName           String    @db.VarChar(100) // 銀行名
  bankCode           String    @db.VarChar(10) // 銀行コード
  branchName         String    @db.VarChar(100) // 支店名
  branchCode         String    @db.VarChar(10) // 支店コード
  accountType        String    @default("普通") @map("account_type") @db.VarChar(20) // 口座種別（普通/当座/貯蓄/その他）
  accountNumber      String    @db.VarChar(20) // 口座番号
  accountHolderName  String    @db.VarChar(200) // 口座名義人
  note               String? // メモ
  isDefault          Boolean   @default(false) // デフォルト口座フラグ
  paymentMethodId    Int? // FK → PaymentMethod（残高管理用決済手段との紐付け）
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime? // 論理削除日時

  // Relations
  operatingCompany    OperatingCompany     @relation(fields: [operatingCompanyId], references: [id], onDelete: Cascade)
  paymentMethod       PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  invoiceGroups       InvoiceGroup[] // 経理システム追加
  projectBankAccounts ProjectBankAccount[]

  @@map("operating_company_bank_accounts")
}

// ============================================
// 契約書ステータスマスタ (Master Contract Statuses)
// ============================================

model MasterContractStatus {
  id                     Int      @id @default(autoincrement())
  name                   String   @db.VarChar(50)
  displayOrder           Int      @default(0) @map("display_order")
  isTerminal             Boolean  @default(false) @map("is_terminal")
  isActive               Boolean  @default(true) @map("is_active")
  statusType             String   @default("progress") @map("status_type") @db.VarChar(20)
  cloudsignStatusMapping String?  @map("cloudsign_status_mapping") @db.VarChar(30)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  contractsCurrent MasterContract[]              @relation("CurrentStatus")
  historiesFrom    MasterContractStatusHistory[] @relation("FromStatus")
  historiesTo      MasterContractStatusHistory[] @relation("ToStatus")

  @@map("master_contract_statuses")
}

// ============================================
// 契約書テーブル (Master Contracts)
// ============================================

model MasterContract {
  id                          Int       @id @default(autoincrement())
  companyId                   Int?      @map("company_id")
  projectId                   Int       @map("project_id")
  slpMemberId                 Int?      @map("slp_member_id")
  contractNumber              String?   @map("contract_number") @db.VarChar(50)
  parentContractId            Int?      @map("parent_contract_id")
  contractType                String    @map("contract_type") @db.VarChar(50)
  title                       String    @db.VarChar(200)
  startDate                   DateTime? @map("start_date") @db.Date
  endDate                     DateTime? @map("end_date") @db.Date
  currentStatusId             Int?      @map("current_status_id")
  targetDate                  DateTime? @map("target_date") @db.Date
  signedDate                  DateTime? @map("signed_date") @db.Date
  isActive                    Boolean   @default(false) @map("is_active")
  signingMethod               String?   @map("signing_method") @db.VarChar(20)
  cloudsignDocumentId         String?   @map("cloudsign_document_id") @db.VarChar(100)
  cloudsignStatus             String?   @map("cloudsign_status") @db.VarChar(30)
  cloudsignSentAt             DateTime? @map("cloudsign_sent_at")
  cloudsignCompletedAt        DateTime? @map("cloudsign_completed_at")
  cloudsignUrl                String?   @map("cloudsign_url") @db.VarChar(500)
  cloudsignTitle              String?   @map("cloudsign_title") @db.VarChar(200)
  cloudsignAutoSync           Boolean   @default(true) @map("cloudsign_auto_sync")
  cloudsignLastRemindedAt     DateTime? @map("cloudsign_last_reminded_at")
  cloudsignSelfSigningUrl     String?   @map("cloudsign_self_signing_url") @db.VarChar(2000)
  cloudsignSelfSigningEmailId Int?      @map("cloudsign_self_signing_email_id")
  cloudsignSelfSignedAt       DateTime? @map("cloudsign_self_signed_at")
  // 締結完了時に CloudSign から取得した受信者の入力値 (widget の label と text の配列)
  // { capturedAt: ISO8601, widgets: [{ label, text, widgetType, page, participantId, participantEmail?, status }, ...] }
  cloudsignInputData          Json?     @map("cloudsign_input_data")
  filePath                    String?   @map("file_path") @db.VarChar(500)
  fileName                    String?   @map("file_name") @db.VarChar(200)
  assignedTo                  String?   @map("assigned_to") @db.VarChar(500)
  note                        String?
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  company                MasterStellaCompany?          @relation(fields: [companyId], references: [id])
  project                MasterProject                 @relation(fields: [projectId], references: [id])
  slpMember              SlpMember?                    @relation(fields: [slpMemberId], references: [id])
  currentStatus          MasterContractStatus?         @relation("CurrentStatus", fields: [currentStatusId], references: [id])
  parentContract         MasterContract?               @relation("ContractHierarchy", fields: [parentContractId], references: [id])
  childContracts         MasterContract[]              @relation("ContractHierarchy")
  statusHistories        MasterContractStatusHistory[]
  contractFiles          ContractFile[]
  relationsAsSource      ContractRelation[]            @relation("RelationSource")
  relationsAsTarget      ContractRelation[]            @relation("RelationTarget")
  selfSigningEmail       OperatingCompanyEmail?        @relation("SelfSigningEmail", fields: [cloudsignSelfSigningEmailId], references: [id])
  contractHistories      StpContractHistory[]
  agentContractHistories StpAgentContractHistory[]

  @@index([companyId], map: "idx_master_contracts_company_id")
  @@index([projectId], map: "idx_master_contracts_project_id")
  @@index([companyId, projectId], map: "idx_master_contracts_company_project")
  @@index([currentStatusId], map: "idx_master_contracts_current_status_id")
  @@index([isActive], map: "idx_master_contracts_is_active")
  @@index([cloudsignDocumentId], map: "idx_master_contracts_cloudsign_document_id")
  @@index([slpMemberId], map: "idx_master_contracts_slp_member_id")
  @@map("master_contracts")
}

// ============================================
// 契約書ステータス変更履歴 (Master Contract Status Histories)
// ============================================

model MasterContractStatusHistory {
  id           Int       @id @default(autoincrement())
  contractId   Int       @map("contract_id")
  eventType    String    @map("event_type") @db.VarChar(30)
  fromStatusId Int?      @map("from_status_id")
  toStatusId   Int?      @map("to_status_id")
  targetDate   DateTime? @map("target_date") @db.Date
  changedBy    String?   @map("changed_by") @db.VarChar(100)
  note         String?
  recordedAt   DateTime  @default(now()) @map("recorded_at")

  contract   MasterContract        @relation(fields: [contractId], references: [id])
  fromStatus MasterContractStatus? @relation("FromStatus", fields: [fromStatusId], references: [id])
  toStatus   MasterContractStatus? @relation("ToStatus", fields: [toStatusId], references: [id])

  @@index([contractId], map: "idx_master_contract_status_histories_contract_id")
  @@index([recordedAt], map: "idx_master_contract_status_histories_recorded_at")
  @@map("master_contract_status_histories")
}

// ============================================
// 契約ファイル (Contract Files)
// ============================================

model ContractFile {
  id         Int      @id @default(autoincrement())
  contractId Int      @map("contract_id")
  filePath   String   @map("file_path") @db.VarChar(500)
  fileName   String   @map("file_name") @db.VarChar(200)
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type") @db.VarChar(100)
  category   String   @default("other") @db.VarChar(30)
  isVisible  Boolean  @default(true) @map("is_visible")
  uploadedBy String?  @map("uploaded_by") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  contract MasterContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId], map: "idx_contract_files_contract_id")
  @@map("contract_files")
}

// ============================================
// 契約関連 (Contract Relations)
// ============================================

model ContractRelation {
  id               Int      @id @default(autoincrement())
  sourceContractId Int      @map("source_contract_id")
  targetContractId Int      @map("target_contract_id")
  relationType     String   @map("relation_type") @db.VarChar(30)
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")

  sourceContract MasterContract @relation("RelationSource", fields: [sourceContractId], references: [id], onDelete: Cascade)
  targetContract MasterContract @relation("RelationTarget", fields: [targetContractId], references: [id], onDelete: Cascade)

  @@index([sourceContractId], map: "idx_contract_relations_source")
  @@index([targetContractId], map: "idx_contract_relations_target")
  @@map("contract_relations")
}

// ============================================
// 外部ユーザー (External Users)
// クライアント・代理店担当者向けログインアカウント
// ============================================

model ExternalUser {
  id                  Int       @id @default(autoincrement())
  companyId           Int // 所属企業（MasterStellaCompanyへの外部キー）
  registrationTokenId Int? // 登録に使用されたトークン
  contactId           Int?      @unique // 担当者情報（任意、StellaCompanyContactへの外部キー）
  name                String    @db.VarChar(100) // 名前
  position            String?   @db.VarChar(100) // 役職
  email               String    @unique @db.VarChar(255) // ログイン用メールアドレス
  passwordHash        String    @db.VarChar(255) // パスワード（ハッシュ化）
  status              String    @default("pending_email") @db.VarChar(20) // pending_email/pending_approval/active/suspended
  emailVerifiedAt     DateTime? // メール認証日時
  approvedAt          DateTime? // 管理者承認日時
  approvedBy          Int? // 承認者（MasterStaffへの外部キー）
  lastLoginAt         DateTime? // 最終ログイン日時
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  company                 MasterStellaCompany             @relation(fields: [companyId], references: [id])
  registrationToken       RegistrationToken?              @relation(fields: [registrationTokenId], references: [id])
  contact                 StellaCompanyContact?           @relation(fields: [contactId], references: [id])
  approver                MasterStaff?                    @relation(fields: [approvedBy], references: [id])
  displayPermissions      ExternalUserDisplayPermission[]
  loginHistories          LoginHistory[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  @@index([companyId])
  @@index([status])
  @@map("external_users")
}

// ============================================
// 表示ビュー定義 (Display Views)
// 外部ユーザー向け画面の定義
// ============================================

model DisplayView {
  id          Int      @id @default(autoincrement())
  viewKey     String   @unique @db.VarChar(50) // stp_client, stp_agent
  viewName    String   @db.VarChar(100) // 採用ブースト（クライアント版）
  projectId   Int // master_projectsへの外部キー
  description String? // 説明
  isActive    Boolean  @default(true) // 有効フラグ
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project                   MasterProject                   @relation(fields: [projectId], references: [id])
  userPermissions           ExternalUserDisplayPermission[]
  registrationTokenDefaults RegistrationTokenDefaultView[]

  @@map("display_views")
}

// ============================================
// 外部ユーザー表示権限 (External User Display Permissions)
// ユーザー×ビューの権限管理
// ============================================

model ExternalUserDisplayPermission {
  id             Int      @id @default(autoincrement())
  externalUserId Int
  displayViewId  Int
  createdAt      DateTime @default(now())

  // Relations
  externalUser ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  displayView  DisplayView  @relation(fields: [displayViewId], references: [id])

  @@unique([externalUserId, displayViewId])
  @@map("external_user_display_permissions")
}

// ============================================
// 登録トークン (Registration Tokens)
// 外部ユーザー登録用の招待トークン
// ============================================

model RegistrationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(64) // 招待トークン
  companyId Int // 対象企業（MasterStellaCompanyへの外部キー）
  name      String?  @db.VarChar(100) // 管理名（誰向けか等）
  note      String? // 備考
  expiresAt DateTime // 有効期限
  maxUses   Int      @default(1) // 最大使用回数
  useCount  Int      @default(0) // 使用回数
  status    String   @default("active") @db.VarChar(20) // active/expired/exhausted/revoked
  issuedBy  Int // 発行者（MasterStaffへの外部キー）
  createdAt DateTime @default(now())

  // Relations
  company       MasterStellaCompany            @relation(fields: [companyId], references: [id])
  issuer        MasterStaff                    @relation(fields: [issuedBy], references: [id])
  defaultViews  RegistrationTokenDefaultView[]
  externalUsers ExternalUser[]

  @@index([token])
  @@map("registration_tokens")
}

// ============================================
// 登録トークンデフォルトビュー (Registration Token Default Views)
// トークン発行時に指定するデフォルトの表示権限
// ============================================

model RegistrationTokenDefaultView {
  id                  Int      @id @default(autoincrement())
  registrationTokenId Int
  displayViewId       Int
  createdAt           DateTime @default(now())

  // Relations
  registrationToken RegistrationToken @relation(fields: [registrationTokenId], references: [id], onDelete: Cascade)
  displayView       DisplayView       @relation(fields: [displayViewId], references: [id])

  @@unique([registrationTokenId, displayViewId])
  @@map("registration_token_default_views")
}

// ============================================
// メール認証トークン (Email Verification Tokens)
// メールアドレス確認用トークン
// ============================================

model EmailVerificationToken {
  id             Int      @id @default(autoincrement())
  token          String   @unique @db.VarChar(64) // 認証トークン
  externalUserId Int // 外部ユーザー（ExternalUserへの外部キー）
  expiresAt      DateTime // 有効期限
  isUsed         Boolean  @default(false) // 使用済みフラグ
  createdAt      DateTime @default(now())

  // Relations
  externalUser ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verification_tokens")
}

// ============================================
// パスワードリセットトークン (Password Reset Tokens)
// パスワード再設定用トークン
// ============================================

model PasswordResetToken {
  id             Int      @id @default(autoincrement())
  token          String   @unique @db.VarChar(64) // リセットトークン
  externalUserId Int? // 外部ユーザー（ExternalUserへの外部キー）
  staffId        Int? // 社内スタッフ（MasterStaffへの外部キー）
  expiresAt      DateTime // 有効期限
  isUsed         Boolean  @default(false) // 使用済みフラグ
  createdAt      DateTime @default(now())

  // Relations
  externalUser ExternalUser? @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  staff        MasterStaff?  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================
// ログイン履歴 (Login Histories)
// 外部ユーザーのログイン記録
// ============================================

model LoginHistory {
  id             Int      @id @default(autoincrement())
  externalUserId Int // 外部ユーザー（ExternalUserへの外部キー）
  loginAt        DateTime @default(now()) // ログイン日時
  ipAddress      String?  @db.VarChar(45) // IPアドレス
  userAgent      String? // ユーザーエージェント
  result         String   @db.VarChar(20) // success/failure
  failureReason  String?  @db.VarChar(50) // 失敗理由

  // Relations
  externalUser ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)

  @@index([externalUserId])
  @@index([loginAt])
  @@map("login_histories")
}

// ============================================
// STPリード獲得フォームトークン (STP Lead Form Tokens)
// 代理店ごとのユニークフォームURL管理
// ============================================

model StpLeadFormToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique @db.VarChar(64) // URLトークン
  agentId   Int?      @unique // 代理店ID（nullは直接顧客用トークン）
  status    String    @default("active") @db.VarChar(20) // active/paused/revoked
  expiresAt DateTime? // 有効期限（nullは無期限）
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  agent       StpAgent?               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  submissions StpLeadFormSubmission[]

  @@index([token])
  @@map("stp_lead_form_tokens")
}

// ============================================
// STPリード獲得フォーム回答 (STP Lead Form Submissions)
// フォーム回答データ
// ============================================

model StpLeadFormSubmission {
  id              Int  @id @default(autoincrement())
  tokenId         Int // フォームトークンへのFK
  stpCompanyId    Int? // 作成されたSTP企業ID
  masterCompanyId Int? // 紐付けられた全顧客マスタID

  // 回答者情報
  companyName  String  @db.VarChar(200) // 会社名
  contactName  String  @db.VarChar(100) // 担当者氏名
  contactEmail String  @db.VarChar(255) // メールアドレス
  contactPhone String? @db.VarChar(50) // 電話番号

  // 採用実績情報
  pastHiringJobTypes         String? // 過去採用経験のある職種（JSON）
  pastRecruitingCostAgency   Int? // 人材紹介費用（円）
  pastRecruitingCostAds      Int? // 求人広告費用（円）
  pastRecruitingCostReferral Int? // リファラル費用（円）
  pastRecruitingCostOther    Int? // その他費用（円）
  pastHiringCount            Int? // 過去採用人数

  // 希望情報
  desiredJobTypes     String? // 希望職種（JSON）
  annualBudget        Int? // 年間採用予算（円）
  annualHiringTarget  Int? // 年間希望採用人数
  hiringAreas         String? // 採用エリア（JSON: 都道府県）
  hiringTimeline      String? @db.VarChar(100) // 採用希望時期（月）
  ageRangeMin         Int? // 採用可能年齢: 下限（旧フォーム互換用）
  ageRangeMax         Int? // 採用可能年齢: 上限（旧フォーム互換用）
  ageRange            String? @db.VarChar(10) // 採用可能年齢幅（不問, 〜30, 〜35, etc.）
  requiredConditions  String? // 必須条件
  preferredConditions String? // 希望条件

  // メタ情報
  status         String    @default("pending") @db.VarChar(20) // pending/processed/rejected
  processedAt    DateTime? // 処理日時
  processedBy    Int? // 処理者（MasterStaffへのFK）
  processingNote String? // 処理メモ
  submittedAt    DateTime  @default(now()) // 回答日時
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  token     StpLeadFormToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  processor MasterStaff?     @relation(fields: [processedBy], references: [id])
  proposals StpProposal[]

  @@index([tokenId])
  @@index([status])
  @@index([submittedAt])
  @@map("stp_lead_form_submissions")
}

// ============================================
// STP提案書 (STP Proposals)
// ヒアリングフォームからの自動生成および手動作成
// ============================================

model StpProposal {
  id Int @id @default(autoincrement())

  // 紐付け（両方nullable、アプリ層でバリデーション）
  stpCompanyId Int? // STP企業への外部キー
  submissionId Int? // フォーム回答への外部キー

  // 基本情報
  title          String  @db.VarChar(200) // 提案書タイトル
  proposalNumber String? @db.VarChar(50) // 提案書番号（自動採番）

  // ファイル情報（PDFアップロード時）
  filePath String? @db.VarChar(500)
  fileName String? @db.VarChar(200)

  // 外部URL（Canva, Google Docs等）
  externalUrl     String? @db.VarChar(500)
  externalService String? @db.VarChar(50) // canva/google_docs/other

  // ステータス
  status String    @default("draft") @db.VarChar(20) // draft/sent/viewed/accepted/rejected
  sentAt DateTime? // 送付日時

  // その他
  assignedTo      String? @db.VarChar(100) // 担当者
  note            String? // 備考
  isAutoGenerated Boolean @default(false) // 自動生成フラグ
  proposalContent Json? // シミュレーション結果と編集可能な提案データ

  // 確定提案書用（確定時に作成されるエントリ）
  sourceProposalId Int? // 元の自動生成提案書ID（確定提案書の場合）
  slideVersion     Int? // 確定したスライドバージョン番号

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // 論理削除日時

  // Relations
  stpCompany        StpCompany?            @relation(fields: [stpCompanyId], references: [id], onDelete: Cascade)
  submission        StpLeadFormSubmission? @relation(fields: [submissionId], references: [id])
  sourceProposal    StpProposal?           @relation("ProposalConfirm", fields: [sourceProposalId], references: [id])
  confirmedVersions StpProposal[]          @relation("ProposalConfirm")

  @@index([stpCompanyId])
  @@index([submissionId])
  @@index([sourceProposalId])
  @@map("stp_proposals")
}

// ============================================
// 短縮URL (Short URLs)
// リード獲得フォームURL等の短縮用
// ============================================

model ShortUrl {
  id          Int      @id @default(autoincrement())
  shortCode   String   @unique @db.VarChar(10) // 短縮コード（6文字英数字）
  originalUrl String   @db.VarChar(500) // 元のURL
  createdAt   DateTime @default(now())

  @@map("short_urls")
}

// ============================================
// STP KPIシート (STP KPI Sheets)
// 企業ごとの運用KPIシート（1企業に複数作成可能）
// ============================================

model StpKpiSheet {
  id           Int      @id @default(autoincrement())
  stpCompanyId Int // stp_companiesへの外部キー
  name         String   @db.VarChar(100) // シート名（自由入力: "Indeed", "Wantedly"等）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  stpCompany StpCompany         @relation(fields: [stpCompanyId], references: [id], onDelete: Cascade)
  weeklyData StpKpiWeeklyData[]
  shareLinks StpKpiShareLink[]

  @@index([stpCompanyId])
  @@map("stp_kpi_sheets")
}

// ============================================
// STP KPI週次データ (STP KPI Weekly Data)
// 週単位の目標値・実績値を管理
// ============================================

model StpKpiWeeklyData {
  id            Int      @id @default(autoincrement())
  kpiSheetId    Int // stp_kpi_sheetsへの外部キー
  weekStartDate DateTime @db.Date // 週開始日
  weekEndDate   DateTime @db.Date // 週終了日

  // 目標値
  targetImpressions  Int? // 表示回数（目標）
  targetCpm          Decimal? @db.Decimal(10, 2) // 表示単価（目標）
  targetClicks       Int? // クリック数（目標）
  targetCtr          Decimal? @db.Decimal(5, 2) // クリック率（目標）
  targetCpc          Decimal? @db.Decimal(10, 2) // クリック単価（目標）
  targetApplications Int? // 応募数（目標）
  targetCvr          Decimal? @db.Decimal(5, 2) // 応募率（目標）
  targetCpa          Decimal? @db.Decimal(10, 2) // 応募単価（目標）
  targetCost         Int? // 費用（目標）

  // 実績値
  actualImpressions  Int? // 表示回数（実績）
  actualCpm          Decimal? @db.Decimal(10, 2) // 表示単価（実績）
  actualClicks       Int? // クリック数（実績）
  actualCtr          Decimal? @db.Decimal(5, 2) // クリック率（実績）
  actualCpc          Decimal? @db.Decimal(10, 2) // クリック単価（実績）
  actualApplications Int? // 応募数（実績）
  actualCvr          Decimal? @db.Decimal(5, 2) // 応募率（実績）
  actualCpa          Decimal? @db.Decimal(10, 2) // 応募単価（実績）
  actualCost         Int? // 費用（実績）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  kpiSheet StpKpiSheet @relation(fields: [kpiSheetId], references: [id], onDelete: Cascade)

  @@unique([kpiSheetId, weekStartDate])
  @@index([kpiSheetId])
  @@map("stp_kpi_weekly_data")
}

// ============================================
// STP KPI共有リンク (STP KPI Share Links)
// 時間制限付きの公開共有リンク
// ============================================

model StpKpiShareLink {
  id         Int      @id @default(autoincrement())
  kpiSheetId Int // stp_kpi_sheetsへの外部キー
  token      String   @unique @db.VarChar(64) // 共有トークン
  expiresAt  DateTime // 有効期限
  createdAt  DateTime @default(now())
  createdBy  Int? // 発行者（master_staffへの外部キー）

  // Relations
  kpiSheet StpKpiSheet @relation(fields: [kpiSheetId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([kpiSheetId])
  @@map("stp_kpi_share_links")
}

// ============================================
// 媒体広告管理 (STP Media Ad Management)
// Airワーク等の媒体広告データ管理
// ============================================

model StpMediaAd {
  id                Int       @id @default(autoincrement())
  contractHistoryId Int // stp_contract_historiesへの外部キー
  adNumber          String    @unique @db.VarChar(20) // 広告番号（例: "2048083"）
  adName            String    @db.VarChar(200) // 広告名（例: "施工管理"）
  status            String    @default("active") @db.VarChar(20) // active, ended, preparing, paused
  startDate         DateTime? @db.Date // 配信開始日
  endDate           DateTime? @db.Date // 配信終了日
  budgetLimit       Int? // 予算上限（円）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contractHistory StpContractHistory      @relation(fields: [contractHistoryId], references: [id], onDelete: Cascade)
  dailyMetrics    StpMediaAdDailyMetric[]
  jobPostings     StpMediaAdJobPosting[]

  @@index([contractHistoryId])
  @@map("stp_media_ads")
}

model StpMediaAdDailyMetric {
  id   Int      @id @default(autoincrement())
  adId Int // stp_media_adsへの外部キー
  date DateTime @db.Date // 配信日

  // カウント系
  impressions       Int @default(0) // 表示数
  clicks            Int @default(0) // クリック数
  applicationStarts Int @default(0) // 応募開始数
  applications      Int @default(0) // 応募数
  cost              Int @default(0) // 利用済予算（円）

  // 率（CSVの値をそのまま保存、例: 5.04 = 5.04%）
  ctr                       Decimal? @db.Decimal(7, 2) // クリック率
  applicationStartRate      Decimal? @db.Decimal(7, 2) // 応募開始率
  applicationCompletionRate Decimal? @db.Decimal(7, 2) // 応募完了率
  applicationRate           Decimal? @db.Decimal(7, 2) // 応募率

  // 単価（円）
  cpc                     Int? // クリック単価
  costPerApplicationStart Int? // 応募開始単価
  cpa                     Int? // 応募単価

  createdAt DateTime @default(now())

  // Relations
  ad StpMediaAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, date])
  @@index([adId])
  @@map("stp_media_ad_daily_metrics")
}

model StpMediaAdJobPosting {
  id        Int     @id @default(autoincrement())
  adId      Int // stp_media_adsへの外部キー
  jobNumber String  @db.VarChar(20) // 求人番号
  jobTitle  String  @db.Text // 求人内容（タイトル）
  jobMemo   String? @db.Text // 求人メモ

  // カウント系
  impressions       Int @default(0) // 表示数
  clicks            Int @default(0) // クリック数
  applicationStarts Int @default(0) // 応募開始数
  applications      Int @default(0) // 応募数
  cost              Int @default(0) // 利用済予算（円）

  // 率
  ctr                       Decimal? @db.Decimal(7, 2) // クリック率
  applicationStartRate      Decimal? @db.Decimal(7, 2) // 応募開始率
  applicationCompletionRate Decimal? @db.Decimal(7, 2) // 応募完了率
  applicationRate           Decimal? @db.Decimal(7, 2) // 応募率

  // 単価（円）
  cpc                     Int? // クリック単価
  costPerApplicationStart Int? // 応募開始単価
  cpa                     Int? // 応募単価

  // 雇用形態
  employmentType String? @db.VarChar(20) // 正社員, パート等

  createdAt DateTime @default(now())

  // Relations
  ad StpMediaAd @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, jobNumber])
  @@index([adId])
  @@map("stp_media_ad_job_postings")
}

// ============================================
// STP求職者 (STP Candidates)
// 採用ブーストプロジェクトの求職者情報管理
// ============================================

model StpCandidate {
  id                  Int       @id @default(autoincrement())
  lastName            String    @db.VarChar(50) // 姓
  firstName           String    @db.VarChar(50) // 名
  interviewDate       DateTime? @db.Date // 面接日程
  interviewAttendance String?   @db.VarChar(20) // 面接参加有無（参加/不参加）
  selectionStatus     String?   @db.VarChar(20) // 選考状況
  offerDate           DateTime? @db.Date // 内定日
  joinDate            DateTime? @db.Date // 入社日
  sendDate            DateTime? @db.Date // 送客日
  industryType        String?   @db.VarChar(20) // 業種区分（general/dispatch）
  jobMedia            String?   @db.VarChar(50) // 求人媒体（Indeed/doda/Wantedly/マイナビ/リクナビ）
  note                String? // メモ書き
  stpCompanyId        Int // 企業（STP企業への外部キー・必須）
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime? // 論理削除日時

  // Relations
  stpCompany     StpCompany         @relation(fields: [stpCompanyId], references: [id])
  revenueRecords StpRevenueRecord[]

  @@index([stpCompanyId])
  @@map("stp_candidates")
}

// ============================================
// 代理店契約履歴 (STP Agent Contract Histories)
// 代理店との契約条件を期間ごとに管理
// デフォルト報酬率を保持（企業契約作成時に自動セット）
// ============================================

model StpAgentContractHistory {
  id                Int       @id @default(autoincrement())
  agentId           Int // 代理店（stp_agentsへの外部キー）
  contractStartDate DateTime  @db.Date // 契約開始日
  contractEndDate   DateTime? @db.Date // 契約終了日（null = 現在有効）
  contractDate      DateTime? @db.Date // 契約日（初期費用発生タイミング）
  status            String    @db.VarChar(20) // "契約前" / "契約済み"

  // 代理店への直接費用
  initialFee Int? // 初期費用
  monthlyFee Int? // 月額費用

  // 月額プランを契約した企業からの報酬
  defaultMpInitialType     String?  @db.VarChar(10) // "rate" or "fixed"
  defaultMpInitialRate     Decimal? @db.Decimal(5, 2) // 初期費用報酬率(%)
  defaultMpInitialFixed    Int? // 初期費用固定報酬額
  defaultMpInitialDuration Int? // 報酬発生期間(ヶ月)
  defaultMpMonthlyType     String?  @db.VarChar(10) // "rate" or "fixed"
  defaultMpMonthlyRate     Decimal? @db.Decimal(5, 2) // 月額報酬率(%)
  defaultMpMonthlyFixed    Int? // 月額報酬固定額
  defaultMpMonthlyDuration Int? // 月額報酬発生期間(ヶ月)

  // 成果報酬プランを契約した企業からの報酬
  defaultPpInitialType     String?  @db.VarChar(10) // "rate" or "fixed"
  defaultPpInitialRate     Decimal? @db.Decimal(5, 2) // 初期費用報酬率(%)
  defaultPpInitialFixed    Int? // 初期費用固定報酬額
  defaultPpInitialDuration Int? // 報酬発生期間(ヶ月)
  defaultPpPerfType        String?  @db.VarChar(10) // "rate" or "fixed"
  defaultPpPerfRate        Decimal? @db.Decimal(5, 2) // 成果報酬率(%)
  defaultPpPerfFixed       Int? // 成果報酬固定額
  defaultPpPerfDuration    Int? // 報酬発生期間(ヶ月)

  note             String? // 備考
  masterContractId Int?      @map("master_contract_id") // 紐づく契約書
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime? // 論理削除日時

  // Relations
  agent               StpAgent                     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  masterContract      MasterContract?              @relation(fields: [masterContractId], references: [id])
  expenseRecords      StpExpenseRecord[]
  commissionOverrides StpAgentCommissionOverride[]

  @@index([agentId])
  @@index([agentId, contractStartDate])
  @@index([masterContractId])
  @@map("stp_agent_contract_histories")
}

// ============================================
// 代理店企業別報酬例外 (STP Agent Commission Overrides)
// 代理店契約のデフォルト報酬率に対する企業別の例外設定
// ============================================

model StpAgentCommissionOverride {
  id                     Int @id @default(autoincrement())
  agentContractHistoryId Int // 代理店契約履歴への外部キー
  stpCompanyId           Int // STP企業への外部キー

  // 月額プラン
  mpInitialType     String?  @db.VarChar(10) // "rate" or "fixed"
  mpInitialRate     Decimal? @db.Decimal(5, 2) // 初期費用報酬率(%)
  mpInitialFixed    Int? // 初期費用固定報酬額
  mpInitialDuration Int? // 報酬発生期間(ヶ月)
  mpMonthlyType     String?  @db.VarChar(10) // "rate" or "fixed"
  mpMonthlyRate     Decimal? @db.Decimal(5, 2) // 月額報酬率(%)
  mpMonthlyFixed    Int? // 月額報酬固定額
  mpMonthlyDuration Int? // 月額報酬発生期間(ヶ月)

  // 成果報酬プラン
  ppInitialType     String?  @db.VarChar(10) // "rate" or "fixed"
  ppInitialRate     Decimal? @db.Decimal(5, 2) // 初期費用報酬率(%)
  ppInitialFixed    Int? // 初期費用固定報酬額
  ppInitialDuration Int? // 報酬発生期間(ヶ月)
  ppPerfType        String?  @db.VarChar(10) // "rate" or "fixed"
  ppPerfRate        Decimal? @db.Decimal(5, 2) // 成果報酬率(%)
  ppPerfFixed       Int? // 成果報酬固定額
  ppPerfDuration    Int? // 報酬発生期間(ヶ月)

  note      String? // 備考
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  agentContractHistory StpAgentContractHistory @relation(fields: [agentContractHistoryId], references: [id], onDelete: Cascade)
  stpCompany           StpCompany              @relation(fields: [stpCompanyId], references: [id], onDelete: Cascade)

  @@unique([agentContractHistoryId, stpCompanyId])
  @@index([agentContractHistoryId])
  @@index([stpCompanyId])
  @@map("stp_agent_commission_overrides")
}

// ============================================
// 売上実績 (STP Revenue Records)
// 企業からの入金を1件ずつ管理
// ============================================

model StpRevenueRecord {
  id                Int  @id @default(autoincrement())
  stpCompanyId      Int // STP企業（stp_companiesへの外部キー）
  contractHistoryId Int? // どの契約条件に基づくか
  candidateId       Int? // 成果報酬の場合、対象の求職者
  invoiceId         Int? // 紐づく請求書（1つの請求書に複数の売上レコードを紐づけ可能）

  // 売上情報
  revenueType    String   @db.VarChar(20) // "initial" / "monthly" / "performance"
  targetMonth    DateTime @db.Date // 対象年月（月初日で統一: 2026-02-01等）
  expectedAmount Int // 請求金額

  // 入金管理
  status        String    @default("pending") @db.VarChar(20) // pending/approved/invoiced/paid/overdue/cancelled
  paymentStatus String?   @db.VarChar(20) // null(通常)/partial(一部入金)/completed_different(金額相違あり入金済)
  invoiceDate   DateTime? @db.Date // 請求日
  dueDate       DateTime? @db.Date // 支払期限
  paidDate      DateTime? @db.Date // 着金日
  paidAmount    Int? // 実際の着金額

  // 承認フロー
  approvedAt DateTime? // 承認日時
  approvedBy Int? // 承認者（MasterStaffへの外部キー）

  // 会計連携（freee等）準備
  accountingStatus     String    @default("unprocessed") @db.VarChar(20) // unprocessed/processing/processed/skipped
  accountingService    String?   @db.VarChar(30) // freee 等
  accountingExternalId String?   @db.VarChar(100) // 外部会計ID
  accountingSyncedAt   DateTime? // 会計連携反映日時

  // 税情報
  taxType   String @default("tax_included") @db.VarChar(20) // "tax_included"（内税）/ "tax_excluded"（外税）
  taxRate   Int    @default(10) // 税率(%)
  taxAmount Int    @default(0) // 税額

  // 自動生成フラグ
  isAutoGenerated Boolean @default(false)

  // 元データ変更の追跡（スナップショット方式）
  sourceDataChangedAt    DateTime? // 元データが変更された日時
  latestCalculatedAmount Int? // 最新の元データで計算した金額

  note      String? // 備考
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // 論理削除日時

  // Relations
  stpCompany                StpCompany                 @relation(fields: [stpCompanyId], references: [id], onDelete: Cascade)
  contractHistory           StpContractHistory?        @relation(fields: [contractHistoryId], references: [id])
  candidate                 StpCandidate?              @relation(fields: [candidateId], references: [id])
  invoice                   StpInvoice?                @relation(fields: [invoiceId], references: [id])
  approver                  MasterStaff?               @relation("RevenueApprover", fields: [approvedBy], references: [id])
  expenseRecords            StpExpenseRecord[]
  editLogs                  StpFinanceEditLog[]        @relation("RevenueEditLogs")
  lineItems                 StpInvoiceLineItem[]
  accountingReconciliations AccountingReconciliation[] @relation("RevenueReconciliation")

  @@index([stpCompanyId])
  @@index([targetMonth])
  @@index([status])
  @@index([stpCompanyId, targetMonth])
  @@index([accountingStatus])
  @@index([invoiceId])
  @@map("stp_revenue_records")
}

// ============================================
// 経費実績 (STP Expense Records)
// 代理店への支払いを1件ずつ管理
// ============================================

model StpExpenseRecord {
  id                     Int  @id @default(autoincrement())
  agentId                Int // 代理店（stp_agentsへの外部キー）
  stpCompanyId           Int? // 紹介報酬の場合、対象企業
  agentContractHistoryId Int? // どの代理店契約に基づくか
  contractHistoryId      Int? // どの企業契約に基づくか（紹介報酬の場合）
  revenueRecordId        Int? // どの売上に対する報酬か
  invoiceId              Int? // 紐づく請求書（1つの請求書に複数の経費レコードを紐づけ可能）

  // 経費情報
  expenseType    String   @db.VarChar(30) // "agent_initial" / "agent_monthly" / "commission_initial" / "commission_performance" / "commission_monthly"
  targetMonth    DateTime @db.Date // 対象年月（月初日で統一: 2026-02-01等）
  expectedAmount Int // 支払予定額

  // 報酬率スナップショット（生成時の適用値を記録）
  appliedCommissionRate Decimal? @db.Decimal(5, 2) // 適用された報酬率(%)
  appliedCommissionType String?  @db.VarChar(10) // "rate" or "fixed"

  // 源泉徴収
  isWithholdingTarget  Boolean  @default(false) // 源泉徴収対象か
  withholdingTaxRate   Decimal? @db.Decimal(5, 2) // 源泉徴収税率（10.21% or 20.42%）
  withholdingTaxAmount Int? // 源泉徴収税額
  netPaymentAmount     Int? // 差引支払額（expectedAmount - withholdingTaxAmount）

  // 支払管理
  status        String    @default("pending") @db.VarChar(20) // pending/approved/paid/cancelled
  paymentStatus String?   @db.VarChar(20) // null(通常)/partial(一部支払)/completed_different(金額相違あり支払済)
  approvedDate  DateTime? @db.Date // 承認日
  paidDate      DateTime? @db.Date // 支払日
  paidAmount    Int? // 実際の支払額

  // 会計連携（freee等）準備
  accountingStatus     String    @default("unprocessed") @db.VarChar(20) // unprocessed/processing/processed/skipped
  accountingService    String?   @db.VarChar(30) // freee 等
  accountingExternalId String?   @db.VarChar(100) // 外部会計ID
  accountingSyncedAt   DateTime? // 会計連携反映日時

  // 税情報
  taxType   String @default("tax_included") @db.VarChar(20) // "tax_included"（内税）/ "tax_excluded"（外税）
  taxRate   Int    @default(10) // 税率(%)
  taxAmount Int    @default(0) // 税額

  // 自動生成フラグ
  isAutoGenerated Boolean @default(false)

  // 元データ変更の追跡（スナップショット方式）
  sourceDataChangedAt    DateTime? // 元データが変更された日時
  latestCalculatedAmount Int? // 最新の元データで計算した金額

  note      String? // 備考
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // 論理削除日時

  // Relations
  agent                     StpAgent                   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  stpCompany                StpCompany?                @relation(fields: [stpCompanyId], references: [id], onDelete: Cascade)
  agentContractHistory      StpAgentContractHistory?   @relation(fields: [agentContractHistoryId], references: [id])
  contractHistory           StpContractHistory?        @relation(fields: [contractHistoryId], references: [id])
  revenueRecord             StpRevenueRecord?          @relation(fields: [revenueRecordId], references: [id])
  invoice                   StpInvoice?                @relation(fields: [invoiceId], references: [id])
  editLogs                  StpFinanceEditLog[]        @relation("ExpenseEditLogs")
  lineItems                 StpInvoiceLineItem[]
  accountingReconciliations AccountingReconciliation[] @relation("ExpenseReconciliation")

  @@index([agentId])
  @@index([stpCompanyId])
  @@index([targetMonth])
  @@index([status])
  @@index([agentId, targetMonth])
  @@index([accountingStatus])
  @@index([invoiceId])
  @@map("stp_expense_records")
}

// ============================================
// 請求書管理 (STP Invoices)
// 自社発行請求書・先方受領請求書を統一管理
// ============================================

model StpInvoice {
  id Int @id @default(autoincrement())

  // 種別: outgoing（自社発行）/ incoming（先方受領）
  direction String @db.VarChar(20)

  // 関連先
  stpCompanyId Int? // 顧客企業
  agentId      Int? // 代理店

  // 適格請求書（インボイス制度）対応
  invoiceType        String  @default("standard") @db.VarChar(20) // "standard"（通常）/ "credit_note"（赤伝）
  originalInvoiceId  Int? // 赤伝の場合、元の請求書ID
  registrationNumber String? @db.VarChar(20) // 適格請求書発行事業者登録番号（発行時スナップショット）

  // 請求書情報
  invoiceNumber String?   @db.VarChar(50) // 請求書番号（自動採番: INV-YYYYMM-NNNN）
  invoiceDate   DateTime? @db.Date // 請求日
  dueDate       DateTime? @db.Date // 支払期限
  totalAmount   Int? // 請求金額（税込）
  taxAmount     Int? // 消費税額

  // 税率ごとの合計（インボイス制度対応）
  subtotalByTaxRate Json? // {"10":{"subtotal":100000,"tax":10000},"8":{"subtotal":50000,"tax":4000}}

  // 源泉徴収（incoming請求書用）
  withholdingTaxAmount Int? // 源泉徴収税額
  netPaymentAmount     Int? // 差引支払額（totalAmount - withholdingTaxAmount）

  // ステータス
  // outgoing: draft → issued → sent → paid
  // incoming: received → approved → paid
  status String @default("draft") @db.VarChar(20)

  // ファイル管理
  filePath String? // 保存ファイルパス
  fileName String? @db.VarChar(200) // 元ファイル名

  // テンプレート（将来用: PDF自動生成）
  templateId   String? @db.VarChar(50) // 使用テンプレートID
  templateData Json? // テンプレート埋め込みデータ

  note      String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations（1:N - 1つの請求書に複数の売上/経費レコードを紐づけ可能）
  stpCompany      StpCompany?          @relation(fields: [stpCompanyId], references: [id], onDelete: Cascade)
  agent           StpAgent?            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  originalInvoice StpInvoice?          @relation("CreditNoteRelation", fields: [originalInvoiceId], references: [id])
  creditNotes     StpInvoice[]         @relation("CreditNoteRelation")
  revenueRecords  StpRevenueRecord[]
  expenseRecords  StpExpenseRecord[]
  lineItems       StpInvoiceLineItem[]

  @@index([direction])
  @@index([stpCompanyId])
  @@index([agentId])
  @@index([status])
  @@map("stp_invoices")
}

// ============================================
// 売上・経費 編集ログ (STP Finance Edit Logs)
// 自動生成レコードの重要フィールド編集や金額不一致を記録
// ============================================

model StpFinanceEditLog {
  id Int @id @default(autoincrement())

  // 対象レコード（どちらか一方）
  revenueRecordId Int?
  expenseRecordId Int?

  // 編集内容
  editType  String  @db.VarChar(30) // "field_change"（重要フィールド変更）/ "amount_mismatch"（金額不一致）
  fieldName String? @db.VarChar(50) // 変更されたフィールド名
  oldValue  String? // 変更前の値
  newValue  String? // 変更後の値
  reason    String? // 変更理由（ユーザー入力）

  // 編集者
  editedBy Int? // 編集者（MasterStaffへの外部キー）

  createdAt DateTime @default(now())

  // Relations
  revenueRecord StpRevenueRecord? @relation("RevenueEditLogs", fields: [revenueRecordId], references: [id])
  expenseRecord StpExpenseRecord? @relation("ExpenseEditLogs", fields: [expenseRecordId], references: [id])
  editor        MasterStaff?      @relation(fields: [editedBy], references: [id])

  @@index([revenueRecordId])
  @@index([expenseRecordId])
  @@map("stp_finance_edit_logs")
}

// ============================================
// 請求書明細行 (STP Invoice Line Items)
// インボイス制度対応の明細管理 + 税率ごと端数処理
// ============================================

model StpInvoiceLineItem {
  id        Int @id @default(autoincrement())
  invoiceId Int // StpInvoiceへの外部キー
  sortOrder Int @default(0) // 表示順

  // 明細内容
  description String @db.VarChar(500) // 品目・サービス名
  quantity    Int    @default(1) // 数量
  unitPrice   Int // 単価（税抜）
  amount      Int // 小計（税抜）= quantity * unitPrice

  // 税情報（明細行レベル）
  taxRate         Int    @default(10) // 適用税率(%)
  taxRateCategory String @default("standard") @db.VarChar(20) // "standard"(10%), "reduced"(8%), "exempt"(0%)

  // 紐づけ（売上/経費レコードへの参照。nullの場合は手入力明細）
  revenueRecordId Int?
  expenseRecordId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoice       StpInvoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  revenueRecord StpRevenueRecord? @relation(fields: [revenueRecordId], references: [id])
  expenseRecord StpExpenseRecord? @relation(fields: [expenseRecordId], references: [id])

  @@index([invoiceId])
  @@map("stp_invoice_line_items")
}

// ============================================
// 月次締めロック (STP Monthly Closes)
// 過去月のデータ変更を防止する月次締め機能
// ============================================

model StpMonthlyClose {
  id           Int       @id @default(autoincrement())
  targetMonth  DateTime  @db.Date // 締め対象月（月初日で統一: 2026-02-01等）
  closedAt     DateTime  @default(now()) // 締め実行日時
  closedBy     Int // 締め実行者（MasterStaffへの外部キー）
  reopenedAt   DateTime? // 再オープン日時（null = ロック中）
  reopenedBy   Int? // 再オープン者
  reopenReason String? // 再オープン理由
  note         String?
  snapshotData Json? // クローズ時のPLスナップショット（経理システム追加）

  // Relations
  closer   MasterStaff  @relation("MonthCloser", fields: [closedBy], references: [id])
  reopener MasterStaff? @relation("MonthReopener", fields: [reopenedBy], references: [id])

  @@unique([targetMonth])
  @@map("stp_monthly_closes")
}

// ============================================
// 請求書番号採番カウンター (STP Invoice Number Sequences)
// INV-YYYYMM-NNNN形式の自動採番を安全に管理
// ============================================

model StpInvoiceNumberSequence {
  id                 Int      @id @default(autoincrement())
  operatingCompanyId Int? // FK → OperatingCompany（経理システム追加）
  yearMonth          String   @db.VarChar(7) // "2026-02" 形式
  lastNumber         Int      @default(0) // その月の最後の番号
  updatedAt          DateTime @updatedAt

  // Relations
  operatingCompany OperatingCompany? @relation(fields: [operatingCompanyId], references: [id])

  @@unique([operatingCompanyId, yearMonth])
  @@map("stp_invoice_number_sequences")
}

// ============================================
// 会計取込バッチ (Accounting Import Batches)
// freee/銀行CSVの取込履歴を管理
// ============================================

model AccountingImportBatch {
  id             Int       @id @default(autoincrement())
  source         String    @db.VarChar(20) // "freee" / "bank_csv" / "manual"
  sourceService  String?   @db.VarChar(30) // "freee", "mufg", "smbc" 等
  fileName       String?   @db.VarChar(500) // 取込ファイル名
  periodFrom     DateTime? @db.Date // 対象期間（開始）
  periodTo       DateTime? @db.Date // 対象期間（終了）
  totalCount     Int       @default(0) // 総件数
  newCount       Int       @default(0) // 新規取込件数
  duplicateCount Int       @default(0) // 重複スキップ件数
  status         String    @default("processing") @db.VarChar(20) // processing/completed/error
  errorMessage   String? // エラー時の内容
  importedBy     Int // 取込実行者（MasterStaffへの外部キー）
  importedAt     DateTime  @default(now()) // 取込日時
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  importer     MasterStaff             @relation(fields: [importedBy], references: [id])
  transactions AccountingTransaction[]

  @@index([source])
  @@index([importedAt])
  @@map("accounting_import_batches")
}

// ============================================
// 会計取引 (Accounting Transactions)
// freee・銀行の入出金データ（実際のお金の動き）
// ============================================

model AccountingTransaction {
  id               Int       @id @default(autoincrement())
  direction        String    @db.VarChar(10) // "incoming"（入金）/ "outgoing"（出金）
  transactionDate  DateTime  @db.Date // 取引日
  valueDate        DateTime? @db.Date // 決済日・受渡日
  amount           Int // 金額（税込）
  taxAmount        Int? // 消費税額
  counterpartyName String    @db.VarChar(200) // 取引先名（freee/銀行の表記）
  counterpartyCode String?   @db.VarChar(50) // 取引先コード（freee上の管理コード）
  description      String? // 摘要（銀行明細の摘要欄）
  memo             String? // 社内メモ
  accountCode      String?   @db.VarChar(20) // 勘定科目コード
  accountName      String?   @db.VarChar(100) // 勘定科目名
  bankAccountName  String?   @db.VarChar(100) // 口座名（みずほ普通、UFJ当座 等）

  // データ元
  source              String  @db.VarChar(20) // "freee" / "bank_csv" / "manual"
  sourceService       String? @db.VarChar(30) // 具体的なサービス名
  sourceTransactionId String? @db.VarChar(100) // 外部システムの取引ID
  sourceDealId        String? @db.VarChar(100) // freeeの取引(deal)ID
  importBatchId       Int? // 取込バッチID

  // 入出金履歴用フィールド
  balance            Int? // 残高（銀行明細の残高欄）
  operatingCompanyId Int? // 法人ID（FK → OperatingCompany）
  deduplicationHash  String? @db.VarChar(64) // 重複検知用SHA-256ハッシュ

  // 消込ステータス
  reconciliationStatus String @default("unmatched") @db.VarChar(20) // unmatched/partial/matched/excluded

  // プロジェクト紐付け（判明している場合）
  projectId Int? // MasterProjectへの外部キー

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  importBatch      AccountingImportBatch?     @relation(fields: [importBatchId], references: [id])
  project          MasterProject?             @relation(fields: [projectId], references: [id])
  operatingCompany OperatingCompany?          @relation(fields: [operatingCompanyId], references: [id])
  reconciliations  AccountingReconciliation[]
  verifications    AccountingVerification[]

  @@index([direction])
  @@index([transactionDate])
  @@index([counterpartyName])
  @@index([reconciliationStatus])
  @@index([projectId])
  @@index([source])
  @@index([sourceTransactionId])
  @@index([operatingCompanyId])
  @@index([deduplicationHash])
  @@map("accounting_transactions")
}

// ============================================
// 会計消込・照合 (Accounting Reconciliations)
// 会計取引とプロジェクト側レコードのN:N紐付け
// ============================================

model AccountingReconciliation {
  id              Int      @id @default(autoincrement())
  transactionId   Int // AccountingTransactionへの外部キー
  projectId       Int // master_projectsへの外部キー
  recordType      String   @db.VarChar(20) // "revenue" / "expense"
  revenueRecordId Int? // StpRevenueRecordへの外部キー（売上の場合）
  expenseRecordId Int? // StpExpenseRecordへの外部キー（経費の場合）
  allocatedAmount Int // この紐付けで消し込む金額
  note            String? // 消込時の備考
  matchMethod     String   @default("manual") @db.VarChar(10) // "auto"（自動照合）/ "manual"（手動）
  matchedBy       Int? // 消込実行者（MasterStaffへの外部キー）
  matchedAt       DateTime @default(now()) // 消込日時
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  transaction   AccountingTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  project       MasterProject         @relation(fields: [projectId], references: [id])
  revenueRecord StpRevenueRecord?     @relation("RevenueReconciliation", fields: [revenueRecordId], references: [id])
  expenseRecord StpExpenseRecord?     @relation("ExpenseReconciliation", fields: [expenseRecordId], references: [id])
  matcher       MasterStaff?          @relation("ReconciliationMatcher", fields: [matchedBy], references: [id])

  @@index([transactionId])
  @@index([revenueRecordId])
  @@index([expenseRecordId])
  @@index([projectId])
  @@map("accounting_reconciliations")
}

// ============================================
// 会計確認 (Accounting Verifications)
// プロジェクト担当と経理のダブルチェック記録
// ============================================

model AccountingVerification {
  id               Int       @id @default(autoincrement())
  transactionId    Int // AccountingTransactionへの外部キー
  verificationType String    @db.VarChar(20) // "project"（業務発生確認）/ "accounting"（経理確認）
  status           String    @default("pending") @db.VarChar(20) // pending/verified/flagged
  verifiedBy       Int // 確認者（MasterStaffへの外部キー）
  verifiedAt       DateTime? // 確認日時（null = 未確認）
  flagReason       String? // 問題ありの場合の理由
  note             String? // 確認メモ
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  transaction AccountingTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  verifier    MasterStaff           @relation(fields: [verifiedBy], references: [id])

  @@unique([transactionId, verificationType])
  @@index([verificationType])
  @@index([status])
  @@index([verifiedBy])
  @@map("accounting_verifications")
}

// ============================================
// 会計月次締め (Accounting Monthly Closes)
// プロジェクト横断の月次締め管理
// プロジェクト側の締め確認後、経理が最終締めを行う
// ============================================

model AccountingMonthlyClose {
  id                 Int       @id @default(autoincrement())
  targetMonth        DateTime  @db.Date // 締め対象月（月初日で統一: 2026-02-01等）
  projectId          Int // プロジェクトID（MasterProjectへの外部キー）
  status             String    @default("open") @db.VarChar(20) // open/project_closed/accounting_closed
  projectClosedAt    DateTime? // プロジェクト側締め日時
  projectClosedBy    Int? // プロジェクト側締め実行者
  accountingClosedAt DateTime? // 経理側最終締め日時
  accountingClosedBy Int? // 経理側最終締め実行者
  reopenedAt         DateTime? // 再オープン日時
  reopenedBy         Int? // 再オープン者
  reopenReason       String? // 再オープン理由
  note               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  project          MasterProject @relation(fields: [projectId], references: [id])
  projectCloser    MasterStaff?  @relation("AcctMonthProjectCloser", fields: [projectClosedBy], references: [id])
  accountingCloser MasterStaff?  @relation("AcctMonthAcctCloser", fields: [accountingClosedBy], references: [id])
  reopener         MasterStaff?  @relation("AcctMonthReopener", fields: [reopenedBy], references: [id])

  @@unique([targetMonth, projectId])
  @@index([targetMonth])
  @@index([projectId])
  @@index([status])
  @@map("accounting_monthly_closes")
}

// ============================================
// 役割種別 × プロジェクト 中間テーブル
// ============================================

model StaffRoleTypeProject {
  id         Int      @id @default(autoincrement())
  roleTypeId Int      @map("role_type_id")
  projectId  Int      @map("project_id")
  createdAt  DateTime @default(now()) @map("created_at")

  roleType StaffRoleType @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)
  project  MasterProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([roleTypeId, projectId])
  @@map("staff_role_type_projects")
}

// ============================================
// 担当者フィールド定義 (Staff Field Definitions)
// stella001が管理するフィールドマスタ
// ============================================

model StaffFieldDefinition {
  id           Int      @id @default(autoincrement())
  fieldCode    String   @unique @map("field_code") @db.VarChar(50) // "STP_COMPANY_SALES" 等
  fieldName    String   @map("field_name") @db.VarChar(100) // "STP企業 担当営業"
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  projectLinks StaffFieldDefinitionProject[]
  restrictions StaffFieldRestriction[]

  @@map("staff_field_definitions")
}

// ============================================
// 担当者フィールド × プロジェクト (どのPJの設定画面に出現するか)
// stella001が管理
// ============================================

model StaffFieldDefinitionProject {
  id                Int      @id @default(autoincrement())
  fieldDefinitionId Int      @map("field_definition_id")
  projectId         Int      @map("project_id")
  createdAt         DateTime @default(now()) @map("created_at")

  fieldDefinition StaffFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  project         MasterProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([fieldDefinitionId, projectId])
  @@map("staff_field_definition_projects")
}

// ============================================
// 担当者フィールド制約 (Staff Field Restrictions)
// PJ側が管理: フィールドごとにプロジェクト・役割で担当者を絞り込む
// sourceProjectId OR roleTypeId で OR結合
// ============================================

model StaffFieldRestriction {
  id                Int      @id @default(autoincrement())
  fieldDefinitionId Int      @map("field_definition_id") // FK → StaffFieldDefinition
  managingProjectId Int      @map("managing_project_id") // この制約を設定したPJ
  sourceProjectId   Int?     @map("source_project_id") // 選択肢に含めるPJ（OR条件）
  roleTypeId        Int?     @map("role_type_id") // 選択肢に含める役割（OR条件）
  createdAt         DateTime @default(now()) @map("created_at")

  fieldDefinition StaffFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  managingProject MasterProject        @relation("ManagingProjectRestrictions", fields: [managingProjectId], references: [id], onDelete: Cascade)
  sourceProject   MasterProject?       @relation("SourceProjectRestrictions", fields: [sourceProjectId], references: [id], onDelete: Cascade)
  roleType        StaffRoleType?       @relation(fields: [roleTypeId], references: [id], onDelete: Cascade)

  @@unique([fieldDefinitionId, managingProjectId, sourceProjectId, roleTypeId])
  @@index([fieldDefinitionId, managingProjectId], map: "idx_field_restrictions_field_managing")
  @@map("staff_field_restrictions")
}

// ============================================
// フィールド変更履歴 (Field Change Logs)
// 汎用的なフィールド変更記録テーブル
// ============================================

model FieldChangeLog {
  id          Int      @id @default(autoincrement())
  entityType  String   @db.VarChar(50) // "stp_company", "stp_agent", "stp_contract_history"
  entityId    Int // 対象レコードのID
  fieldName   String   @db.VarChar(50) // "salesStaffId", "adminStaffId" 等
  displayName String   @db.VarChar(100) // "担当営業", "担当事務" 等（UI表示用）
  oldValue    String? // 変更前の値
  newValue    String? // 変更後の値
  note        String // 変更理由メモ（必須）
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("field_change_logs")
}

// ============================================
// STP設定 (STP Settings)
// key-value形式でダッシュボード設定等を保存
// ============================================

model StpSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100) // 設定キー（例: "annual_revenue_target"）
  value     String // 設定値（JSON or テキスト）
  updatedAt DateTime @updatedAt

  @@map("stp_settings")
}

// ============================================
// ============================================
// 経理・財務管理システム テーブル（SPEC-ACCOUNTING-001）
// ============================================
// ============================================

// ============================================
// ① Transaction（取引）
// ============================================

model Transaction {
  id                     Int  @id @default(autoincrement())
  invoiceGroupId         Int? // FK → InvoiceGroup（売上側の請求グループ）
  paymentGroupId         Int? // FK → PaymentGroup（経費側の支払グループ）
  counterpartyId         Int // FK → Counterparty（取引先）
  recurringTransactionId Int? // FK → RecurringTransaction（定期取引から生成された場合）
  allocationTemplateId   Int? // FK → AllocationTemplate（按分ありの場合）
  costCenterId           Int? // FK → CostCenter（按分なしの場合のプロジェクト）
  expenseCategoryId      Int? // FK → ExpenseCategory（費目、未設定可）
  projectId              Int? // FK → MasterProject（どのプロジェクトで作成されたか）

  type      String // "revenue" | "expense"
  amount    Int // 金額（税抜）
  taxAmount Int // 消費税額
  taxRate   Int    @default(10) // 税率（%）
  taxType   String @default("tax_excluded") // "tax_included" | "tax_excluded"

  periodFrom           DateTime // 発生期間From
  periodTo             DateTime // 発生期間To
  paymentDueDate       DateTime? // 支払期日
  scheduledPaymentDate DateTime? // 入金/支払予定日
  paymentMethodId      Int? // FK → PaymentMethod（決済手段）

  status String @default("unconfirmed")
  // "unconfirmed" | "confirmed" | "awaiting_accounting" |
  // "returned" | "resubmitted" | "journalized" |
  // "partially_paid" | "paid" | "hidden"

  note String? // 摘要・メモ

  // 自動生成トラッキング
  isAutoGenerated        Boolean   @default(false)
  sourceType             String? // "crm" | "recurring" | "manual" | "slack"
  sourceDataChangedAt    DateTime? // ソースデータ変更日時
  latestCalculatedAmount Int? // 最新の計算金額（ソース変更時）

  // STP固有（移行用）
  stpRevenueType       String? // "initial" | "monthly" | "performance"
  stpExpenseType       String? // "agent_initial" | "agent_monthly" | "commission_initial" etc.
  stpCandidateId       Int? // FK → StpCandidate（成果報酬の場合）
  stpContractHistoryId Int? // FK → StpContractHistory
  stpContractHistory   StpContractHistory? @relation(fields: [stpContractHistoryId], references: [id])
  stpAgentId           Int? // FK → StpAgent

  // 経費負担者
  hasExpenseOwner Boolean @default(false) // 経費負担者を指定するか

  // 源泉徴収（経費の場合）
  isWithholdingTarget  Boolean  @default(false)
  withholdingTaxRate   Decimal?
  withholdingTaxAmount Int?
  netPaymentAmount     Int?

  isConfidential Boolean @default(false)

  journalCompleted Boolean @default(false) // 経理が仕訳完了を手動管理

  confirmedBy Int? // FK → MasterStaff
  confirmedAt DateTime?

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  invoiceGroup            InvoiceGroup?                @relation(fields: [invoiceGroupId], references: [id])
  paymentGroup            PaymentGroup?                @relation(fields: [paymentGroupId], references: [id])
  counterparty            Counterparty                 @relation(fields: [counterpartyId], references: [id])
  recurringTransaction    RecurringTransaction?        @relation(fields: [recurringTransactionId], references: [id])
  allocationTemplate      AllocationTemplate?          @relation(fields: [allocationTemplateId], references: [id])
  costCenter              CostCenter?                  @relation(fields: [costCenterId], references: [id])
  expenseCategory         ExpenseCategory?             @relation(fields: [expenseCategoryId], references: [id])
  project                 MasterProject?               @relation(fields: [projectId], references: [id])
  paymentMethod           PaymentMethod?               @relation(fields: [paymentMethodId], references: [id])
  confirmer               MasterStaff?                 @relation("TransactionConfirmer", fields: [confirmedBy], references: [id])
  creator                 MasterStaff                  @relation("TransactionCreator", fields: [createdBy], references: [id])
  updater                 MasterStaff?                 @relation("TransactionUpdater", fields: [updatedBy], references: [id])
  journalEntries          JournalEntry[]
  comments                TransactionComment[]
  attachments             Attachment[]
  allocationConfirmations AllocationConfirmation[]
  allocationOverrides     AllocationTemplateOverride[]
  allocationGroupItems    AllocationGroupItem[]
  expenseOwners           TransactionExpenseOwner[]
  cryptoDetail            CryptoTransactionDetail?
}

// ============================================
// ①-b TransactionExpenseOwner（経費負担者）
// ============================================

model TransactionExpenseOwner {
  id            Int      @id @default(autoincrement())
  transactionId Int
  staffId       Int? // FK → MasterStaff（スタッフ選択時）
  customName    String? // スタッフ外の手入力名（staffId が null の場合）
  createdAt     DateTime @default(now())

  transaction Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  staff       MasterStaff? @relation(fields: [staffId], references: [id])

  @@unique([transactionId, staffId])
  @@index([transactionId])
}

// ============================================
// ② InvoiceGroup（請求グループ）
// ============================================

model InvoiceGroup {
  id                 Int  @id @default(autoincrement())
  counterpartyId     Int // FK → Counterparty（請求先の取引先）
  operatingCompanyId Int // FK → OperatingCompany（請求元法人）
  bankAccountId      Int? // FK → OperatingCompanyBankAccount（振込先口座）

  invoiceNumber       String?   @unique // 請求書番号（例: STE-INV-202603-0001）
  invoiceDate         DateTime? // 請求日
  paymentDueDate      DateTime? // 入金期限
  expectedPaymentDate DateTime? // 入金予定日
  actualPaymentDate   DateTime? // 実際の入金日

  subtotal    Int? // 小計（税抜、自動計算）
  taxAmount   Int? // 消費税額（小計から一括計算）
  totalAmount Int? // 合計（税込、自動計算）

  pdfPath     String? // 生成済みPDFのファイルパス
  pdfFileName String? // PDFファイル名

  // 訂正請求書
  originalInvoiceGroupId Int? // FK → InvoiceGroup（訂正元）
  correctionType         String? // "replacement" | "additional"（差し替え/追加請求）

  // 請求書ビルダー用
  honorific        String  @default("御中") // 宛名敬称（御中/様）
  remarks          String? // 請求書備考欄
  lineOrder        Json? // 明細表示順 ["tx:15","memo:1","tx:23"]
  lineDescriptions Json? // 明細品目オーバーライド {"123":"カスタムテキスト"}

  status String @default("draft")
  // "draft" | "pdf_created" | "sent" | "awaiting_accounting" |
  // "partially_paid" | "paid" | "returned" | "corrected"

  // 経理が手動で切り替える入金完了ステータス
  // "unpaid"（未入金）/ "partial"（一部入金）/ "completed"（入金完了）
  // 振込手数料等で記録合計と請求金額が一致しないことがあるため、自動判定せず手動管理
  manualPaymentStatus String @default("unpaid") @map("manual_payment_status")

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  counterparty           Counterparty                 @relation(fields: [counterpartyId], references: [id])
  operatingCompany       OperatingCompany             @relation(fields: [operatingCompanyId], references: [id])
  bankAccount            OperatingCompanyBankAccount? @relation(fields: [bankAccountId], references: [id])
  originalInvoiceGroup   InvoiceGroup?                @relation("InvoiceCorrection", fields: [originalInvoiceGroupId], references: [id])
  correctedInvoiceGroups InvoiceGroup[]               @relation("InvoiceCorrection")
  transactions           Transaction[]
  allocationItems        AllocationGroupItem[]
  journalEntries         JournalEntry[]
  invoiceMails           InvoiceMail[]
  comments               TransactionComment[]
  attachments            Attachment[]
  memoLines              InvoiceGroupMemoLine[]
  bankTxGroupLinks       BankTransactionGroupLink[]
  receipts               InvoiceGroupReceipt[]
  projectId              Int?
  project                MasterProject?               @relation("ProjectInvoiceGroups", fields: [projectId], references: [id])
  creator                MasterStaff                  @relation("InvoiceGroupCreator", fields: [createdBy], references: [id])
  updater                MasterStaff?                 @relation("InvoiceGroupUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ②-b InvoiceGroupMemoLine（請求書メモ行）
// ============================================

model InvoiceGroupMemoLine {
  id             Int      @id @default(autoincrement())
  invoiceGroupId Int      @map("invoice_group_id")
  description    String
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  invoiceGroup InvoiceGroup @relation(fields: [invoiceGroupId], references: [id], onDelete: Cascade)

  @@map("invoice_group_memo_lines")
}

// ============================================
// ③ PaymentGroup（支払グループ）
// ============================================

model PaymentGroup {
  id                 Int       @id @default(autoincrement())
  counterpartyId     Int? // FK → Counterparty（支払先。手入力の場合はnull、経理がマスタ紐付け後にセット）
  operatingCompanyId Int // FK → OperatingCompany（支払元法人）
  targetMonth        DateTime? // 対象月（YYYY-MM-01）※廃止予定

  expectedPaymentDate DateTime? // 支払予定日
  paymentDueDate      DateTime? // 支払期限
  actualPaymentDate   DateTime? // 実際の支払日
  totalAmount         Int? // 合計金額
  taxAmount           Int? // 税額

  // 請求書発行依頼
  referenceCode       String? @unique // "PG-0042" — 作成時自動生成
  receivedPdfPath     String? // 受領した請求書PDFのパス
  receivedPdfFileName String? // 受領したPDFのファイル名

  // 受信請求書マッチング
  expectedInboundEmailId Int? // 返信を待つ受信メールアドレス

  paymentType            String  @default("invoice") // "invoice" | "direct"
  isConfidential         Boolean @default(false)
  customCounterpartyName String? // 手入力された取引先名（経理がマスタ紐付けするまでの仮値）

  status String @default("before_request")
  // invoice: "before_request" | "requested" | "invoice_received" |
  //          "rejected" | "re_requested" | "confirmed" |
  //          "awaiting_accounting" | "returned" | "paid"
  // direct:  "unprocessed" | "confirmed" | "pending_approval" |
  //          "awaiting_accounting" | "returned" | "paid"
  // pending_approval: 手動追加の経費が経理承認待ち状態

  // 経理が手動で切り替える支払完了ステータス
  // "unpaid"（未支払）/ "partial"（一部支払）/ "completed"（支払完了）
  // 振込手数料等で記録合計と支払金額が一致しないことがあるため、自動判定せず手動管理
  manualPaymentStatus String @default("unpaid") @map("manual_payment_status")

  confirmedBy Int? // FK → MasterStaff（請求書確認者）
  confirmedAt DateTime?

  // 経理承認フロー（手動追加された経費のみ使用）
  approverStaffId Int? // FK → MasterStaff（承認者）
  approvedAt      DateTime? // 経理承認日時

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  counterparty         Counterparty?              @relation(fields: [counterpartyId], references: [id])
  operatingCompany     OperatingCompany           @relation(fields: [operatingCompanyId], references: [id])
  transactions         Transaction[]
  allocationItems      AllocationGroupItem[]
  journalEntries       JournalEntry[]
  invoiceMails         InvoiceMail[]
  comments             TransactionComment[]
  attachments          Attachment[]
  projectId            Int?
  project              MasterProject?             @relation("ProjectPaymentGroups", fields: [projectId], references: [id])
  confirmer            MasterStaff?               @relation("PaymentGroupConfirmer", fields: [confirmedBy], references: [id])
  approver             MasterStaff?               @relation("PaymentGroupApprover", fields: [approverStaffId], references: [id])
  creator              MasterStaff                @relation("PaymentGroupCreator", fields: [createdBy], references: [id])
  updater              MasterStaff?               @relation("PaymentGroupUpdater", fields: [updatedBy], references: [id])
  expectedInboundEmail OperatingCompanyEmail?     @relation("ExpectedInbound", fields: [expectedInboundEmailId], references: [id])
  inboundInvoices      InboundInvoice[]
  bankTxGroupLinks     BankTransactionGroupLink[]
  payments             PaymentGroupPayment[]
}

// ============================================
// ③-b InvoiceGroupReceipt（請求グループ入金記録 — 経理側で複数回の入金を記録）
// ============================================

model InvoiceGroupReceipt {
  id                    Int      @id @default(autoincrement())
  invoiceGroupId        Int      @map("invoice_group_id")
  receivedDate          DateTime @map("received_date") // 入金日
  amount                Int // 入金額（税込）
  comment               String?  @db.VarChar(500) // 任意コメント
  createdById           Int      @map("created_by_id")
  bankTransactionLinkId Int?     @unique @map("bank_transaction_link_id") // 銀行履歴から自動生成された場合のリンク
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  invoiceGroup        InvoiceGroup              @relation(fields: [invoiceGroupId], references: [id], onDelete: Cascade)
  creator             MasterStaff               @relation("InvoiceGroupReceiptCreator", fields: [createdById], references: [id])
  bankTransactionLink BankTransactionGroupLink? @relation(fields: [bankTransactionLinkId], references: [id], onDelete: SetNull)

  @@index([invoiceGroupId])
  @@index([receivedDate])
  @@map("invoice_group_receipts")
}

// ============================================
// ③-c PaymentGroupPayment（支払グループ支払記録 — 経理側で複数回の支払を記録）
// ============================================

model PaymentGroupPayment {
  id                    Int      @id @default(autoincrement())
  paymentGroupId        Int      @map("payment_group_id")
  paidDate              DateTime @map("paid_date") // 支払日
  amount                Int // 支払額（税込）
  comment               String?  @db.VarChar(500) // 任意コメント
  createdById           Int      @map("created_by_id")
  bankTransactionLinkId Int?     @unique @map("bank_transaction_link_id") // 銀行履歴から自動生成された場合のリンク
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  paymentGroup        PaymentGroup              @relation(fields: [paymentGroupId], references: [id], onDelete: Cascade)
  creator             MasterStaff               @relation("PaymentGroupPaymentCreator", fields: [createdById], references: [id])
  bankTransactionLink BankTransactionGroupLink? @relation(fields: [bankTransactionLinkId], references: [id], onDelete: SetNull)

  @@index([paymentGroupId])
  @@index([paidDate])
  @@map("payment_group_payments")
}

// ============================================
// ④ RecurringTransaction（定期取引）
// ============================================

model RecurringTransaction {
  id                   Int  @id @default(autoincrement())
  counterpartyId       Int // FK → Counterparty
  expenseCategoryId    Int // FK → ExpenseCategory（費目）
  costCenterId         Int? // FK → CostCenter（按分なしの場合のプロジェクト）
  allocationTemplateId Int? // FK → AllocationTemplate（按分ありの場合）
  paymentMethodId      Int? // FK → PaymentMethod（決済手段）
  projectId            Int? // FK → MasterProject（どのプロジェクトで使用するか）
  approverStaffId      Int? // FK → MasterStaff（生成される取引の既定承認者）

  type             String // "revenue" | "expense"
  name             String // 名称（例: AWS利用料、オフィス家賃）
  amount           Int? // 金額（変動の場合はnull）
  taxAmount        Int? // 消費税額
  taxRate          Int       @default(10) // 税率（%）
  amountType       String    @default("fixed") // "fixed" | "variable"
  frequency        String // "once" | "monthly" | "yearly" | "weekly"
  intervalCount    Int       @default(1) // 繰り返し間隔（例: monthly × 2 = 2ヶ月ごと、yearly × 1 = 毎年）
  executeOnLastDay Boolean   @default(false) // monthly時、毎月末日に実行するフラグ（trueの場合 executionDay は無視）
  executionDay     Int? // monthly: 日付(1-31), yearly: 日付(1-31), weekly: 曜日(0=日,1=月,...,6=土)
  startDate        DateTime // 開始日（once の場合はこの日のみ生成）
  endDate          DateTime? // 終了日（null=継続中、超過で生成停止）
  isActive         Boolean   @default(true)
  note             String? // 摘要・メモ

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  counterparty       Counterparty                       @relation(fields: [counterpartyId], references: [id])
  expenseCategory    ExpenseCategory                    @relation(fields: [expenseCategoryId], references: [id])
  costCenter         CostCenter?                        @relation(fields: [costCenterId], references: [id])
  allocationTemplate AllocationTemplate?                @relation(fields: [allocationTemplateId], references: [id])
  paymentMethod      PaymentMethod?                     @relation(fields: [paymentMethodId], references: [id])
  project            MasterProject?                     @relation(fields: [projectId], references: [id])
  approver           MasterStaff?                       @relation("RecurringApprover", fields: [approverStaffId], references: [id])
  transactions       Transaction[]
  expenseOwners      RecurringTransactionExpenseOwner[]
  creator            MasterStaff                        @relation("RecurringCreator", fields: [createdBy], references: [id])
  updater            MasterStaff?                       @relation("RecurringUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ④-b RecurringTransactionExpenseOwner（定期取引の担当者・複数）
// ============================================

model RecurringTransactionExpenseOwner {
  id                     Int      @id @default(autoincrement())
  recurringTransactionId Int
  staffId                Int? // FK → MasterStaff
  customName             String? // スタッフ外の手入力名
  createdAt              DateTime @default(now())

  recurringTransaction RecurringTransaction @relation(fields: [recurringTransactionId], references: [id], onDelete: Cascade)
  staff                MasterStaff?         @relation(fields: [staffId], references: [id])

  @@unique([recurringTransactionId, staffId])
  @@index([recurringTransactionId])
}

// ============================================
// ⑤ CostCenter（按分先マスタ）
// ============================================

model CostCenter {
  id        Int     @id @default(autoincrement())
  name      String // 名称（例: STP事業、社内開発、管理部門）
  projectId Int? // FK → MasterProject（CRMプロジェクトと紐づく場合）
  isActive  Boolean @default(true)

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  project                   MasterProject?                @relation(fields: [projectId], references: [id])
  projectAssignments        CostCenterProjectAssignment[]
  transactions              Transaction[]
  recurringTransactions     RecurringTransaction[]
  allocationTemplateLines   AllocationTemplateLine[]
  allocationConfirmations   AllocationConfirmation[]
  allocationGroupItems      AllocationGroupItem[]
  ownerAllocationTemplates  AllocationTemplate[]          @relation("OwnerCostCenter")
  budgets                   Budget[]
  counterparty              Counterparty?
  creator                   MasterStaff?                  @relation("CostCenterCreator", fields: [createdBy], references: [id])
  updater                   MasterStaff?                  @relation("CostCenterUpdater", fields: [updatedBy], references: [id])
  projectDefaultCostCenters MasterProject[]               @relation("ProjectDefaultCostCenter")
}

// ============================================
// ⑤-b CostCenterProjectAssignment（経理プロジェクト↔CRMプロジェクト中間テーブル）
// ============================================

model CostCenterProjectAssignment {
  id           Int      @id @default(autoincrement())
  costCenterId Int
  projectId    Int
  createdAt    DateTime @default(now())

  costCenter CostCenter    @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  project    MasterProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([costCenterId, projectId])
  @@map("cost_center_project_assignments")
}

// ============================================
// ⑥ AllocationTemplate（按分テンプレート）
// ============================================

model AllocationTemplate {
  id       Int     @id @default(autoincrement())
  name     String // 名称（例: 外注Xさん、オフィス家賃）
  isActive Boolean @default(true)

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  ownerCostCenterId Int? // FK → CostCenter（代表プロジェクトのコストセンター）

  // Relations
  lines                 AllocationTemplateLine[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  overrides             AllocationTemplateOverride[]
  ownerCostCenter       CostCenter?                  @relation("OwnerCostCenter", fields: [ownerCostCenterId], references: [id])
  creator               MasterStaff                  @relation("AllocTemplateCreator", fields: [createdBy], references: [id])
  updater               MasterStaff?                 @relation("AllocTemplateUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑦ AllocationTemplateLine（按分テンプレート明細）
// ============================================

model AllocationTemplateLine {
  id             Int     @id @default(autoincrement())
  templateId     Int // FK → AllocationTemplate
  costCenterId   Int? // FK → CostCenter（null = 未確定枠）
  allocationRate Decimal // 按分率（%）。全明細の合計が100になること
  label          String? // 表示ラベル（「未確定」等）

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  template   AllocationTemplate @relation(fields: [templateId], references: [id])
  costCenter CostCenter?        @relation(fields: [costCenterId], references: [id])
  creator    MasterStaff?       @relation("AllocLineCreator", fields: [createdBy], references: [id])
  updater    MasterStaff?       @relation("AllocLineUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑧ AllocationConfirmation（按分確定）
// ============================================

model AllocationConfirmation {
  id            Int       @id @default(autoincrement())
  transactionId Int // FK → Transaction
  costCenterId  Int // FK → CostCenter
  confirmedBy   Int? // FK → MasterStaff
  confirmedAt   DateTime?

  createdAt DateTime @default(now())

  // Relations
  transaction Transaction  @relation(fields: [transactionId], references: [id])
  costCenter  CostCenter   @relation(fields: [costCenterId], references: [id])
  confirmer   MasterStaff? @relation(fields: [confirmedBy], references: [id])

  @@unique([transactionId, costCenterId])
}

// ============================================
// ⑨ AllocationTemplateOverride（按分テンプレート変更時の個別適用記録）
// ============================================

model AllocationTemplateOverride {
  id                   Int     @id @default(autoincrement())
  transactionId        Int // FK → Transaction
  allocationTemplateId Int // FK → AllocationTemplate
  snapshotRates        Json // 変更前の按分率スナップショット [{"costCenterId": 1, "rate": 50}, ...]
  reason               String? // 維持理由（任意）

  createdBy Int // FK → MasterStaff
  createdAt DateTime @default(now())

  // Relations
  transaction        Transaction        @relation(fields: [transactionId], references: [id])
  allocationTemplate AllocationTemplate @relation(fields: [allocationTemplateId], references: [id])
  creator            MasterStaff        @relation("AllocOverrideCreator", fields: [createdBy], references: [id])

  @@unique([transactionId, allocationTemplateId])
}

// ============================================
// ⑨-b AllocationGroupItem（按分グループ明細）
// 按分取引の各CostCenter分をInvoiceGroup/PaymentGroupに紐づける
// ============================================

model AllocationGroupItem {
  id                 Int    @id @default(autoincrement())
  transactionId      Int // FK → Transaction（按分元の取引）
  costCenterId       Int // FK → CostCenter（どのCostCenter分か）
  groupType          String // "invoice" | "payment"
  allocatedAmount    Int // 按分後の金額（税込）
  allocatedTaxAmount Int // 按分後の税額

  invoiceGroupId Int? // FK → InvoiceGroup（groupType="invoice"時のみ）
  paymentGroupId Int? // FK → PaymentGroup（groupType="payment"時のみ）

  createdBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transaction  Transaction   @relation(fields: [transactionId], references: [id])
  costCenter   CostCenter    @relation(fields: [costCenterId], references: [id])
  invoiceGroup InvoiceGroup? @relation(fields: [invoiceGroupId], references: [id])
  paymentGroup PaymentGroup? @relation(fields: [paymentGroupId], references: [id])
  creator      MasterStaff?  @relation("AllocGroupItemCreator", fields: [createdBy], references: [id])

  @@unique([transactionId, costCenterId, groupType])
  @@index([invoiceGroupId])
  @@index([paymentGroupId])
  @@index([transactionId])
}

// ============================================
// ⑩ ExpenseCategory（費目マスタ）
// ============================================

model ExpenseCategory {
  id               Int       @id @default(autoincrement())
  name             String // 名称（外注費、サブスク費、家賃等）
  type             String // "revenue" | "expense" | "both"
  systemCode       String?   @unique @db.VarChar(50) // NULLならユーザー作成、非NULLならシステム予約
  projectId        Int // FK → MasterProject（必須）
  defaultAccountId Int? // FK → Account（デフォルト勘定科目）
  displayOrder     Int       @default(0)
  isActive         Boolean   @default(true)
  deletedAt        DateTime?

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project               MasterProject          @relation(fields: [projectId], references: [id])
  defaultAccount        Account?               @relation(fields: [defaultAccountId], references: [id])
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  autoJournalRules      AutoJournalRule[]
  creator               MasterStaff?           @relation("ExpCatCreator", fields: [createdBy], references: [id])
  updater               MasterStaff?           @relation("ExpCatUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑪ JournalEntry（仕訳）
// ============================================

model JournalEntry {
  id                Int      @id @default(autoincrement())
  invoiceGroupId    Int? // FK → InvoiceGroup（売上側：請求グループ単位で紐づく）
  paymentGroupId    Int? // FK → PaymentGroup（経費側：支払グループ単位で紐づく）
  transactionId     Int? // FK → Transaction（個別取引に直接紐づく場合）
  bankTransactionId Int? // FK → BankTransaction（入出金起点の仕訳の場合）
  projectId         Int? // FK → MasterProject（プロジェクト）
  counterpartyId    Int? // FK → Counterparty（取引先）
  hasInvoice        Boolean  @default(true) // 適格請求書の有無
  journalDate       DateTime // 仕訳日
  description       String // 摘要

  isAutoGenerated        Boolean @default(false) // 自動生成フラグ
  status                 String  @default("draft") // "draft" | "confirmed"
  autoJournalRuleId      Int? // FK → AutoJournalRule（どのルールで生成されたか）
  sourceReconciliationId Int? // FK → Reconciliation（消込自動仕訳の生成元）

  // 実現/未実現ステータス
  realizationStatus String    @default("realized") // "realized" | "unrealized"
  scheduledDate     DateTime? // 実現予定日（未実現の場合、この日に経理が確認）
  realizedAt        DateTime? // 実際に実現にした日時
  realizedBy        Int? // FK → MasterStaff（実現操作をした担当者）

  approvedBy Int? // FK → MasterStaff（確定者）
  approvedAt DateTime?

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  invoiceGroup         InvoiceGroup?      @relation(fields: [invoiceGroupId], references: [id])
  paymentGroup         PaymentGroup?      @relation(fields: [paymentGroupId], references: [id])
  transaction          Transaction?       @relation(fields: [transactionId], references: [id])
  bankTransaction      BankTransaction?   @relation("JournalBankTransaction", fields: [bankTransactionId], references: [id])
  autoJournalRule      AutoJournalRule?   @relation(fields: [autoJournalRuleId], references: [id])
  sourceReconciliation Reconciliation?    @relation("ReconciliationAutoJournals", fields: [sourceReconciliationId], references: [id])
  project              MasterProject?     @relation(fields: [projectId], references: [id])
  counterparty         Counterparty?      @relation(fields: [counterpartyId], references: [id])
  lines                JournalEntryLine[]
  reconciliations      Reconciliation[]
  attachments          Attachment[]
  approver             MasterStaff?       @relation("JournalApprover", fields: [approvedBy], references: [id])
  realizer             MasterStaff?       @relation("JournalRealizer", fields: [realizedBy], references: [id])
  creator              MasterStaff        @relation("JournalCreator", fields: [createdBy], references: [id])
  updater              MasterStaff?       @relation("JournalUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑫ JournalEntryLine（仕訳明細）
// ============================================

model JournalEntryLine {
  id             Int     @id @default(autoincrement())
  journalEntryId Int // FK → JournalEntry
  side           String // "debit" | "credit"（借方/貸方）
  accountId      Int // FK → Account（勘定科目）
  amount         Int // 金額
  description    String? // 明細摘要（任意）

  // 消費税
  taxClassification String? // 消費税区分: "taxable_10" | "taxable_8" | "exempt" | "non_taxable" | "tax_free_export" | "taxable_10_no_invoice" | "taxable_8_no_invoice"
  taxAmount         Int? // 消費税額

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])
  creator      MasterStaff? @relation("JournalLineCreator", fields: [createdBy], references: [id])
  updater      MasterStaff? @relation("JournalLineUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑬ Account（勘定科目）
// ============================================

model Account {
  id           Int     @id @default(autoincrement())
  code         String  @unique // 科目コード（例: "1100"）
  name         String // 科目名（例: 売掛金）
  category     String // "asset" | "liability" | "equity" | "revenue" | "cost_of_sales" | "sga" | "non_operating_revenue" | "non_operating_expense" | "extraordinary_income" | "extraordinary_loss"
  subcategory  String? // サブカテゴリ（例: "流動資産", "有形固定資産", "人件費"）
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  journalEntryLines JournalEntryLine[]
  expenseCategories ExpenseCategory[]
  debitRules        AutoJournalRule[]  @relation("DebitAccount")
  creditRules       AutoJournalRule[]  @relation("CreditAccount")
  budgets           Budget[]
  creator           MasterStaff?       @relation("AccountCreator", fields: [createdBy], references: [id])
  updater           MasterStaff?       @relation("AccountUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑭ BankTransaction（入出金）
// ============================================

model BankTransaction {
  id              Int      @id @default(autoincrement())
  transactionDate DateTime // 日付
  direction       String // "incoming" | "outgoing"（入金/出金）
  paymentMethodId Int // FK → PaymentMethod（決済手段）
  counterpartyId  Int? // FK → Counterparty（取引先）
  amount          Int // 金額
  description     String? // 摘要
  source          String   @default("manual") // "manual" | "legacy" | "csv_import"（データ元識別）
  linkCompleted   Boolean  @default(false) @map("link_completed") // 経理がグループへの紐付け完了を手動で押したか

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  paymentMethod   PaymentMethod              @relation(fields: [paymentMethodId], references: [id])
  counterparty    Counterparty?              @relation(fields: [counterpartyId], references: [id])
  reconciliations Reconciliation[]
  journalEntries  JournalEntry[]             @relation("JournalBankTransaction")
  attachments     Attachment[]
  cryptoDetail    CryptoTransactionDetail?
  groupLinks      BankTransactionGroupLink[]
  creator         MasterStaff                @relation("BankTxCreator", fields: [createdBy], references: [id])
  updater         MasterStaff?               @relation("BankTxUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑭-b BankTransactionGroupLink（銀行入出金 ↔ 請求/支払グループ 多対多）
// 1つの入出金で複数グループを消し込む or 1つのグループが複数入金で分割着金するケースに対応
// ============================================

model BankTransactionGroupLink {
  id                Int      @id @default(autoincrement())
  bankTransactionId Int
  invoiceGroupId    Int? // どちらか一方のみ
  paymentGroupId    Int?
  amount            Int // この紐付けで割り当てる金額
  note              String?
  createdBy         Int // FK → MasterStaff
  createdAt         DateTime @default(now())

  bankTransaction BankTransaction      @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  invoiceGroup    InvoiceGroup?        @relation(fields: [invoiceGroupId], references: [id], onDelete: Cascade)
  paymentGroup    PaymentGroup?        @relation(fields: [paymentGroupId], references: [id], onDelete: Cascade)
  creator         MasterStaff          @relation("BankTxGroupLinkCreator", fields: [createdBy], references: [id])
  invoiceReceipt  InvoiceGroupReceipt? // 自動生成された入金記録 (1:1)
  paymentPayment  PaymentGroupPayment? // 自動生成された支払記録 (1:1)

  @@index([bankTransactionId])
  @@index([invoiceGroupId])
  @@index([paymentGroupId])
}

// ============================================
// ⑮ Reconciliation（消込）
// ============================================

model Reconciliation {
  id                Int @id @default(autoincrement())
  journalEntryId    Int // FK → JournalEntry
  bankTransactionId Int // FK → BankTransaction
  amount            Int // 消込金額

  performedBy Int // FK → MasterStaff（消込実行者）
  performedAt DateTime @default(now())

  createdAt DateTime @default(now())

  // Relations
  journalEntry       JournalEntry    @relation(fields: [journalEntryId], references: [id])
  bankTransaction    BankTransaction @relation(fields: [bankTransactionId], references: [id])
  performer          MasterStaff     @relation("ReconciliationPerformer", fields: [performedBy], references: [id])
  autoJournalEntries JournalEntry[]  @relation("ReconciliationAutoJournals")
}

// ============================================
// ⑯ Counterparty（取引先マスタ）
// ============================================

model Counterparty {
  id               Int     @id @default(autoincrement())
  displayId        String? @unique // "SC-1"（Stella顧客）or "TP-1"（その他）
  name             String // 名称
  companyId        Int? // FK → MasterStellaCompany（Stella顧客と紐づく場合）
  costCenterId     Int?    @unique // FK → CostCenter（経理プロジェクト按分先の場合）
  counterpartyType String  @default("other")
  // "customer" | "vendor" | "service" | "project" | "other"
  memo             String?
  isActive         Boolean @default(true)

  // インボイス制度
  isInvoiceRegistered       Boolean   @default(false) // 適格請求書発行事業者か
  invoiceRegistrationNumber String? // 登録番号（T+13桁）
  invoiceEffectiveDate      DateTime? // インボイス適用開始日

  // 統合管理
  mergedIntoId Int? // FK → Counterparty（統合先）
  mergedAt     DateTime?

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  company               MasterStellaCompany?   @relation(fields: [companyId], references: [id])
  costCenter            CostCenter?            @relation(fields: [costCenterId], references: [id])
  mergedInto            Counterparty?          @relation("CounterpartyMerge", fields: [mergedIntoId], references: [id])
  mergedFrom            Counterparty[]         @relation("CounterpartyMerge")
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  bankTransactions      BankTransaction[]
  autoJournalRules      AutoJournalRule[]
  invoiceGroups         InvoiceGroup[]
  paymentGroups         PaymentGroup[]
  journalEntries        JournalEntry[]
  creator               MasterStaff?           @relation("CounterpartyCreator", fields: [createdBy], references: [id])
  updater               MasterStaff?           @relation("CounterpartyUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑰ AutoJournalRule（自動仕訳ルール）
// ============================================

model AutoJournalRule {
  id                Int     @id @default(autoincrement())
  counterpartyId    Int? // FK → Counterparty（null = 全取引先）
  transactionType   String? // "revenue" | "expense"（null = 両方）
  expenseCategoryId Int? // FK → ExpenseCategory（null = 全費目）
  debitAccountId    Int // FK → Account（借方科目）
  creditAccountId   Int // FK → Account（貸方科目）
  priority          Int     @default(100) // 優先度（小さいほど高い）
  isActive          Boolean @default(true)

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  counterparty    Counterparty?    @relation(fields: [counterpartyId], references: [id])
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  debitAccount    Account          @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount   Account          @relation("CreditAccount", fields: [creditAccountId], references: [id])
  journalEntries  JournalEntry[]
  creator         MasterStaff      @relation("AutoJournalCreator", fields: [createdBy], references: [id])
  updater         MasterStaff?     @relation("AutoJournalUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑱ PaymentMethod（決済手段マスタ）
// ============================================

model PaymentMethod {
  id         Int    @id @default(autoincrement())
  methodType String // "cash" | "bank_account" | "credit_card" | "crypto_wallet"
  name       String // 名称（例: 三菱UFJ普通、会社用VISA）
  details    Json? // 種別ごとの詳細情報

  // 残高管理
  initialBalance     Int? // 初期残高
  initialBalanceDate DateTime? // 初期残高日

  // 残高アラート
  balanceAlertThreshold Int? // 残高アラート閾値

  // クレカ専用
  closingDay          Int? // 締め日
  paymentDay          Int? // 引落日
  settlementAccountId Int? // FK → PaymentMethod（引落口座）

  availableFor String  @default("both") // "incoming" | "outgoing" | "both"
  isActive     Boolean @default(true)

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  settlementAccount     PaymentMethod?                @relation("CreditCardSettlement", fields: [settlementAccountId], references: [id])
  creditCards           PaymentMethod[]               @relation("CreditCardSettlement")
  bankTransactions      BankTransaction[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  cryptoDetails         CryptoTransactionDetail[]
  bankAccounts          OperatingCompanyBankAccount[]
  creator               MasterStaff?                  @relation("PayMethodCreator", fields: [createdBy], references: [id])
  updater               MasterStaff?                  @relation("PayMethodUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ⑲ Attachment（証憑）
// ============================================

model Attachment {
  id                Int  @id @default(autoincrement())
  transactionId     Int? // FK → Transaction
  journalEntryId    Int? // FK → JournalEntry
  bankTransactionId Int? // FK → BankTransaction
  commentId         Int? // FK → TransactionComment（コメント返信時の添付）
  invoiceGroupId    Int? // FK → InvoiceGroup（請求添付ファイル）
  paymentGroupId    Int? // FK → PaymentGroup（支払添付ファイル）

  fileName       String
  filePath       String // ストレージパス
  fileSize       Int? // バイト数
  mimeType       String?
  attachmentType String  @default("other")
  // "invoice" | "estimate" | "delivery_note" | "order" | "order_confirmation" | "purchase_order" | "contract" | "receipt" | "voucher" | "other"

  displayName   String? // ユーザー入力の表示名部分（拡張子除く）
  generatedName String? // 自動生成ファイル名全体（例: 請求書_テスト株式会社御中_20260227_191446.pdf）

  uploadedBy Int // FK → MasterStaff
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  // Relations
  transaction     Transaction?        @relation(fields: [transactionId], references: [id])
  journalEntry    JournalEntry?       @relation(fields: [journalEntryId], references: [id])
  bankTransaction BankTransaction?    @relation(fields: [bankTransactionId], references: [id])
  comment         TransactionComment? @relation(fields: [commentId], references: [id])
  invoiceGroup    InvoiceGroup?       @relation(fields: [invoiceGroupId], references: [id])
  paymentGroup    PaymentGroup?       @relation(fields: [paymentGroupId], references: [id])
  uploader        MasterStaff         @relation("AttachmentUploader", fields: [uploadedBy], references: [id])
}

// ============================================
// ⑳ CryptoTransactionDetail（仮想通貨取引詳細）
// ============================================

model CryptoTransactionDetail {
  id                 Int     @id @default(autoincrement())
  transactionId      Int?    @unique // FK → Transaction
  bankTransactionId  Int?    @unique // FK → BankTransaction
  currency           String // 銘柄（USDT、BTC、ETH等）
  network            String // ネットワーク（TRC20、ERC20等）
  counterpartyWallet String? // 取引先Walletアドレス
  ownWallet          String? // 自社Walletアドレス
  foreignAmount      Decimal // 外貨金額
  foreignCurrency    String // 外貨単位（USD等）
  exchangeRate       Decimal // レート
  paymentMethodId    Int? // FK → PaymentMethod

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transaction     Transaction?     @relation(fields: [transactionId], references: [id])
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  paymentMethod   PaymentMethod?   @relation(fields: [paymentMethodId], references: [id])
  creator         MasterStaff?     @relation("CryptoDetailCreator", fields: [createdBy], references: [id])
  updater         MasterStaff?     @relation("CryptoDetailUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ㉑ SystemSetting（システム設定）
// ============================================

model SystemSetting {
  id           Int     @id @default(autoincrement())
  category     String // "crypto_currency" | "crypto_network" 等
  value        String // 選択肢の値（"USDT", "BTC", "TRC20" 等）
  label        String? // 表示ラベル（null の場合は value をそのまま表示）
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creator MasterStaff? @relation("SystemSettingCreator", fields: [createdBy], references: [id])
  updater MasterStaff? @relation("SystemSettingUpdater", fields: [updatedBy], references: [id])

  @@unique([category, value])
}

// ============================================
// ㉒ Budget（予算）
// ============================================

model Budget {
  id            Int      @id @default(autoincrement())
  costCenterId  Int? // FK → CostCenter（null = 全社）
  accountId     Int? // FK → Account（紐づく勘定科目）
  categoryLabel String // 予算カテゴリラベル（売上、外注費、家賃等）
  targetMonth   DateTime // 対象月（YYYY-MM-01）
  budgetAmount  Int // 予算額
  memo          String?

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  costCenter CostCenter?  @relation(fields: [costCenterId], references: [id])
  account    Account?     @relation(fields: [accountId], references: [id])
  creator    MasterStaff  @relation("BudgetCreator", fields: [createdBy], references: [id])
  updater    MasterStaff? @relation("BudgetUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ㉓ MonthlyCloseLog（月次クローズ履歴）
// ============================================

model MonthlyCloseLog {
  id           Int      @id @default(autoincrement())
  projectId    Int? // FK → MasterProject（null = 全社クローズ）
  targetMonth  DateTime // 対象月（YYYY-MM-01）
  action       String // "close" | "reopen"
  reason       String? // 再オープン時の理由（必須）
  snapshotData Json? // クローズ時のPLスナップショット（closeの場合）

  performedBy Int // FK → MasterStaff（経理管理者）
  performedAt DateTime @default(now())

  // Relations
  project   MasterProject? @relation(fields: [projectId], references: [id])
  performer MasterStaff    @relation("MonthlyClosePerformer", fields: [performedBy], references: [id])

  @@index([targetMonth])
  @@index([projectId, targetMonth])
}

// ============================================
// ㉔ OperatingCompanyEmail（運営法人メールアドレス）
// ============================================

model OperatingCompanyEmail {
  id                 Int     @id @default(autoincrement())
  operatingCompanyId Int? // FK → OperatingCompany（任意）
  email              String
  label              String? // 用途（例: 請求書送付用、一般問い合わせ用）
  smtpHost           String? // SMTP設定（null=システム共通設定を使用）
  smtpPort           Int?
  smtpUser           String?
  smtpPass           String?
  isDefault          Boolean @default(false)

  // IMAP設定（受信チェック用）
  imapHost                      String?
  imapPort                      Int?
  imapUser                      String?
  imapPass                      String?
  enableInbound                 Boolean @default(false)
  lastCheckedImapUid            Int     @default(0) // システムが最後にチェックしたIMAP UID
  lastCheckedCloudsignUid       Int     @default(0) // CloudSign署名メール用の最終チェックUID
  lastCheckedCloudsignBounceUid Int     @default(0) @map("last_checked_cloudsign_bounce_uid") // CloudSign送信失敗通知用の最終チェックUID

  deletedAt DateTime?

  createdBy Int? // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  operatingCompany             OperatingCompany? @relation(fields: [operatingCompanyId], references: [id])
  invoiceMails                 InvoiceMail[]
  projectEmails                ProjectEmail[]
  expectedInboundPaymentGroups PaymentGroup[]    @relation("ExpectedInbound")
  inboundInvoices              InboundInvoice[]
  selfSigningContracts         MasterContract[]  @relation("SelfSigningEmail")
  creator                      MasterStaff?      @relation("OpCoEmailCreator", fields: [createdBy], references: [id])
  updater                      MasterStaff?      @relation("OpCoEmailUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ㉔-b ProjectEmail（プロジェクト別メール設定）
// ============================================

model ProjectEmail {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  emailId   Int      @map("email_id")
  isDefault Boolean  @default(false) @map("is_default")
  memo      String? // このアドレスの説明メモ（例: 「STP請求書送付用」）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project MasterProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email   OperatingCompanyEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@unique([projectId, emailId])
  @@map("project_emails")
}

// ============================================
// ㉔-c ProjectBankAccount（プロジェクト別銀行口座設定）
// ============================================

model ProjectBankAccount {
  id            Int      @id @default(autoincrement())
  projectId     Int      @map("project_id")
  bankAccountId Int      @map("bank_account_id")
  isDefault     Boolean  @default(false) @map("is_default")
  memo          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project     MasterProject               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bankAccount OperatingCompanyBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([projectId, bankAccountId])
  @@map("project_bank_accounts")
}

// ============================================
// ㉕ InvoiceTemplate（請求書テンプレート）
// ============================================

model InvoiceTemplate {
  id                   Int     @id @default(autoincrement())
  operatingCompanyId   Int // FK → OperatingCompany
  projectId            Int?    @map("project_id") // FK → MasterProject（PJごとの管理）
  name                 String // テンプレート名
  templateType         String // "sending" | "request"（送付用/発行依頼用）
  emailSubjectTemplate String // メール件名テンプレート
  emailBodyTemplate    String // メール本文テンプレート（テンプレート変数使用可）
  isDefault            Boolean @default(false)

  createdBy Int // FK → MasterStaff
  updatedBy Int? // FK → MasterStaff
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  operatingCompany OperatingCompany @relation(fields: [operatingCompanyId], references: [id])
  project          MasterProject?   @relation(fields: [projectId], references: [id])
  creator          MasterStaff      @relation("InvoiceTemplateCreator", fields: [createdBy], references: [id])
  updater          MasterStaff?     @relation("InvoiceTemplateUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ㉖ InvoiceMail（請求書送信履歴）
// ============================================

model InvoiceMail {
  id                 Int  @id @default(autoincrement())
  invoiceGroupId     Int? // FK → InvoiceGroup（請求書送付の場合）
  paymentGroupId     Int? // FK → PaymentGroup（発行依頼の場合）
  operatingCompanyId Int // FK → OperatingCompany
  senderEmailId      Int? // FK → OperatingCompanyEmail

  sendMethod String // "email" | "line" | "postal" | "other"
  subject    String? // 件名（メール以外はnull可）
  body       String? // 本文
  pdfPath    String? // 添付PDFのパス

  status       String    @default("draft")
  // "draft" | "sent" | "failed"
  sentBy       Int? // FK → MasterStaff（送信実行者）
  sentAt       DateTime? // 送信日時
  errorMessage String? // 送信失敗時のエラー内容

  createdBy Int // FK → MasterStaff（下書き作成者）
  updatedBy Int? // FK → MasterStaff（最終更新者）
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  invoiceGroup     InvoiceGroup?          @relation(fields: [invoiceGroupId], references: [id])
  paymentGroup     PaymentGroup?          @relation(fields: [paymentGroupId], references: [id])
  operatingCompany OperatingCompany       @relation(fields: [operatingCompanyId], references: [id])
  senderEmail      OperatingCompanyEmail? @relation(fields: [senderEmailId], references: [id])
  recipients       InvoiceMailRecipient[]
  sender           MasterStaff?           @relation("InvoiceMailSender", fields: [sentBy], references: [id])
  creator          MasterStaff            @relation("InvoiceMailCreator", fields: [createdBy], references: [id])
  updater          MasterStaff?           @relation("InvoiceMailUpdater", fields: [updatedBy], references: [id])
}

// ============================================
// ㉗ InvoiceMailRecipient（請求書送信先）
// ============================================

model InvoiceMailRecipient {
  id            Int     @id @default(autoincrement())
  invoiceMailId Int // FK → InvoiceMail
  contactId     Int? // FK → StellaCompanyContact（既存担当者から選んだ場合）
  name          String? // 手動入力の場合の名前
  email         String // メールアドレス
  recipientType String // "to" | "cc" | "bcc"

  createdAt DateTime @default(now())

  // Relations
  invoiceMail InvoiceMail           @relation(fields: [invoiceMailId], references: [id])
  contact     StellaCompanyContact? @relation(fields: [contactId], references: [id])
}

// ============================================
// ㉘ TransactionComment（取引コメント）
// ============================================

model TransactionComment {
  id             Int  @id @default(autoincrement())
  transactionId  Int? // FK → Transaction
  invoiceGroupId Int? // FK → InvoiceGroup
  paymentGroupId Int? // FK → PaymentGroup
  parentId       Int? // FK → TransactionComment（スレッド返信の場合、親コメントID）

  body             String // コメント本文
  commentType      String  @default("normal")
  // "normal" | "return" | "approval" | "question"
  returnReasonType String? // 差し戻し時の種別: "question" | "correction_request" | "approval_check" | "other"

  createdBy Int // FK → MasterStaff
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  // Relations
  transaction  Transaction?         @relation(fields: [transactionId], references: [id])
  invoiceGroup InvoiceGroup?        @relation(fields: [invoiceGroupId], references: [id])
  paymentGroup PaymentGroup?        @relation(fields: [paymentGroupId], references: [id])
  parent       TransactionComment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies      TransactionComment[] @relation("CommentThread")
  attachments  Attachment[]
  creator      MasterStaff          @relation("CommentCreator", fields: [createdBy], references: [id])
}

// ============================================
// ㉙ Notification（通知）
// ============================================

model Notification {
  id          Int     @id @default(autoincrement())
  recipientId Int // FK → MasterStaff（宛先）
  senderType  String // "system" | "staff"
  senderId    Int? // FK → MasterStaff（スタッフからの通知の場合）
  category    String // "finance" | "accounting" | "kpi" | "system" | "other"
  title       String
  message     String
  linkUrl     String? // 関連ページへのリンク

  status          String    @default("unread")
  // "unread" | "read" | "in_progress" | "completed"
  statusChangedAt DateTime?
  statusChangedBy Int? // FK → MasterStaff

  // アクション（承認など）
  actionType     String? // "payment_group_approval" など
  actionTargetId Int? // 対象レコードのID

  createdAt DateTime @default(now())

  // Relations
  recipient     MasterStaff  @relation("NotificationRecipient", fields: [recipientId], references: [id])
  sender        MasterStaff? @relation("NotificationSender", fields: [senderId], references: [id])
  statusChanger MasterStaff? @relation("NotificationStatusChanger", fields: [statusChangedBy], references: [id])
}

// ============================================
// ㉚ ChangeLog（変更履歴）
// ============================================

model ChangeLog {
  id         Int    @id @default(autoincrement())
  tableName  String // テーブル名（例: "Transaction", "JournalEntry"）
  recordId   Int // 変更されたレコードのID
  changeType String // "create" | "update" | "delete"
  oldData    Json? // 変更前のデータ
  newData    Json? // 変更後のデータ

  changedBy Int // FK → MasterStaff
  changedAt DateTime @default(now())

  // Relations
  changer MasterStaff @relation("ChangeLogChanger", fields: [changedBy], references: [id])
}

// ============================================
// 候補判定（TransactionCandidateDecision）
// ============================================

model TransactionCandidateDecision {
  id           Int     @id @default(autoincrement())
  candidateKey String  @db.VarChar(200) // "crm-revenue-initial-123" 等
  targetMonth  String  @db.VarChar(7) // "2026-03"（YYYY-MM形式、Zodで厳格検証）
  status       String  @default("pending") // pending | converted | held | dismissed
  reasonType   String? @db.VarChar(50) // held_price_undecided, dismissed_duplicate, etc.
  memo         String?
  needsReview  Boolean @default(false)

  // ソース変更検知用フィンガープリント（SHA-256ハッシュ）
  sourceFingerprint String?

  // 変動金額候補用（Phase 3）
  overrideAmount               Int?
  overrideTaxAmount            Int?
  overrideTaxRate              Int?
  overrideMemo                 String?
  overrideScheduledPaymentDate DateTime? @db.Date

  decidedBy Int? // FK → MasterStaff
  decidedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  decider MasterStaff? @relation("CandidateDecisionDecider", fields: [decidedBy], references: [id])

  @@unique([candidateKey, targetMonth])
}

// ============================================
// 受信請求書（InboundInvoice）
// ============================================

model InboundInvoice {
  id                Int      @id @default(autoincrement())
  messageId         String // メール Message-ID
  attachmentIndex   Int // 同一メール内の添付ファイル番号（0始まり）
  receivedByEmailId Int // どのアドレスで受信したか
  fromEmail         String
  fromName          String?
  subject           String?
  emailBody         String? // メール本文（テキスト）
  receivedAt        DateTime

  paymentGroupId  Int? // マッチ先（null = 未マッチ）
  matchConfidence String? // "high" | "medium" | "low"
  referenceCode   String? // PDF名から抽出した PG-XXXX

  attachmentFileName String?
  attachmentPath     String? // 仮保存パス（/uploads/inbound-invoices/）
  attachmentSize     Int?
  attachmentMimeType String?

  status      String    @default("pending") // pending | unmatched | confirmed | rejected
  processedBy Int?
  processedAt DateTime?
