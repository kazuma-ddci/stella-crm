  paymentGroup    PaymentGroup?         @relation(fields: [paymentGroupId], references: [id])
  processor       MasterStaff?          @relation("InboundInvoiceProcessor", fields: [processedBy], references: [id])

  @@unique([messageId, attachmentIndex])
