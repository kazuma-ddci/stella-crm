  name         String   @db.VarChar(100)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  progresses HojoLoanProgress[]

  @@map("hojo_loan_progress_statuses")
}

// ============================================
// 貸金 顧客進捗管理
// ============================================

model HojoLoanProgress {
  id               Int @id @default(autoincrement())
  formSubmissionId Int @unique
  vendorId         Int

  // フォームから自動取得
  companyName   String?  @db.VarChar(255) // 社名（屋号名）
  representName String?  @db.VarChar(255) // 代表者(契約者)氏名
  loanAmount    Decimal? @db.Decimal(14, 0) // 貸付金額（フォームの借入希望金額）
  applicantType String?  @db.VarChar(20) // "法人" or "個人事業主"

  // ベンダー入力
  requestDate       DateTime? // 依頼日
  toolPurchasePrice Decimal?  @db.Decimal(14, 0) // ツール購入代金
  fundTransferDate  DateTime? // 資金移動日
  loanExecutionDate DateTime? // 貸付実行日（時刻含む）

  // 貸金業社入力
  statusId         Int?
  memo             String?   @db.Text // 備考
  memorandum       String?   @db.Text // 覚書
  funds            String?   @db.Text // 資金
  repaymentDate    DateTime? // 返金日(着金日)
  repaymentAmount  Decimal?  @db.Decimal(14, 0) // 返金額(着金額)
  principalAmount  Decimal?  @db.Decimal(14, 0) // 元金分
  interestAmount   Decimal?  @db.Decimal(14, 0) // 利息分
  overshortAmount  Decimal?  @db.Decimal(14, 0) // 過不足
  operationFee     Decimal?  @db.Decimal(14, 0) // 運用フィー
  redemptionAmount Decimal?  @db.Decimal(14, 0) // 償還額
  redemptionDate   DateTime? // 償還日
  endMemo          String?   @db.Text // 返済備考

  // 弊社スタッフ専用
