  createdAt    DateTime    @default(now())
  deletedAt    DateTime?

  @@map("slp_documents")
}

// SLP配布動画
// PDF資料と同じく1本のみ配布中（isActive=true）の設計
model SlpVideo {
  id           Int         @id @default(autoincrement())
  fileName     String      @db.VarChar(255) // アップロード時の元ファイル名
  filePath     String      @db.VarChar(500) // サーバー上の保存パス（public/uploads以下）
  fileSize     Int // ファイルサイズ（バイト）
