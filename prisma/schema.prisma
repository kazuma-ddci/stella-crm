// ============================================
// SLP 企業名簿 (SLP Company Records)
// 概要案内予約時にレコードが追加される
// ============================================

model SlpCompanyRecord {
  id         Int     @id @default(autoincrement())
  prolineUid String? @map("proline_uid") @db.VarChar(100) // プロライン側のUID（変更/キャンセル時の検索キー）

  // 商談情報（ステータス・日時・担当者・Zoom・予約ID等）は SlpMeetingSession + SlpMeetingSessionZoom に移行済み
  // Phase 1c で旧カラム briefing_* / consultation_* / reservation_id / merged_*_reservation_ids を削除

  // ============================================
  // 企業基本情報（Phase 1 で追加）
  // ============================================
  companyName                        String?   @map("company_name") @db.VarChar(200) // 企業名
  representativeName                 String?   @map("representative_name") @db.VarChar(100) // 代表者名
  employeeCount                      Int?      @map("employee_count") // 従業員数
  prefecture                         String?   @db.VarChar(20) // 都道府県
  address                            String?   @db.VarChar(500) // 住所
  companyPhone                       String?   @map("company_phone") @db.VarChar(50) // 企業電話番号
  pensionOffice                      String?   @map("pension_office") @db.VarChar(100) // 管轄の年金事務所
  pensionOfficerName                 String?   @map("pension_officer_name") @db.VarChar(100) // 年金事務所担当者名
  industryId                         Int?      @map("industry_id") // 業種マスタID
  flowSourceId                       Int?      @map("flow_source_id") // 流入経路マスタID
  salesStaffId                       Int?      @map("sales_staff_id") // 担当営業（スタッフID）
  status1Id                          Int?      @map("status1_id") // 企業ステータス①マスタID
  status2Id                          Int?      @map("status2_id") // 企業ステータス②マスタID
  lastContactDate                    DateTime? @map("last_contact_date") @db.Date // 最終接触日
  annualLaborCostExecutive           Decimal?  @map("annual_labor_cost_executive") @db.Decimal(15, 2) // 年間人件費（役員様分、円）
  annualLaborCostEmployee            Decimal?  @map("annual_labor_cost_employee") @db.Decimal(15, 2) // 年間人件費（従業員様分、円）
  averageMonthlySalary               Decimal?  @map("average_monthly_salary") @db.Decimal(15, 2) // 平均月給（円）
  // プロライン予約フォーム(form3-2〜4)でユーザーが入力した生テキスト。
  // 「5000万円」「約50人」等、数値に自動変換できない回答もそのまま保存し、
  // 企業詳細画面で数値入力欄の上にサジェストとして表示する（スタッフが見て手動で数値化）。
  annualLaborCostExecutiveFormAnswer String?   @map("annual_labor_cost_executive_form_answer") @db.VarChar(500) // 年間人件費(役員)フォーム回答
  annualLaborCostEmployeeFormAnswer  String?   @map("annual_labor_cost_employee_form_answer") @db.VarChar(500) // 年間人件費(従業員)フォーム回答
  employeeCountFormAnswer            String?   @map("employee_count_form_answer") @db.VarChar(500) // 従業員数フォーム回答

  // ============================================
  // 事業形態・法人/個人事業主対応
  // ============================================
  businessType        String? @map("business_type") @db.VarChar(20) // "corporation" | "sole_proprietor"
  corporateNumber     String? @map("corporate_number") @db.VarChar(13) // 法人番号（将来の全企業マスタ統合で法人同一判定に使用）
  companyEmail        String? @map("company_email") @db.VarChar(255) // 企業メール / 事業用メール
  representativePhone String? @map("representative_phone") @db.VarChar(50) // 代表者電話番号
  representativeEmail String? @map("representative_email") @db.VarChar(255) // 代表者メールアドレス
  primaryContactId    Int?    @map("primary_contact_id") // 代表者として選択した担当者ID

  // ============================================
  // 金額・契約情報（Phase 1 で追加）
  // ============================================
  initialFee            Decimal?  @map("initial_fee") @db.Decimal(15, 2) // 初期導入費用
  initialPeopleCount    Int?      @map("initial_people_count") // 初期導入人数
  monthlyFee            Decimal?  @map("monthly_fee") @db.Decimal(15, 2) // 月額利用料
  monthlyPeopleCount    Int?      @map("monthly_people_count") // 月額利用人数
  contractDate          DateTime? @map("contract_date") @db.Date // 契約日
  lastPaymentDate       DateTime? @map("last_payment_date") @db.Date // 前回の支払日
  invoiceSentDate       DateTime? @map("invoice_sent_date") @db.Date // 請求書送付日
  nextPaymentDate       DateTime? @map("next_payment_date") @db.Date // 次回の支払日
  estMaxRefundPeople    Int?      @map("est_max_refund_people") // 想定最大還付人数
  estMaxRefundAmount    Decimal?  @map("est_max_refund_amount") @db.Decimal(15, 2) // 想定最大還付金額
  estOurRevenue         Decimal?  @map("est_our_revenue") @db.Decimal(15, 2) // 想定弊社売上
  estAgentPayment       Decimal?  @map("est_agent_payment") @db.Decimal(15, 2) // 想定代理店支払金額
  confirmedRefundPeople Int?      @map("confirmed_refund_people") // 確定還付人数
  confirmedRefundAmount Decimal?  @map("confirmed_refund_amount") @db.Decimal(15, 2) // 確定還付金額
  confirmedOurRevenue   Decimal?  @map("confirmed_our_revenue") @db.Decimal(15, 2) // 確定弊社売上
  confirmedAgentPayment Decimal?  @map("confirmed_agent_payment") @db.Decimal(15, 2) // 確定代理店支払金額
  paymentReceivedDate   DateTime? @map("payment_received_date") @db.Date // 着金日

  // ============================================
  // 全顧客マスタとの紐付け（任意）
  // 同じ会社が他プロジェクトにも登録されている場合、全社マスタのIDをここに入れて集約する
  // ============================================
  masterCompanyId Int? @map("master_company_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  contacts              SlpCompanyContact[]
  primaryContact        SlpCompanyContact?              @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  salesStaff            MasterStaff?                    @relation("SlpCompanySalesStaff", fields: [salesStaffId], references: [id])
  industry              SlpIndustryMaster?              @relation(fields: [industryId], references: [id])
  flowSource            SlpFlowSourceMaster?            @relation(fields: [flowSourceId], references: [id])
  status1               SlpCompanyStatus1Master?        @relation(fields: [status1Id], references: [id])
  status2               SlpCompanyStatus2Master?        @relation(fields: [status2Id], references: [id])
  statusHistories       SlpCompanyRecordStatusHistory[]
  submittedDocuments    SlpCompanyDocument[]
  reservationHistories  SlpReservationHistory[]
  masterCompany         MasterStellaCompany?            @relation("SlpCompanyRecordToMaster", fields: [masterCompanyId], references: [id])
  contactHistories      SlpContactHistory[]             @relation("SlpContactHistoryCompanyRecord")

  // 重複統合関連リレーション
  duplicateCandidatesA SlpCompanyDuplicateCandidate[] @relation("DuplicateCandidateA")
  duplicateCandidatesB SlpCompanyDuplicateCandidate[] @relation("DuplicateCandidateB")
  duplicateExclusionsA SlpCompanyDuplicateExclusion[] @relation("DuplicateExclusionA")
  duplicateExclusionsB SlpCompanyDuplicateExclusion[] @relation("DuplicateExclusionB")

  // Zoom送信ログ（SlpMeetingSession と紐付くが、企業側からも辿れるよう保持）
  zoomSendLogs SlpZoomSendLog[] @relation("SlpZoomSendLogsForCompany")

  // 商談セッション
  meetingSessions SlpMeetingSession[] @relation("SlpCompanyRecordSessions")

  @@index([prolineUid])
  @@index([industryId])
  @@index([flowSourceId])
  @@index([salesStaffId])
  @@index([status1Id])
  @@index([status2Id])
  @@index([masterCompanyId])
  @@map("slp_company_records")
}

// ============================================
// SLP 企業重複候補キャッシュ (SLP Company Duplicate Candidates)
// 企業名・電話番号・住所のいずれかが部分一致する企業ペアを記録する
// 基本情報の更新時に再計算される
// ============================================

model SlpCompanyDuplicateCandidate {
  id         Int      @id @default(autoincrement())
  recordIdA  Int      @map("record_id_a") // 小さい方のID
  recordIdB  Int      @map("record_id_b") // 大きい方のID
  reasons    String[] // 一致した理由 ["企業名", "電話番号", "住所"]
  detectedAt DateTime @default(now()) @map("detected_at")

  recordA SlpCompanyRecord @relation("DuplicateCandidateA", fields: [recordIdA], references: [id], onDelete: Cascade)
  recordB SlpCompanyRecord @relation("DuplicateCandidateB", fields: [recordIdB], references: [id], onDelete: Cascade)

  @@unique([recordIdA, recordIdB])
  @@index([recordIdA])
  @@index([recordIdB])
  @@map("slp_company_duplicate_candidates")
}

// ============================================
// SLP 企業重複除外 (SLP Company Duplicate Exclusions)
// 「この2社は重複ではない」とスタッフが判定したペアを記録する
// 一度マークしたペアは重複候補として表示されなくなる
// ============================================

model SlpCompanyDuplicateExclusion {
  id           Int      @id @default(autoincrement())
  recordIdA    Int      @map("record_id_a") // 小さい方のID
  recordIdB    Int      @map("record_id_b") // 大きい方のID
  excludedById Int?     @map("excluded_by_id") // マークしたスタッフ
  reason       String?  @db.Text // 任意のメモ
  createdAt    DateTime @default(now()) @map("created_at")

  recordA    SlpCompanyRecord @relation("DuplicateExclusionA", fields: [recordIdA], references: [id], onDelete: Cascade)
  recordB    SlpCompanyRecord @relation("DuplicateExclusionB", fields: [recordIdB], references: [id], onDelete: Cascade)
  excludedBy MasterStaff?     @relation("SlpDuplicateExclusionStaff", fields: [excludedById], references: [id])

  @@unique([recordIdA, recordIdB])
  @@index([recordIdA])
  @@index([recordIdB])
  @@map("slp_company_duplicate_exclusions")
}

// ============================================
// SLP 予約履歴 (SLP Reservation History)
// 概要案内・導入希望商談 の予約・変更・キャンセル履歴を保存する。
// プロラインのwebhookから来るたびに記録（新規予約・変更・キャンセル）。
// 既存データは遡及作成しないので、テーブル作成後の予約からのみ記録される。
// ============================================

model SlpReservationHistory {
  id              Int       @id @default(autoincrement())
  companyRecordId Int       @map("company_record_id")
  reservationType String    @map("reservation_type") @db.VarChar(20) // "briefing" | "consultation"
  actionType      String    @map("action_type") @db.VarChar(20) // "予約" | "変更" | "キャンセル"
  reservationId   String?   @map("reservation_id") @db.VarChar(100) // プロラインの予約ID（その時点の値）
  reservedAt      DateTime? @map("reserved_at") // 案内日/商談日（その時点の値）
  bookedAt        DateTime? @map("booked_at") // 予約発生日時（その時点の値）
  staffName       String?   @map("staff_name") @db.VarChar(100) // 担当者名スナップショット
  staffId         Int?      @map("staff_id") // 解決済みスタッフID（FKなし、参照のみ）
  formAnswers     Json?     @map("form_answers") // 新規予約時のフォーム回答（年間人件費・従業員数等）。将来のフォーム拡張に備えてJSON
  createdAt       DateTime  @default(now()) @map("created_at")

  // 商談セッション紐付け（Phase 1で追加 — nullable、段階移行）
  sessionId   Int? @map("session_id")
  roundNumber Int? @map("round_number")

  companyRecord SlpCompanyRecord   @relation(fields: [companyRecordId], references: [id], onDelete: Cascade)
  session       SlpMeetingSession? @relation("SlpReservationHistorySession", fields: [sessionId], references: [id])

  @@index([companyRecordId, reservationType, createdAt(sort: Desc)])
  @@index([sessionId])
  @@map("slp_reservation_history")
}

// ============================================
// SLP 企業 提出書類
// 企業の担当者（公式LINE友達）が公開フォームから提出する各種書類を管理する
// 「初回提出書類」(category=initial) … 源泉徴収簿/算定基礎届/賃金台帳 × 5期分
// 「追加提出書類」(category=additional) … 被保険者資格取得届/月額変更届/賞与支払届/標準報酬決定通知書（無制限）
// 同じスロット (companyRecordId, category, documentType, fiscalPeriod) に
// 上書きアップロードした場合は古いレコードも削除せず、isCurrent=false で履歴として保持する
// ============================================

model SlpCompanyDocument {
  id              Int       @id @default(autoincrement())
  companyRecordId Int       @map("company_record_id")
  category        String    @db.VarChar(20) // "initial" | "additional"
  documentType    String    @map("document_type") @db.VarChar(50) // "withholding_book" | "calculation_base" | "wage_ledger" | "qualification_acquisition" | "monthly_change" | "bonus_payment" | "standard_remuneration"
  fiscalPeriod    Int?      @map("fiscal_period") // 0=直近期, 1=1期前, 2=2期前, 3=3期前, 4=4期前 (initial時のみ。additional時は null)
  fileName        String    @map("file_name") @db.VarChar(500) // 元のファイル名（表示用）
  filePath        String    @map("file_path") @db.VarChar(1000) // /uploads/slp/company-documents/... 形式の公開パス
  fileSize        Int?      @map("file_size")
  mimeType        String?   @map("mime_type") @db.VarChar(100)
  uploadedByUid   String?   @map("uploaded_by_uid") @db.VarChar(100) // 提出者の SlpLineFriend.uid
  uploadedByName  String?   @map("uploaded_by_name") @db.VarChar(200) // 提出時の LINE 名スナップショット（後で友達名が変わっても残す）
  isCurrent       Boolean   @default(true) @map("is_current") // 同スロットの最新版か（initial の上書き履歴管理用。additional は常に true）
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at") // 論理削除（管理画面から）

  companyRecord SlpCompanyRecord @relation(fields: [companyRecordId], references: [id], onDelete: Cascade)

  @@index([companyRecordId])
  @@index([companyRecordId, category, documentType, fiscalPeriod])
  @@index([companyRecordId, isCurrent, deletedAt])
  @@index([deletedAt])
  @@map("slp_company_documents")
}

// ============================================
// SLP 企業名簿 ステータス変更履歴
// 手動変更時の理由を記録する
// ============================================

model SlpCompanyRecordStatusHistory {
  id          Int      @id @default(autoincrement())
  recordId    Int      @map("record_id")
  flow        String   @default("briefing") @db.VarChar(20) // "briefing"=概要案内, "consultation"=導入希望商談
  fromStatus  String?  @map("from_status") @db.VarChar(50)
  toStatus    String?  @map("to_status") @db.VarChar(50)
  reason      String?  @db.Text
  changedById Int?     @map("changed_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  record    SlpCompanyRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  changedBy MasterStaff?     @relation("SlpCompanyRecordStatusChanger", fields: [changedById], references: [id])

  @@index([recordId])
  @@map("slp_company_record_status_histories")
}

// ============================================
// SLP 企業名簿 担当者 (SLP Company Contacts)
// 1企業に複数の担当者を紐付け
// ============================================

model SlpCompanyContact {
  id              Int      @id @default(autoincrement())
  companyRecordId Int      @map("company_record_id")
  name            String?  @db.VarChar(200) // 名前
  role            String?  @db.VarChar(100) // 役割（代表者/主担当者/その他自由入力）
  email           String?  @db.VarChar(255) // メールアドレス
  phone           String?  @db.VarChar(50) // 電話番号
  lineFriendId    Int?     @map("line_friend_id") // 公式LINE友達
  isPrimary       Boolean  @default(false) @map("is_primary")
  /// 商談の確定・変更・リマインド等をLINEで受け取るか。デフォルトON。
  /// 予約者（SlpMeetingSession.bookerContactId）の場合はこのフラグに関わらず必ず送信される。
  receivesSessionNotifications Boolean @default(true) @map("receives_session_notifications")
  createdAt       DateTime @default(now()) @map("created_at")

  // AS担当の手動上書き（自動解決値を上書きする場合のみ設定）
  manualAsId          Int?      @map("manual_as_id") // 手動設定したAS（SlpAs.id）
  manualAsReason      String?   @map("manual_as_reason") @db.Text // 変更理由（手動上書き時必須）
  manualAsChangedAt   DateTime? @map("manual_as_changed_at") // 手動上書きした日時
  manualAsChangedById Int?      @map("manual_as_changed_by_id") // 手動上書きしたスタッフID

  companyRecord     SlpCompanyRecord           @relation(fields: [companyRecordId], references: [id], onDelete: Cascade)
  primaryOf         SlpCompanyRecord[]         @relation("PrimaryContact")
  lineFriend        SlpLineFriend?             @relation(fields: [lineFriendId], references: [id])
  manualAs          SlpAs?                     @relation("SlpCompanyContactManualAs", fields: [manualAsId], references: [id])
  manualAsChangedBy MasterStaff?               @relation("SlpCompanyContactManualAsChangedBy", fields: [manualAsChangedById], references: [id])
  bookedSessions    SlpMeetingSession[]        @relation("SessionBooker")
  notifyOverrides   SlpSessionNotifyContact[]

  @@map("slp_company_contacts")
}

// ============================================
// SLP プロライン担当者マッピング (SLP Proline Staff Mapping)
// ProLineから来る「概要案内担当者 / 導入希望商談担当者」のテキスト名を、
// LINE友達およびスタッフに紐付けるためのマスタ
// （概要案内・導入希望商談どちらでも共用）
//
// DBテーブル名は互換性のため slp_briefing_staff_mappings のまま
// ============================================

model SlpProlineStaffMapping {
  id               Int      @id @default(autoincrement())
  prolineStaffName String   @unique @map("briefing_staff_name") @db.VarChar(100) // プロライン担当者名（DBカラムは旧名のまま）
  lineFriendId     Int?     @map("line_friend_id") // 公式LINE友達
  staffId          Int?     @map("staff_id") // スタッフ
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lineFriend SlpLineFriend? @relation(fields: [lineFriendId], references: [id])
  staff      MasterStaff?   @relation(fields: [staffId], references: [id])

  @@map("slp_briefing_staff_mappings")
}

// ============================================
// SLP 業種マスタ (SLP Industry Master)
// 企業名簿の「業種」プルダウン選択肢。スタッフが画面から自由に追加可能
