model SlpIndustryMaster {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100) // 業種名
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyRecords SlpCompanyRecord[]

  @@map("slp_industry_masters")
}

// ============================================
// SLP 流入経路マスタ (SLP Flow Source Master)
// 企業名簿の「流入経路」プルダウン選択肢。スタッフが画面から自由に追加可能
// ============================================

model SlpFlowSourceMaster {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100) // 流入経路名（例: LINE/SNS/紹介/HP/展示会）
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyRecords SlpCompanyRecord[]

  @@map("slp_flow_source_masters")
}

// ============================================
// SLP 企業ステータス①マスタ (SLP Company Status1 Master)
// 企業名簿の「ステータス①」プルダウン選択肢。スタッフが画面から自由に追加可能
// ============================================

model SlpCompanyStatus1Master {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100) // ステータス①名
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyRecords SlpCompanyRecord[]

  @@map("slp_company_status1_masters")
}

// ============================================
// SLP 企業ステータス②マスタ (SLP Company Status2 Master)
// 企業名簿の「ステータス②」プルダウン選択肢。スタッフが画面から自由に追加可能
// ============================================

model SlpCompanyStatus2Master {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100) // ステータス②名
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyRecords SlpCompanyRecord[]

  @@map("slp_company_status2_masters")
}

// ============================================
// 補助金プロジェクト フォーム回答
// ============================================

model HojoFormSubmission {
  id                         Int       @id @default(autoincrement())
  formType                   String    @db.VarChar(100) // フォーム種別（例: "digital-promotion"）
  companyName                String?   @db.VarChar(255) // 会社名／屋号
  representName              String?   @db.VarChar(255) // 代表者氏名
  email                      String?   @db.VarChar(255) // メールアドレス
  phone                      String?   @db.VarChar(50) // 電話番号
  answers                    Json // 元の回答データ（JSON・不変）
  modifiedAnswers            Json? // 変更後の回答データ（JSON・編集時のみ）
  changeHistory              Json? // 変更履歴（JSON配列: [{changedAt, changedBy, changes: [{field, oldValue, newValue}]}]）
  fileUrls                   Json? // アップロードファイルURL群（JSON配列）
  vendorMemo                 String?   @map("vendor_memo") @db.Text // ベンダー備考
  lenderMemo                 String?   @map("lender_memo") @db.Text // 貸金業社備考
  staffMemo                  String?   @map("staff_memo") @db.Text // 弊社備考
  linkedApplicationSupportId Int?      @map("linked_application_support_id") // 確定紐付け先の申請者レコードID
  linkedAt                   DateTime? @map("linked_at") // 紐付け日時
  confirmedAt                DateTime? @map("confirmed_at") // 確定日時（スタッフが「確定」ボタンを押した日時）
  rpaRunningAt               DateTime? @map("rpa_running_at") // RPA実行中の排他フラグ。10分以上前のものは stale として無視して再実行可
  submittedAt                DateTime  @default(now())
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  deletedAt                  DateTime?

  loanProgress             HojoLoanProgress?
  linkedApplicationSupport HojoApplicationSupport? @relation("FormSubmissionLink", fields: [linkedApplicationSupportId], references: [id], onDelete: SetNull)

  @@index([linkedApplicationSupportId])
  @@map("hojo_form_submissions")
}

// ============================================
// 補助金プロジェクト LINE友達情報
// 4アカウント分の公式LINE友達データを管理
// ============================================

// 申請サポートセンター
model HojoLineFriendShinseiSupport {
  id               Int       @id @default(autoincrement())
  snsname          String?   @db.VarChar(200)
  password         String?   @db.VarChar(100)
  emailLine        String?   @db.VarChar(255)
  emailRenkei      String?   @db.VarChar(255)
  emailLine2       String?   @db.VarChar(255)
  email            String?   @db.VarChar(255)
  uid              String    @unique @db.VarChar(100)
  friendAddedDate  DateTime?
  activeStatus     String?   @db.VarChar(50)
