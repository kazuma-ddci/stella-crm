// ============================================

model HojoApplicationSupport {
  id                    Int       @id @default(autoincrement())
  lineFriendId          Int // LINE友達（助成金申請サポート）のID（同一LINEユーザーで複数レコード可）
  vendorId              Int? // 紹介元ベンダー
  vendorIdManual        Boolean   @default(false) @map("vendor_id_manual") // true=手動設定、false=free1から自動設定
  statusId              Int? // 自社ステータス
  applicantName         String?   @db.VarChar(200) // 申請者名
  detailMemo            String?   @db.Text // 詳細メモ
  formAnswerDate        DateTime? // フォーム回答日
  formTranscriptDate    DateTime? // フォーム転記日
  applicationFormDate   DateTime? // 申請フォーム入力日
  documentStorageUrl    String?   @db.VarChar(2000) // 資料保管URL
  subsidyDesiredDate    DateTime? @map("subsidy_desired_date") // 助成金着金希望日
  subsidyAmount         Int?      @map("subsidy_amount") // 助成金額
  paymentReceivedDate   DateTime? // 原資着金日
  paymentReceivedAmount Int? // 原資金額
  bbsTransferAmount     Int? // BBSへの振込額
  bbsTransferDate       DateTime? // BBSへの振込日
  subsidyReceivedDate   DateTime? // 助成金着金日
  alkesMemo             String?   @map("alkes_memo") @db.Text // ALKES備考
  bbsMemo               String?   @map("bbs_memo") @db.Text // BBS備考
  bbsStatus             String?   @map("bbs_status") @db.VarChar(50) // BBSステータス（旧・文字列）
  bbsStatusId           Int?      @map("bbs_status_id") // BBSステータス（新・FK）
  vendorMemo            String?   @map("vendor_memo") @db.Text // ベンダー備考
  pdfGenerationRunningAt     DateTime? @map("pdf_generation_running_at") // 資料PDF生成中の排他フラグ。10分以上前は stale として無視
  pdfGenerationRunningDocType String?  @map("pdf_generation_running_doc_type") @db.VarChar(50) // 現在生成中の資料種別（training_report / support_application / business_plan）
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  lineFriend            HojoLineFriendJoseiSupport        @relation(fields: [lineFriendId], references: [id], onDelete: Cascade)
  vendor                HojoVendor?                       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  status                HojoApplicationStatus?            @relation(fields: [statusId], references: [id], onDelete: SetNull)
  bbsStatusRef          HojoBbsStatus?                    @relation(fields: [bbsStatusId], references: [id], onDelete: SetNull)
  grantCustomerPreApps  HojoGrantCustomerPreApplication[]
  linkedFormSubmissions HojoFormSubmission[]              @relation("FormSubmissionLink")
  documents             HojoApplicationSupportDocument[]

  @@map("hojo_application_supports")
}

// API費用日次上限の解除記録。1日1行のみ作成される（date ユニーク）。
// 管理者が「制限解除」ボタンを押すと当日分のレコードが作成され、
// その日は上限チェックがスキップされる。翌日 (JST 0時) 以降は再び上限有効。
model HojoDailyApiCostOverride {
  id                  Int      @id @default(autoincrement())
  date                DateTime @db.Date // JST日付（UTCでの0時起算、ユニーク）
  overriddenAt        DateTime @default(now()) @map("overridden_at")
  overriddenByStaffId Int?     @map("overridden_by_staff_id")
  reason              String?  @db.Text

  overriddenByStaff MasterStaff? @relation(fields: [overriddenByStaffId], references: [id], onDelete: SetNull)

  @@unique([date])
  @@map("hojo_daily_api_cost_overrides")
}

model HojoApplicationSupportDocument {
  id                   Int      @id @default(autoincrement())
  applicationSupportId Int      @map("application_support_id")
  docType              String   @map("doc_type") @db.VarChar(50)
  filePath             String   @map("file_path") @db.VarChar(500)
  fileName             String   @map("file_name") @db.VarChar(255)
  generatedAt          DateTime @default(now()) @map("generated_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // AI生成系（docType = "business_plan" のみで使用。他 docType では NULL）
  generatedSections   Json?    @map("generated_sections")
  editedSections      Json?    @map("edited_sections")
  modelName           String?  @map("model_name") @db.VarChar(50)
  inputTokens         Int?     @map("input_tokens")
  outputTokens        Int?     @map("output_tokens")
  cacheReadTokens     Int?     @map("cache_read_tokens")
  cacheCreationTokens Int?     @map("cache_creation_tokens")
  costUsd             Decimal? @map("cost_usd") @db.Decimal(10, 6)

  // 再生成直前の編集内容＆PDFファイルのバックアップ（1世代のみ保持）
  previousEditedSections Json?    @map("previous_edited_sections")
  previousFilePath       String?  @map("previous_file_path") @db.VarChar(500)
  previousFileName       String?  @map("previous_file_name") @db.VarChar(255)

  applicationSupport HojoApplicationSupport @relation(fields: [applicationSupportId], references: [id], onDelete: Cascade)

  @@unique([applicationSupportId, docType])
  @@index([applicationSupportId])
  @@map("hojo_application_support_documents")
}

