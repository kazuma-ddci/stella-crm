// ============================================
// スタッフのミーティング連携（Zoom / 将来のGoogle Meet等）
// スタッフ個別にOAuthトークンを保存。refresh_token/access_tokenはAES-256-GCMで暗号化。
// 連携は本人のみ、連携解除はSLP manager以上。
// ============================================
model StaffMeetingIntegration {
  id                    Int       @id @default(autoincrement())
  staffId               Int       @map("staff_id")
  provider              String    @db.VarChar(30) // "zoom" | "google_meet"
  externalUserId        String    @map("external_user_id") @db.VarChar(200) // Zoom user id等
  externalEmail         String?   @map("external_email") @db.VarChar(255)
  externalDisplayName   String?   @map("external_display_name") @db.VarChar(200)
  refreshTokenEnc       String    @map("refresh_token_enc") @db.Text
  accessTokenEnc        String?   @map("access_token_enc") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  scope                 String?   @db.Text
  connectedAt           DateTime  @default(now()) @map("connected_at")
  lastRefreshedAt       DateTime? @map("last_refreshed_at")
  disconnectedAt        DateTime? @map("disconnected_at")
  disconnectedByStaffId Int?      @map("disconnected_by_staff_id")

  staff          MasterStaff  @relation("StaffMeetingIntegrations", fields: [staffId], references: [id], onDelete: Cascade)
  disconnectedBy MasterStaff? @relation("StaffMeetingIntegrationsDisconnectedBy", fields: [disconnectedByStaffId], references: [id])

  @@unique([staffId, provider])
  @@index([provider])
  @@index([disconnectedAt])
  @@map("staff_meeting_integrations")
}

// SlpZoomMessageTemplate は SlpNotificationTemplate に統合、Phase 1c で削除

// ============================================
// SLP Zoom AI プロンプトテンプレート
// 議事録要約・先方参加者抽出・お礼メッセージ生成用のシステムプロンプト。
// CRM上でスタッフが編集可能、Claude Sonnet 4.6 / Haiku 4.5 が使用。
// ============================================
model SlpZoomAiPromptTemplate {
  id               Int      @id @default(autoincrement())
  templateKey      String   @unique @map("template_key") @db.VarChar(100)
  label            String   @db.VarChar(200)
  promptBody       String   @map("prompt_body") @db.Text
  model            String   @default("claude-sonnet-4-6") @db.VarChar(80)
  maxTokens        Int      @default(8192) @map("max_tokens")
  updatedByStaffId Int?     @map("updated_by_staff_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  updatedBy MasterStaff? @relation("SlpZoomAiPromptTemplateUpdater", fields: [updatedByStaffId], references: [id])

  @@map("slp_zoom_ai_prompt_templates")
}

// ============================================
// SLP Zoom プロライン送信ログ
// FormZoomGuide/Consult 経由でお客様に送ったメッセージの全履歴。
// 送信失敗時のリトライ判定・監査用。
// ============================================
model SlpZoomSendLog {
  id              Int      @id @default(autoincrement())
  /// セッション非依存の紹介者通知（friend_added / contract_signed など）では null。
  /// 商談関連（briefing / consultation）では事業者IDが入る。
  companyRecordId Int?     @map("company_record_id")
  category        String   @db.VarChar(30) // "briefing" | "consultation" | "referral"
  trigger         String   @db.VarChar(50) // "confirm" | "change" | "remind_day_before" | "remind_hour_before" | "friend_added" | "contract_signed" 等
  uid             String   @db.VarChar(100)
  formId          String   @map("form_id") @db.VarChar(100)
  fieldKey        String   @map("field_key") @db.VarChar(50) // "form16-1" 等
  bodyText        String   @map("body_text") @db.Text
  status          String   @db.VarChar(30) // "success" | "failed"
  errorMessage    String?  @map("error_message") @db.Text
  httpStatus      Int?     @map("http_status")
  sentAt          DateTime @default(now()) @map("sent_at")

  // 商談セッション紐付け（Phase 1で追加 — nullable、段階移行）
  sessionId   Int?    @map("session_id")
  recipient   String? @db.VarChar(20) // "customer" | "referrer"

  companyRecord SlpCompanyRecord?  @relation("SlpZoomSendLogsForCompany", fields: [companyRecordId], references: [id], onDelete: Cascade)
  session       SlpMeetingSession? @relation("SlpZoomSendLogSession", fields: [sessionId], references: [id])

  @@index([companyRecordId])
  @@index([sentAt])
  @@index([status])
  @@index([sessionId])
  @@map("slp_zoom_send_logs")
}

// ============================================
// SLP Zoom 録画・議事録（Zoom URL情報を含む）
// 1つの接触履歴に複数のZoom記録を紐付け可能（1:N、途中切れ+再開時等）。
// URL情報(joinUrl/zoomMeetingId/scheduledAt等) も含み、旧 SlpMeetingSessionZoom を吸収。
// state: "予定" | "取得中" | "完了" | "失敗" — ユーザー視点のステータス。
// ============================================
model SlpZoomRecording {
  id                          Int       @id @default(autoincrement())
  contactHistoryId            Int       @map("contact_history_id") // 1:N — UNIQUE 削除済み
  zoomMeetingId               BigInt    @unique @map("zoom_meeting_id") // Zoom Meeting IDはシステム全体でユニーク
  zoomMeetingUuid             String?   @map("zoom_meeting_uuid") @db.VarChar(200)
  category                    String    @db.VarChar(30) // "briefing" | "consultation"
  hostStaffId                 Int?      @map("host_staff_id")

  // ============================================
  // Zoom URL情報（旧 SlpMeetingSessionZoom から吸収）
  // ============================================
  joinUrl                     String    @default("") @map("join_url") @db.VarChar(1000)
  startUrl                    String?   @map("start_url") @db.VarChar(2000)
  password                    String?   @db.VarChar(100)
  scheduledAt                 DateTime? @map("scheduled_at")
  isPrimary                   Boolean   @default(true) @map("is_primary")
  label                       String?   @db.VarChar(100) // "延長分", "再実施" 等

  // ユーザー視点のステータス: "予定" | "取得中" | "完了" | "失敗"
  state                       String    @default("予定") @db.VarChar(20)

  // 通知送信済みフラグ（旧 SlpMeetingSessionZoom から移行、isPrimary=true のプライマリZoomでのみ使用）
  confirmSentAt               DateTime? @map("confirm_sent_at")
  remindDaySentAt             DateTime? @map("remind_day_sent_at")
  remindHourSentAt            DateTime? @map("remind_hour_sent_at")

  // Zoom API発行エラー（発行失敗時）
  zoomApiError                String?   @map("zoom_api_error") @db.Text
  zoomApiErrorAt              DateTime? @map("zoom_api_error_at")

  // ============================================
  // 録画・議事録データ（既存）
  // ============================================
  recordingStartAt            DateTime? @map("recording_start_at")
  recordingEndAt              DateTime? @map("recording_end_at")
  mp4Path                     String?   @map("mp4_path") @db.VarChar(1000)
  mp4SizeBytes                BigInt?   @map("mp4_size_bytes")
  transcriptPath              String?   @map("transcript_path") @db.VarChar(1000)
  transcriptText              String?   @map("transcript_text") @db.Text
  aiCompanionSummary          String?   @map("ai_companion_summary") @db.Text
  aiCompanionFetchedAt        DateTime? @map("ai_companion_fetched_at")
  summaryNextSteps            String?   @map("summary_next_steps") @db.Text
  chatLogPath                 String?   @map("chat_log_path") @db.VarChar(1000)
  chatLogText                 String?   @map("chat_log_text") @db.Text
  chatFetchedAt               DateTime? @map("chat_fetched_at")
  participantsJson            String?   @map("participants_json") @db.Text
  participantsFetchedAt       DateTime? @map("participants_fetched_at")
  claudeSummary               String?   @map("claude_summary") @db.Text
  claudeSummaryGeneratedAt    DateTime? @map("claude_summary_generated_at")
  claudeSummaryPromptSnapshot String?   @map("claude_summary_prompt_snapshot") @db.Text
  claudeSummaryModel          String?   @map("claude_summary_model") @db.VarChar(80)
  participantsExtracted       String?   @map("participants_extracted") @db.Text
  downloadStatus              String    @default("pending") @map("download_status") @db.VarChar(30) // "pending" | "in_progress" | "completed" | "failed" | "no_recording"
  downloadError               String?   @map("download_error") @db.Text
  zoomCloudDeletedAt          DateTime? @map("zoom_cloud_deleted_at")

  // 議事録を ContactHistory.meetingMinutes に追記済みかの判定用（二重追記防止）
  minutesAppendedAt           DateTime? @map("minutes_appended_at")
  // Claude生成議事録を ContactHistory.meetingMinutes に反映済みかの判定用
  claudeMinutesAppendedAt     DateTime? @map("claude_minutes_appended_at")

  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")
  deletedAt                   DateTime? @map("deleted_at")

  contactHistory SlpContactHistory @relation(fields: [contactHistoryId], references: [id], onDelete: Cascade)
  hostStaff      MasterStaff?      @relation("SlpZoomRecordingHost", fields: [hostStaffId], references: [id])

  @@index([contactHistoryId])
  @@index([state])
  @@index([downloadStatus])
  @@index([createdAt])
  @@map("slp_zoom_recordings")
}

// ============================================
// SLP 商談セッション (SLP Meeting Session)
// 概要案内・導入希望商談のラウンド毎のセッションを記録する。
// ラウンド番号 = 完了回数ベース（キャンセル/飛び/論理削除は番号消費しない）。
// 1ラウンドに複数試行あり得る（予約→キャンセル→再予約→完了）。
// 並列「予約中」は原則1つだが、プロラインwebhook重複時は複数許容（アプリで警告）。
// ============================================
model SlpMeetingSession {
  id              Int    @id @default(autoincrement())
  companyRecordId Int    @map("company_record_id")
  category        String @db.VarChar(20) // "briefing" | "consultation"
  roundNumber     Int    @map("round_number") // 1, 2, 3, ...
  status          String @db.VarChar(20) // "未予約" | "予約中" | "完了" | "キャンセル" | "飛び"
  source          String @db.VarChar(20) // "proline" | "manual"

  scheduledAt          DateTime? @map("scheduled_at") // 商談日時（status=未予約時はnull）
  assignedStaffId      Int?      @map("assigned_staff_id")
  prolineReservationId String?   @map("proline_reservation_id") @db.VarChar(100) // プロライン予約ID（webhook紐付け、manual時はnull）
  prolineStaffName     String?   @map("proline_staff_name") @db.VarChar(200)      // プロラインWebhookから受信した担当者名（生テキスト）。マッピング未登録時の警告UI用
  /// この商談を予約した担当者（SlpCompanyContact.id）。プロライン経由で予約された場合に webhook の LINE UID から解決して記録。
  /// 手動セットの場合は null。この担当者は receivesSessionNotifications フラグに関わらず必ず通知を受ける。
  bookerContactId      Int?      @map("booker_contact_id")

  bookedAt     DateTime? @map("booked_at") // 予約発生日時（予約中になった時点）
  completedAt  DateTime? @map("completed_at")
  cancelledAt  DateTime? @map("cancelled_at")
  noShowAt     DateTime? @map("no_show_at")
  cancelReason String?   @map("cancel_reason") @db.Text
  noShowReason String?   @map("no_show_reason") @db.Text

  notes String? @db.Text // スタッフメモ

  createdByStaffId Int?      @map("created_by_staff_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  companyRecord        SlpCompanyRecord           @relation("SlpCompanyRecordSessions", fields: [companyRecordId], references: [id], onDelete: Cascade)
  assignedStaff        MasterStaff?               @relation("SlpSessionAssignedStaff", fields: [assignedStaffId], references: [id])
  createdByStaff       MasterStaff?               @relation("SlpSessionCreatedBy", fields: [createdByStaffId], references: [id])
  bookerContact        SlpCompanyContact?         @relation("SessionBooker", fields: [bookerContactId], references: [id], onDelete: SetNull)
  histories            SlpMeetingSessionHistory[]
  reservationHistories SlpReservationHistory[]    @relation("SlpReservationHistorySession")
  zoomSendLogs         SlpZoomSendLog[]           @relation("SlpZoomSendLogSession")
  contactHistories     SlpContactHistory[]        @relation("SlpContactHistorySession")
  notifyOverrides      SlpSessionNotifyContact[]

  @@index([companyRecordId, category, roundNumber])
  @@index([companyRecordId, category, status])
  @@index([prolineReservationId])
  @@index([scheduledAt])
  @@index([bookerContactId])
  @@map("slp_meeting_sessions")
}

// ============================================
// SLP 商談セッション 通知対象 個別設定 (Session Notify Override)
// 各商談カードの「通知対象を個別設定」モーダルで設定する、この商談だけの通知対象リスト。
// 行が存在する → 個別モード（行のcontactだけに通知）
// 行が存在しない → デフォルトモード（予約者 + receivesSessionNotifications=true の担当者）
// キャンセル時・セッション削除時にクリア。
// ============================================
model SlpSessionNotifyContact {
  sessionId Int @map("session_id")
  contactId Int @map("contact_id")
  createdAt DateTime @default(now()) @map("created_at")

  session SlpMeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact SlpCompanyContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([sessionId, contactId])
  @@index([contactId])
  @@map("slp_session_notify_contacts")
}

// ============================================
// SLP 商談セッション 変更履歴 (SLP Meeting Session History)
// セッション作成・フィールド編集・ステータス変更・削除の全履歴を記録。
// ステータス変更時は理由の記載を必須とする（アプリレベル）。
// ============================================
model SlpMeetingSessionHistory {
  id        Int @id @default(autoincrement())
  sessionId Int @map("session_id")

  changedByStaffId Int?    @map("changed_by_staff_id")
  changeType       String  @map("change_type") @db.VarChar(30) // "created" | "field_edit" | "status_change" | "deleted" | "restored"
  fieldName        String? @map("field_name") @db.VarChar(100)
  oldValue         String? @map("old_value") @db.Text
  newValue         String? @map("new_value") @db.Text
  reason           String? @db.Text // 変更理由（status_change時は必須）

  changedAt DateTime @default(now()) @map("changed_at")

  session        SlpMeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  changedByStaff MasterStaff?      @relation("SlpSessionHistoryChangedBy", fields: [changedByStaffId], references: [id])

  @@index([sessionId, changedAt(sort: Desc)])
  @@map("slp_meeting_session_histories")
}

// ============================================
// SLP 通知テンプレート (SLP Notification Template)
// お客様・紹介者への全通知文面を一元管理。
// recipient × category × roundType × source × trigger の組み合わせでテンプレートを保存。
// 旧 SlpZoomMessageTemplate はこのテーブルに統合される。
// ============================================
model SlpNotificationTemplate {
  id Int @id @default(autoincrement())

  recipient String  @db.VarChar(20) // "customer" | "referrer"
  category  String  @db.VarChar(20) // "briefing" | "consultation"
  roundType String? @map("round_type") @db.VarChar(20) // "first" | "continuous"（referrerはnull）
  source    String? @db.VarChar(20) // "proline" | "manual"（referrerはnull）
  trigger   String  @db.VarChar(40) // "confirm" | "change" | "cancel" | "complete" | "remind_day_before" | "remind_hour_before" | "confirm_no_url" | "change_no_url" | "regenerated_manual_notice"

  formId String  @map("form_id") @db.VarChar(20) // "form16" | "form17" | "form18" | "form11" | "form13"
  label  String  @db.VarChar(200)
  body   String  @db.Text
  isActive Boolean @default(true) @map("is_active")

  updatedByStaffId Int?     @map("updated_by_staff_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  updatedBy MasterStaff? @relation("SlpNotificationTemplateUpdater", fields: [updatedByStaffId], references: [id])

  @@unique([recipient, category, roundType, source, trigger])
  @@index([recipient, category])
  @@map("slp_notification_templates")
}

// ============================================
// HOJO 接触履歴 (Hojo Contact Histories)
// 顧客種別: ベンダー / BBS / 貸金業社 / その他
// targetType で相手種別を識別し、各FKに紐付ける（otherは全てnull）
// ============================================
model HojoContactHistory {
  id                   Int      @id @default(autoincrement())
  contactDate          DateTime @map("contact_date")
  contactMethodId      Int?     @map("contact_method_id")
  contactCategoryId    Int?     @map("contact_category_id")
  assignedTo           String?  @map("assigned_to") @db.VarChar(500) // スタッフIDカンマ区切り
  customerParticipants String?  @map("customer_participants") @db.VarChar(500)
  meetingMinutes       String?  @map("meeting_minutes") @db.Text
  note                 String?  @db.Text
  staffId              Int?     @map("staff_id") // 作成スタッフ

  // ターゲット識別: "vendor" | "bbs" | "lender" | "other"
  // ベンダーのみ FK で紐付け、BBS/貸金業社/その他は顧客種別タグで分類
  targetType String @map("target_type") @db.VarChar(20)
  vendorId   Int?   @map("vendor_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  contactMethod   ContactMethod?   @relation(fields: [contactMethodId], references: [id])
  contactCategory ContactCategory? @relation(fields: [contactCategoryId], references: [id])
  staff           MasterStaff?     @relation("HojoContactHistoryStaff", fields: [staffId], references: [id])
  vendor          HojoVendor?      @relation("HojoContactHistoryVendor", fields: [vendorId], references: [id], onDelete: SetNull)

  tags           HojoContactHistoryTag[]
  files          HojoContactHistoryFile[]
  zoomRecordings HojoZoomRecording[]

  @@index([targetType, deletedAt])
  @@index([vendorId, deletedAt])
  @@index([contactDate])
  @@index([contactMethodId])
  @@index([contactCategoryId])
  @@index([staffId])
  @@map("hojo_contact_histories")
}

// ============================================
// HOJO 接触履歴 - 顧客種別タグ (中間テーブル)
// ============================================
model HojoContactHistoryTag {
  contactHistoryId Int      @map("contact_history_id")
  customerTypeId   Int      @map("customer_type_id")
  createdAt        DateTime @default(now()) @map("created_at")

  contactHistory HojoContactHistory @relation(fields: [contactHistoryId], references: [id], onDelete: Cascade)
  customerType   CustomerType       @relation("HojoContactHistoryTagCustomerType", fields: [customerTypeId], references: [id])

  @@id([contactHistoryId, customerTypeId])
  @@index([customerTypeId])
  @@map("hojo_contact_history_tags")
}

// ============================================
// HOJO 接触履歴 - 添付ファイル
// ============================================
model HojoContactHistoryFile {
  id               Int      @id @default(autoincrement())
  contactHistoryId Int      @map("contact_history_id")
  filePath         String?  @map("file_path") @db.VarChar(500) // ローカル保存パス
  fileName         String   @map("file_name") @db.VarChar(200)
  fileSize         Int?     @map("file_size")
  mimeType         String?  @map("mime_type") @db.VarChar(100)
  url              String?  @db.VarChar(1000) // 外部URL（Google Drive等）
  createdAt        DateTime @default(now()) @map("created_at")

  contactHistory HojoContactHistory @relation(fields: [contactHistoryId], references: [id], onDelete: Cascade)

  @@index([contactHistoryId])
  @@map("hojo_contact_history_files")
}

// ============================================
// HOJO Zoom 録画・議事録
// SLP側のSlpZoomRecording構造を踏襲。category/通知フラグは廃止。
// ============================================
model HojoZoomRecording {
  id                          Int       @id @default(autoincrement())
  contactHistoryId            Int       @map("contact_history_id")
  zoomMeetingId               BigInt    @unique @map("zoom_meeting_id")
  zoomMeetingUuid             String?   @map("zoom_meeting_uuid") @db.VarChar(200)
  hostStaffId                 Int?      @map("host_staff_id")

  // Zoom URL情報
  joinUrl                     String    @default("") @map("join_url") @db.VarChar(1000)
  startUrl                    String?   @map("start_url") @db.VarChar(2000)
  password                    String?   @db.VarChar(100)
  scheduledAt                 DateTime? @map("scheduled_at")
  isPrimary                   Boolean   @default(true) @map("is_primary")
  label                       String?   @db.VarChar(100)

  state                       String    @default("予定") @db.VarChar(20) // "予定" | "取得中" | "完了" | "失敗"

  // Zoom API発行エラー
  zoomApiError                String?   @map("zoom_api_error") @db.Text
  zoomApiErrorAt              DateTime? @map("zoom_api_error_at")

  // 録画・議事録データ
  recordingStartAt            DateTime? @map("recording_start_at")
  recordingEndAt              DateTime? @map("recording_end_at")
  mp4Path                     String?   @map("mp4_path") @db.VarChar(1000)
  mp4SizeBytes                BigInt?   @map("mp4_size_bytes")
  transcriptPath              String?   @map("transcript_path") @db.VarChar(1000)
  transcriptText              String?   @map("transcript_text") @db.Text
  aiCompanionSummary          String?   @map("ai_companion_summary") @db.Text
  aiCompanionFetchedAt        DateTime? @map("ai_companion_fetched_at")
  summaryNextSteps            String?   @map("summary_next_steps") @db.Text
  chatLogPath                 String?   @map("chat_log_path") @db.VarChar(1000)
  chatLogText                 String?   @map("chat_log_text") @db.Text
  chatFetchedAt               DateTime? @map("chat_fetched_at")
  participantsJson            String?   @map("participants_json") @db.Text
  participantsFetchedAt       DateTime? @map("participants_fetched_at")
  claudeSummary               String?   @map("claude_summary") @db.Text
  claudeSummaryGeneratedAt    DateTime? @map("claude_summary_generated_at")
  claudeSummaryPromptSnapshot String?   @map("claude_summary_prompt_snapshot") @db.Text
  claudeSummaryModel          String?   @map("claude_summary_model") @db.VarChar(80)
  participantsExtracted       String?   @map("participants_extracted") @db.Text
  downloadStatus              String    @default("pending") @map("download_status") @db.VarChar(30)
  downloadError               String?   @map("download_error") @db.Text
  zoomCloudDeletedAt          DateTime? @map("zoom_cloud_deleted_at")

  // 議事録追記済みフラグ（二重追記防止）
  minutesAppendedAt           DateTime? @map("minutes_appended_at")
  claudeMinutesAppendedAt     DateTime? @map("claude_minutes_appended_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  contactHistory HojoContactHistory @relation(fields: [contactHistoryId], references: [id], onDelete: Cascade)
  hostStaff      MasterStaff?       @relation("HojoZoomRecordingHost", fields: [hostStaffId], references: [id])

  @@index([contactHistoryId])
  @@index([state])
  @@index([downloadStatus])
  @@index([createdAt])
  @@map("hojo_zoom_recordings")
}

// ============================================
// HOJO 事業計画書生成プロンプト
// Claude に渡すSystemプロンプトをスタッフが編集できるようDB化
// {{sectionSpec}} / {{totalChars}} プレースホルダーをコード側で置換
// 単一レコード（id=1）運用
// ============================================
model HojoBusinessPlanPrompt {
  id               Int      @id @default(autoincrement())
  promptBody       String   @map("prompt_body") @db.Text
  model            String   @default("claude-sonnet-4-6") @db.VarChar(80)
  maxTokens        Int      @default(32000) @map("max_tokens")
  updatedByStaffId Int?     @map("updated_by_staff_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  updatedBy MasterStaff? @relation("HojoBusinessPlanPromptUpdater", fields: [updatedByStaffId], references: [id])

  @@map("hojo_business_plan_prompts")
}
