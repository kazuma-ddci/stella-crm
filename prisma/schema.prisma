// ============================================
// SLP 資料管理 (SLP Documents)
// 組合員向け配布資料（PDF）のアップロード・管理
// isActive=true の最新レコードが現在有効な資料
// ============================================

model SlpDocument {
  id           Int         @id @default(autoincrement())
  fileName     String      @db.VarChar(255) // アップロード時の元ファイル名
  filePath     String      @db.VarChar(500) // サーバー上の保存パス（public/uploads以下）
  fileSize     Int // ファイルサイズ（バイト）
