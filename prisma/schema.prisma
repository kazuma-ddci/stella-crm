// ============================================
// 補助金 ベンダー (Hojo Vendors)
// 補助金申請で連携するベンダーのマスタ
// ============================================

model HojoVendor {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(200)
  lineFriendId      Int?     @map("line_friend_id") // セキュリティクラウドLINE友達のID
  joseiLineFriendId Int?     @map("josei_line_friend_id") // 助成金申請サポートLINE友達のID
  accessToken       String   @unique @map("access_token") @db.VarChar(64) // ベンダー専用ページ用トークン
  memo              String?  @db.Text
  displayOrder      Int      @default(0) @map("display_order")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // --- ベンダー基本情報（ベンダー顧客リストより） ---
  representativeName         String? @map("representative_name") @db.VarChar(200)
  representativeLineFriendId Int?    @map("representative_line_friend_id")
  contactPersonName          String? @map("contact_person_name") @db.VarChar(200)
  contactPersonLineFriendId  Int?    @map("contact_person_line_friend_id")
  email                      String? @db.VarChar(255)
  phone                      String? @db.VarChar(50)

  // 全体の初回MTG（旧キックオフMTG位置）
  kickoffMtg DateTime? @map("kickoff_mtg")

  // 次の連絡日（全体用: 基本情報タブに表示）
  nextContactDate DateTime? @map("next_contact_date")
  // 次の連絡日（卸用: ベンダー一覧の卸関連カラムに表示）
  nextContactDateWholesale DateTime? @map("next_contact_date_wholesale")
  // 次の連絡日（コンサル用: ベンダー一覧のコンサル関連カラムに表示）
  nextContactDateConsulting DateTime? @map("next_contact_date_consulting")

  // セキュリティクラウド卸
  scWholesaleStatusId         Int?      @map("sc_wholesale_status_id")
  scWholesaleContractStatusId Int?      @map("sc_wholesale_contract_status_id")
  scWholesaleKickoffMtg       DateTime? @map("sc_wholesale_kickoff_mtg")
  scWholesaleContractDate     DateTime? @map("sc_wholesale_contract_date")
  scWholesaleEndDate          DateTime? @map("sc_wholesale_end_date")
  scWholesaleMemo             String?   @map("sc_wholesale_memo") @db.Text

  // コンサルティングプラン
  consultingPlanStatusId         Int?      @map("consulting_plan_status_id")
  consultingPlanContractStatusId Int?      @map("consulting_plan_contract_status_id")
  consultingPlanKickoffMtg       DateTime? @map("consulting_plan_kickoff_mtg")
  consultingPlanContractDate     DateTime? @map("consulting_plan_contract_date")
  consultingPlanEndDate          DateTime? @map("consulting_plan_end_date")
  consultingPlanMemo             String?   @map("consulting_plan_memo") @db.Text

  // 交付申請BPO
  grantApplicationBpo                 Boolean   @default(false) @map("grant_application_bpo")
  grantApplicationBpoContractStatusId Int?      @map("grant_application_bpo_contract_status_id")
  grantApplicationBpoKickoffMtg       DateTime? @map("grant_application_bpo_kickoff_mtg")
  grantApplicationBpoContractDate     DateTime? @map("grant_application_bpo_contract_date")
  grantApplicationBpoMemo             String?   @map("grant_application_bpo_memo") @db.Text

  // 助成金コンサルティング
  subsidyConsulting           Boolean   @default(false) @map("subsidy_consulting")
  subsidyConsultingKickoffMtg DateTime? @map("subsidy_consulting_kickoff_mtg")
  subsidyConsultingMemo       String?   @map("subsidy_consulting_memo") @db.Text

  // 貸金業者（旧: 貸金利用の有無）
  loanUsage           Boolean   @default(false) @map("loan_usage")
  loanUsageKickoffMtg DateTime? @map("loan_usage_kickoff_mtg")
  loanUsageMemo       String?   @map("loan_usage_memo") @db.Text

  // ベンダー登録の有無
  vendorRegistrationStatusId Int?    @map("vendor_registration_status_id")
  vendorRegistrationMemo     String? @map("vendor_registration_memo") @db.Text

  // ツール登録の有無
  toolRegistrationStatusId Int?    @map("tool_registration_status_id")
  toolRegistrationMemo     String? @map("tool_registration_memo") @db.Text

  // コンサルティングプラン金額情報
  consultingContractAmount Decimal? @map("consulting_contract_amount") @db.Decimal(12, 0)
  successFee               Decimal? @map("success_fee") @db.Decimal(12, 0)
  vendorSharedMemo         String?  @map("vendor_shared_memo") @db.Text

  // 担当AS（セキュリティクラウドLINEユーザーから選択 or 自動検出）
  assignedAsLineFriendId Int? @map("assigned_as_line_friend_id")

  // --- リレーション ---
  lineFriend                        HojoLineFriendSecurityCloud?       @relation("vendorLineFriend", fields: [lineFriendId], references: [id], onDelete: SetNull)
  representativeLineFriend          HojoLineFriendSecurityCloud?       @relation("vendorRepresentative", fields: [representativeLineFriendId], references: [id], onDelete: SetNull)
  contactPersonLineFriend           HojoLineFriendSecurityCloud?       @relation("vendorContactPerson", fields: [contactPersonLineFriendId], references: [id], onDelete: SetNull)
  joseiLineFriend                   HojoLineFriendJoseiSupport?        @relation(fields: [joseiLineFriendId], references: [id], onDelete: SetNull)
  scWholesaleStatus                 HojoVendorScWholesaleStatus?       @relation(fields: [scWholesaleStatusId], references: [id], onDelete: SetNull)
  scWholesaleContractStatus         HojoVendorContractStatus?          @relation("vendorScWholesaleContractStatus", fields: [scWholesaleContractStatusId], references: [id], onDelete: SetNull)
  consultingPlanStatus              HojoVendorConsultingPlanStatus?    @relation(fields: [consultingPlanStatusId], references: [id], onDelete: SetNull)
  consultingPlanContractStatus      HojoVendorContractStatus?          @relation("vendorConsultingPlanContractStatus", fields: [consultingPlanContractStatusId], references: [id], onDelete: SetNull)
  grantApplicationBpoContractStatus HojoVendorContractStatus?          @relation("vendorGrantApplicationBpoContractStatus", fields: [grantApplicationBpoContractStatusId], references: [id], onDelete: SetNull)
  vendorRegistrationStatus          HojoVendorRegistrationStatus?      @relation(fields: [vendorRegistrationStatusId], references: [id], onDelete: SetNull)
  toolRegistrationStatus            HojoVendorToolRegistrationStatus?  @relation(fields: [toolRegistrationStatusId], references: [id], onDelete: SetNull)
  assignedAsLineFriend              HojoLineFriendSecurityCloud?       @relation("vendorAssignedAs", fields: [assignedAsLineFriendId], references: [id], onDelete: SetNull)
  consultingStaff                   HojoVendorConsultingStaff[]
  contacts                          HojoVendorContact[]
  contractDocuments                 HojoVendorContractDocument[]
  applicationSupports               HojoApplicationSupport[]
  vendorAccounts                    HojoVendorAccount[]
  wholesaleAccounts                 HojoWholesaleAccount[]
  consultingContracts               HojoConsultingContract[]
  consultingActivities              HojoConsultingActivity[]
  grantCustomerPreApps              HojoGrantCustomerPreApplication[]
  grantCustomerPostApps             HojoGrantCustomerPostApplication[]
  loanProgresses                    HojoLoanProgress[]
  contactHistories                  HojoContactHistory[]               @relation("HojoContactHistoryVendor")

  @@map("hojo_vendors")
}

