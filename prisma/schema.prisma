  targetValue Int // 目標値（円 or 件数）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([yearMonth, kpiKey])
  @@map("kpi_monthly_targets")
}

// ============================================
// USDT日次レート (USDT Daily Rates)
// CoinGecko APIから取得したUSDT/JPYレートを日次で管理
// ============================================

model UsdtDailyRate {
