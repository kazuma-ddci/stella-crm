  // 報酬管理 - 代理店③
  agent3Number           String?   @map("agent3_number") @db.VarChar(100)
  agent3LineName         String?   @map("agent3_line_name") @db.VarChar(200)
  agent3Pct              Decimal?  @map("agent3_pct") @db.Decimal(5, 3)
  agent3Amount           Decimal?  @map("agent3_amount") @db.Decimal(12, 0)
  agent3PaymentDate      DateTime? @map("agent3_payment_date")
  agent3PaymentCompleted String?   @map("agent3_payment_completed") @db.VarChar(20)

  // その他
  vendorPattern String? @map("vendor_pattern") @db.VarChar(200)
  toolPattern   String? @map("tool_pattern") @db.VarChar(200)
  wageTable1    String? @map("wage_table_1") @db.VarChar(200)
  wageTable2    String? @map("wage_table_2") @db.VarChar(200)
  wageTable3    String? @map("wage_table_3") @db.VarChar(200)
  wageTable4    String? @map("wage_table_4") @db.VarChar(200)
  wageTable5    String? @map("wage_table_5") @db.VarChar(200)
  wageTable6    String? @map("wage_table_6") @db.VarChar(200)
  wageTable7    String? @map("wage_table_7") @db.VarChar(200)
  wageTable8    String? @map("wage_table_8") @db.VarChar(200)
  wageTable9    String? @map("wage_table_9") @db.VarChar(200)
  wageTable10   String? @map("wage_table_10") @db.VarChar(200)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vendor         HojoVendor                       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  preApplication HojoGrantCustomerPreApplication? @relation(fields: [preApplicationId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([preApplicationId])
  @@map("hojo_grant_customer_post_applications")
}

// ============================================
