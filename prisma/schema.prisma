  wageTable2  String? @map("wage_table_2") @db.VarChar(200)
  wageTable3  String? @map("wage_table_3") @db.VarChar(200)
  wageTable4  String? @map("wage_table_4") @db.VarChar(200)
  wageTable5  String? @map("wage_table_5") @db.VarChar(200)
  wageTable6  String? @map("wage_table_6") @db.VarChar(200)
