}

// SLP資料・動画閲覧アクセスログ
// 公式LINE経由で配布されたURLにアクセスがあるたびに記録
// uid・snsname・IPアドレス・アクセス時刻を保存し、流出元の特定に使用
model SlpDocumentAccessLog {
  id           Int      @id @default(autoincrement())
  uid          String   @db.VarChar(255) // LINEユーザーID（URLパラメータから取得）
  snsname      String   @db.VarChar(255) // LINE名（URLパラメータから取得）
  resourceType String   @default("document") @db.VarChar(20) // "document" | "video"
  ipAddress    String?  @db.VarChar(45) // IPv4/IPv6アドレス
  userAgent    String?  @db.Text // ブラウザUA文字列
  accessedAt   DateTime @default(now())

  @@index([uid])
  @@index([accessedAt])
  @@index([resourceType])
  @@map("slp_document_access_logs")
}

// ============================================
// SLP 代理店管理 (SLP Agencies)
// 代理店の階層構造管理（親→子→孫…無限階層）
// ============================================

model SlpAgencyContractStatus {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100) // ステータス名
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  agencies SlpAgency[]

  @@map("slp_agency_contract_statuses")
}

model SlpAgency {
  id                   Int       @id @default(autoincrement())
  name                 String    @db.VarChar(200) // 代理店名
  corporateName        String?   @map("corporate_name") @db.VarChar(200) // 法人名
  email                String?   @db.VarChar(255) // メールアドレス
  phone                String?   @db.VarChar(50) // 電話番号
  address              String?   @db.Text // 所在地
  contractStatusId     Int?      @map("contract_status_id") // 契約ステータス
  contractStartDate    DateTime? @map("contract_start_date") @db.Date // 契約開始日
  contractEndDate      DateTime? @map("contract_end_date") @db.Date // 契約終了日
  notes                String?   @db.Text // 備考
  // 事業形態・法人/個人事業主対応
  isIndividualBusiness Boolean   @default(false) @map("is_individual_business") // true=個人事業主, false=法人
  corporateNumber      String?   @map("corporate_number") @db.VarChar(13) // 法人番号
  representativeName   String?   @map("representative_name") @db.VarChar(100) // 代表者名
  representativePhone  String?   @map("representative_phone") @db.VarChar(50) // 代表者電話番号
  representativeEmail  String?   @map("representative_email") @db.VarChar(255) // 代表者メールアドレス
  parentId             Int?      @map("parent_id") // 親代理店ID（自己参照で無限階層）

  // 全顧客マスタとの紐付け（任意）
  masterCompanyId Int? @map("master_company_id")

  parent           SlpAgency?               @relation("AgencyHierarchy", fields: [parentId], references: [id])
  children         SlpAgency[]              @relation("AgencyHierarchy")
  contacts         SlpAgencyContact[]
  contractStatus   SlpAgencyContractStatus? @relation(fields: [contractStatusId], references: [id])
  masterCompany    MasterStellaCompany?     @relation("SlpAgencyToMaster", fields: [masterCompanyId], references: [id])
  contactHistories SlpContactHistory[]      @relation("SlpContactHistoryAgency")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([masterCompanyId])
  @@map("slp_agencies")
}

model SlpAgencyContact {
  id           Int     @id @default(autoincrement())
  agencyId     Int     @map("agency_id")
  name         String  @db.VarChar(200) // 名前
  role         String? @db.VarChar(100) // 役割
  email        String? @db.VarChar(255) // メールアドレス
  phone        String? @db.VarChar(50) // 電話番号
  lineFriendId Int?    @map("line_friend_id") // LINE番号（SlpLineFriend.id）

  agency     SlpAgency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  lineFriend SlpLineFriend? @relation("AgencyContactLineFriend", fields: [lineFriendId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("slp_agency_contacts")
}

// ============================================
// SLP 予約ペンディング情報 (SLP Reservation Pending)
// CRM中継URL → プロライン予約フォーム自動送信 → 予約完了webhook という流れで、
// 「どの企業の予約か」を CRM側で一意に紐付けるための一時情報。
// 中継URLでユーザーが企業を選択した瞬間にここへ保存し、
// プロライン側のフォームには企業名と一緒に token を hidden で送る。
// 予約完了 webhook 受信時、token でこのレコードを引いて正しい企業に紐付ける。
// ============================================

model SlpReservationPending {
  id                    Int       @id @default(autoincrement())
  token                 String    @unique @db.VarChar(64) // CRMが生成するランダムトークン（フォームhiddenで送る）
  uid                   String    @db.VarChar(100) // 対象ユーザーのプロラインUID
  reservationType       String    @map("reservation_type") @db.VarChar(20) // "briefing" | "consultation"
  companyRecordIds      Int[]     @map("company_record_ids") // 既存企業を選択した場合のレコードID配列
  newCompanyName        String?   @map("new_company_name") @db.VarChar(500) // 新規企業として予約する場合の企業名（カンマ区切り可）
  expectedCompanyName   String    @map("expected_company_name") @db.VarChar(500) // 整合性チェック用：CRMがフォームに送信した企業名
  // 年間人件費・従業員数（概要案内のform3-2,3,4で送られてくる値を参考に保持）
  // ※実際にはwebhook側でDBに直接書くので、ここには持たない
  createdAt             DateTime  @default(now()) @map("created_at")
  expiresAt             DateTime  @map("expires_at") // 30分後
  consumedAt            DateTime? @map("consumed_at") // webhook受信時に紐付けが完了した時刻
  consumedReservationId String?   @map("consumed_reservation_id") @db.VarChar(100) // 紐付けに使われた予約ID
  businessType          String?   @map("business_type") @db.VarChar(20) // "corporation" | "sole_proprietor"（予約時の事業形態）

  @@index([token])
  @@index([uid, createdAt])
  @@index([expiresAt])
  @@map("slp_reservation_pending")
}

// ============================================
// 自動化エラーログ (Automation Errors)
// Webhook・Cron等の自動化処理で発生したエラーを記録
// ============================================

model AutomationError {
  id        Int      @id @default(autoincrement())
  source    String   @db.VarChar(100) // エラー発生元（例: "cloudsign-webhook", "cron/remind-slp-members"）
  message   String   @db.VarChar(2000) // エラーメッセージ
  detail    String?  @db.Text // 追加詳細（JSON文字列）
  resolved  Boolean  @default(false) // 解決済みフラグ
  createdAt DateTime @default(now())

  @@map("automation_errors")
}

// ============================================
// 月次スナップショット (Monthly Snapshots)
// 月末時点の集計値を保存（代理店数など前月比計算用）
// ============================================

model MonthlySnapshot {
  id          Int      @id @default(autoincrement())
  yearMonth   String   @map("year_month") @db.VarChar(7) // "2026-03"
  snapshotKey String   @map("snapshot_key") @db.VarChar(50) // "active_agent_count" etc.
  value       Int // スナップショット値
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([yearMonth, snapshotKey])
  @@map("monthly_snapshots")
}

// ============================================
// アラート対応記録 (Alert Acknowledgments)
// アラートの「対応済み」状態を永続化する
// ============================================

model AlertAcknowledgment {
  id        Int      @id @default(autoincrement())
  alertType String   @map("alert_type") @db.VarChar(50) // "unpaid_invoice", "unsigned_contract", "kpi_behind"
  alertKey  String   @map("alert_key") @db.VarChar(200) // "invoice_group:42", "contract:15" 等
  staffId   Int?     @map("staff_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  staff MasterStaff? @relation(fields: [staffId], references: [id])

  @@unique([alertType, alertKey])
  @@map("alert_acknowledgments")
}

// ============================================
// アクティビティログ (Activity Logs)
// CRM内の全操作を自動記録する
// ============================================

model ActivityLog {
  id        Int      @id @default(autoincrement())
  tableName String   @map("table_name") @db.VarChar(100) // "stp_companies", "master_contracts" 等
  recordId  Int      @map("record_id") // 対象レコードのID
  action    String   @db.VarChar(10) // "create", "update", "delete"
  changes   Json? // 変更差分（update時: {field: {old, new}}）
  userId    Int?     @map("user_id") // 操作者のスタッフID
  createdAt DateTime @default(now()) @map("created_at")

  staff MasterStaff? @relation("ActivityLogStaff", fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================
// 補助金 Telegram通知ボット (Hojo Telegram Bots)
// Telegram Bot の接続情報を管理
// ============================================

model HojoTelegramBot {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100) // 表示名（例: "メイン通知Bot"）
  token     String   @db.VarChar(255) // Bot API トークン
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rules HojoTelegramNotificationRule[]

  @@map("hojo_telegram_bots")
}

// ============================================
// 補助金 Telegramグループ (送信先グループのマスタ)
// ============================================

model HojoTelegramGroup {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100) // 表示名（例: "補助金メイングループ"）
  chatId    String   @map("chat_id") @db.VarChar(50) // TelegramグループのチャットID
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  topics HojoTelegramTopic[]
  rules  HojoTelegramNotificationRule[]

  @@map("hojo_telegram_groups")
}

// ============================================
// 補助金 Telegramトピック (グループ内トピックのマスタ)
// ============================================

model HojoTelegramTopic {
  id        Int      @id @default(autoincrement())
  groupId   Int      @map("group_id")
  name      String   @db.VarChar(100) // 表示名（例: "塩澤チーム", "概要案内未予約"）
  topicId   String   @map("topic_id") @db.VarChar(50) // Telegramトピック（スレッド）ID
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group         HojoTelegramGroup              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fixedRules    HojoTelegramNotificationRule[] @relation("FixedTopic")
  staffMappings HojoTelegramTopicMapping[]

  @@map("hojo_telegram_topics")
}

// ============================================
// 補助金 Telegram通知ルール (Hojo Telegram Notification Rules)
// 1ルール = 1つのPHPファイルに相当。プロラインからの通知設定を管理
// ============================================

model HojoTelegramNotificationRule {
  id                   Int      @id @default(autoincrement())
  uuid                 String   @unique @default(uuid()) @db.VarChar(36) // URLに使うUUID
  name                 String   @db.VarChar(200) // ルール名（例: "申請予約通知"）
  botId                Int      @map("bot_id")
  groupId              Int?     @map("group_id") // 送信先グループ（group_direct / fixed時）
  eventType            String   @map("event_type") @db.VarChar(30) // "booking_new" | "booking_change" | "booking_cancel" | "custom"
  bookingPrefix        String?  @map("booking_prefix") @db.VarChar(10) // "cl1", "cl2" 等。customの場合null
  topicStrategy        String   @map("topic_strategy") @db.VarChar(20) // "staff_mapped" | "fixed" | "group_direct"
  fixedTopicId         Int?     @map("fixed_topic_id") // fixed時のHojoTelegramTopicのID
  messageTemplate      String   @map("message_template") @db.Text // プレースホルダー付きテンプレート
  customParams         Json?    @map("custom_params") // カスタムイベント時の追加パラメータ定義
  includeFormFields    Json?    @map("include_form_fields") // フォームフィールド名の配列
  duplicateLockSeconds Int      @default(180) @map("duplicate_lock_seconds")
  lineAccountType      String?  @map("line_account_type") @db.VarChar(30) // "josei-support" | "security-cloud"
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  bot           HojoTelegramBot               @relation(fields: [botId], references: [id], onDelete: Cascade)
  group         HojoTelegramGroup?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  fixedTopic    HojoTelegramTopic?            @relation("FixedTopic", fields: [fixedTopicId], references: [id], onDelete: SetNull)
  topicMappings HojoTelegramTopicMapping[]
  logs          HojoTelegramNotificationLog[]

  @@map("hojo_telegram_notification_rules")
}

// ============================================
// 補助金 Telegramトピックマッピング
// スタッフ名 → トピック/メンション の対応表
// ============================================

model HojoTelegramTopicMapping {
  id              Int      @id @default(autoincrement())
  ruleId          Int      @map("rule_id")
  staffName       String   @map("staff_name") @db.VarChar(50) // プロラインから来るスタッフ名
  telegramTopicId Int?     @map("telegram_topic_id") // FK → HojoTelegramTopic
  telegramMention String?  @map("telegram_mention") @db.VarChar(100) // "@username"
  isDefault       Boolean  @default(false) @map("is_default") // マッチしない場合のデフォルト
  createdAt       DateTime @default(now()) @map("created_at")

  rule  HojoTelegramNotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  topic HojoTelegramTopic?           @relation(fields: [telegramTopicId], references: [id], onDelete: SetNull)

  @@map("hojo_telegram_topic_mappings")
}

// ============================================
// 補助金 Telegram通知ログ（重複防止 + 送信履歴）
// ============================================

model HojoTelegramNotificationLog {
  id           Int      @id @default(autoincrement())
  ruleId       Int      @map("rule_id")
  requestHash  String   @map("request_hash") @db.VarChar(64) // パラメータのMD5ハッシュ
  status       String   @db.VarChar(20) // "sent" | "duplicate" | "error"
  params       Json? // 受信したパラメータ（デバッグ用）
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  rule HojoTelegramNotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, requestHash, createdAt])
  @@map("hojo_telegram_notification_logs")
}

// ============================================
// ベンダー管理 ステータスマスタ
// ============================================

model HojoVendorScWholesaleStatus {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  color        String   @default("gray") @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendors HojoVendor[]

  @@map("hojo_vendor_sc_wholesale_statuses")
}

model HojoVendorConsultingPlanStatus {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  color        String   @default("gray") @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendors HojoVendor[]

  @@map("hojo_vendor_consulting_plan_statuses")
}

model HojoVendorRegistrationStatus {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendors HojoVendor[]

  @@map("hojo_vendor_registration_statuses")
}

model HojoVendorToolRegistrationStatus {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendors HojoVendor[]

  @@map("hojo_vendor_tool_registration_statuses")
}

// ============================================
// ベンダー 契約状況マスタ（共通）
// セキュリティクラウド卸/コンサル/BPOで共通利用
// ============================================

model HojoVendorContractStatus {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scWholesaleVendors         HojoVendor[] @relation("vendorScWholesaleContractStatus")
  consultingPlanVendors      HojoVendor[] @relation("vendorConsultingPlanContractStatus")
  grantApplicationBpoVendors HojoVendor[] @relation("vendorGrantApplicationBpoContractStatus")

  @@map("hojo_vendor_contract_statuses")
}

// ============================================
// ベンダー 契約書（URL or アップロードファイル、複数）
// ============================================

model HojoVendorContractDocument {
  id           Int      @id @default(autoincrement())
  vendorId     Int      @map("vendor_id")
  serviceType  String   @map("service_type") @db.VarChar(50) // "scWholesale" | "consultingPlan" | "grantApplicationBpo"
  type         String   @db.VarChar(20) // "url" | "file"
  url          String?  @db.VarChar(1000)
  filePath     String?  @map("file_path") @db.VarChar(500)
  fileName     String?  @map("file_name") @db.VarChar(255)
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  vendor HojoVendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, serviceType])
  @@map("hojo_vendor_contract_documents")
}

// ============================================
// ベンダー コンサル担当者（多対多）
// ============================================

model HojoVendorConsultingStaff {
  id        Int      @id @default(autoincrement())
  vendorId  Int      @map("vendor_id")
  staffId   Int      @map("staff_id")
  createdAt DateTime @default(now()) @map("created_at")

  vendor HojoVendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  staff  MasterStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([vendorId, staffId])
  @@map("hojo_vendor_consulting_staff")
}

// ============================================
// コンサル/BPO 契約管理
// ============================================

model HojoConsultingContract {
  id                   Int       @id @default(autoincrement())
  vendorId             Int       @map("vendor_id")
  lineNumber           String?   @map("line_number") @db.VarChar(100)
  lineName             String?   @map("line_name") @db.VarChar(200)
  referralUrl          String?   @map("referral_url") @db.VarChar(500)
  assignedAs           String?   @map("assigned_as") @db.VarChar(200)
  consultingStaff      String?   @map("consulting_staff") @db.VarChar(200)
  companyName          String    @map("company_name") @db.VarChar(200)
  representativeName   String?   @map("representative_name") @db.VarChar(200)
  mainContactName      String?   @map("main_contact_name") @db.VarChar(200)
  customerEmail        String?   @map("customer_email") @db.VarChar(255)
  customerPhone        String?   @map("customer_phone") @db.VarChar(50)
  contractDate         DateTime? @map("contract_date")
  contractPlan         String?   @map("contract_plan") @db.VarChar(200)
  contractAmount       Decimal?  @map("contract_amount") @db.Decimal(12, 0)
  serviceType          String?   @map("service_type") @db.VarChar(200)
  caseStatus           String?   @map("case_status") @db.VarChar(100)
  hasScSales           Boolean   @default(false) @map("has_sc_sales")
  hasSubsidyConsulting Boolean   @default(false) @map("has_subsidy_consulting")
  hasBpoSupport        Boolean   @default(false) @map("has_bpo_support")
  consultingPlan       String?   @map("consulting_plan") @db.VarChar(200)
  successFee           Decimal?  @map("success_fee") @db.Decimal(12, 0)
  startDate            DateTime? @map("start_date")
  endDate              DateTime? @map("end_date")
  billingStatus        String?   @map("billing_status") @db.VarChar(100)
  paymentStatus        String?   @map("payment_status") @db.VarChar(100)
  revenueRecordingDate DateTime? @map("revenue_recording_date")
  grossProfit          Decimal?  @map("gross_profit") @db.Decimal(12, 0)
  notes                String?   @db.Text
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vendor     HojoVendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  activities HojoConsultingActivity[]

  @@index([vendorId])
  @@map("hojo_consulting_contracts")
}

// ============================================
// コンサル/BPO 活動記録
// ============================================

model HojoConsultingActivity {
  id            Int      @id @default(autoincrement())
  vendorId      Int      @map("vendor_id")
  contractId    Int?     @map("contract_id")
  activityDate  DateTime @map("activity_date")
  contactMethod String?  @map("contact_method") @db.VarChar(100)

  // ベンダー側が記入可能
  vendorIssue String? @map("vendor_issue") @db.Text

  // スタッフのみ（ベンダー非表示）
  hearingContent  String? @map("hearing_content") @db.Text
  responseContent String? @map("response_content") @db.Text
  proposalContent String? @map("proposal_content") @db.Text

  // ベンダー次回アクション
  vendorNextAction String?   @map("vendor_next_action") @db.Text
  nextDeadline     DateTime? @map("next_deadline")

  // ベンダータスク
  vendorTask          String?   @map("vendor_task") @db.VarChar(500)
  vendorTaskDeadline  DateTime? @map("vendor_task_deadline")
  vendorTaskPriority  String?   @map("vendor_task_priority") @db.VarChar(20)
  vendorTaskCompleted Boolean   @default(false) @map("vendor_task_completed")

  // 申請サポートタスク（ベンダー非表示）
  supportTask          String?   @map("support_task") @db.VarChar(500)
  supportTaskDeadline  DateTime? @map("support_task_deadline")
  supportTaskPriority  String?   @map("support_task_priority") @db.VarChar(20)
  supportTaskCompleted Boolean   @default(false) @map("support_task_completed")

  // 添付（複数URL対応・JSON配列）
  attachmentUrls Json? @map("attachment_urls") // string[]
  recordingUrls  Json? @map("recording_urls") // string[]
  screenshotUrls Json? @map("screenshot_urls") // string[]

  // ベンダー側のみ記入可能
  notes String? @db.Text

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vendor   HojoVendor                   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  contract HojoConsultingContract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)
  tasks    HojoConsultingActivityTask[]

  @@index([vendorId])
  @@index([contractId])
  @@map("hojo_consulting_activities")
}

// ============================================
// コンサル履歴 タスク（ベンダー様/コンサルチーム共通）
// 1つのactivityに複数のタスクを紐付けられる
// ============================================

model HojoConsultingActivityTask {
  id           Int       @id @default(autoincrement())
  activityId   Int       @map("activity_id")
  taskType     String    @map("task_type") @db.VarChar(20) // "vendor" | "consulting_team"
  content      String?   @db.Text
  deadline     DateTime?
  priority     String?   @db.VarChar(20) // 高/中/低
  completed    Boolean   @default(false)
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activity HojoConsultingActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("hojo_consulting_activity_tasks")
}

// ============================================
