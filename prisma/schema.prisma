  scenarioPos4        String? // 現在の場所4
  scenarioPos5        String? // 現在の場所5
  sortOrder           Int       @default(0) @map("sort_order") // 廃止予定（レガシー: ProLine同期時の連番）。idで代替
  form4NotifyCount    Int       @default(0) // Form4（友だち追加通知）送信回数
  isManuallyAdded     Boolean   @default(false) @map("is_manually_added") // true=CRMから手動追加（編集・削除可）, false=プロライン同期/Webhook由来（編集・削除不可）
  referrerNotRequired Boolean   @default(false) @map("referrer_not_required") // true=紹介者不要（free1が空でも警告しない）
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  companyContacts      SlpCompanyContact[]
  prolineStaffMappings SlpProlineStaffMapping[]
  asLinks              SlpAs[]                       @relation("LineFriendAsLinks")
  agencyContacts       SlpAgencyContact[]            @relation("AgencyContactLineFriend")
  contactHistoryLinks  SlpContactHistoryLineFriend[]

